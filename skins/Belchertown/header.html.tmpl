        #if not $load_core_js
        <script>
            (function() {
                function ensureDarkThemeStylesheet() {
                    if (document.getElementById("belchertownDarkStyle")) {
                        return;
                    }

                    var darkStylesheet = document.createElement("link");
                    darkStylesheet.id = "belchertownDarkStyle";
                    darkStylesheet.rel = "stylesheet";
                    darkStylesheet.type = "text/css";
                    darkStylesheet.media = "all";
                    darkStylesheet.href = "$relative_url/belchertown-dark.min.css?ver=$asset_version";
                    document.head.appendChild(darkStylesheet);
                }

                function setSimpleTheme(themeName, toggleOverride) {
                    if (toggleOverride) {
                        sessionStorage.setItem("theme", "toggleOverride");
                    }

                    if (themeName === "dark") {
                        ensureDarkThemeStylesheet();
                        document.body.classList.add("dark");
                        document.body.classList.remove("light");
                        sessionStorage.setItem("currentTheme", "dark");
                        #if $Extras.has_key('logo_image_dark') and $Extras.logo_image_dark != ""
                        var darkLogo = document.getElementById("logo_image");
                        if (darkLogo) {
                            darkLogo.setAttribute("src", "$Extras.logo_image_dark");
                        }
                        #end if
                    } else if (themeName === "light") {
                        document.body.classList.add("light");
                        document.body.classList.remove("dark");
                        sessionStorage.setItem("currentTheme", "light");
                        #if $Extras.has_key('logo_image') and $Extras.logo_image != ""
                        var lightLogo = document.getElementById("logo_image");
                        if (lightLogo) {
                            lightLogo.setAttribute("src", "$Extras.logo_image");
                        }
                        #end if
                    }

                    var themeSwitch = document.getElementById("themeSwitch");
                    if (themeSwitch) {
                        themeSwitch.checked = themeName === "dark";
                    }
                }

                function initSimpleTheme() {
                    var requestedTheme = "";
                    try {
                        requestedTheme = new URLSearchParams(window.location.search).get("theme") || "";
                    } catch (err) {
                        requestedTheme = "";
                    }

                    if (requestedTheme === "dark" || requestedTheme === "light") {
                        setSimpleTheme(requestedTheme, true);
                    } else if (requestedTheme === "auto") {
                        sessionStorage.setItem("theme", "auto");
                        setSimpleTheme("$bodyTheme", false);
                    } else if (sessionStorage.getItem("theme") === "toggleOverride") {
                        setSimpleTheme(sessionStorage.getItem("currentTheme") || "$bodyTheme", false);
                    }

                    var themeSwitch = document.getElementById("themeSwitch");
                    if (themeSwitch) {
                        themeSwitch.addEventListener("change", function(event) {
                            setSimpleTheme(event.target.checked ? "dark" : "light", true);
                        });
                    }
                }

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", initSimpleTheme);
                } else {
                    initSimpleTheme();
                }
            })();
        </script>
