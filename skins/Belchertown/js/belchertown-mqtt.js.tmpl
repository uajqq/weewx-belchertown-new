// #if $Extras.has_key("mqtt_websockets_enabled") and $Extras.mqtt_websockets_enabled == '1'
//============================================//
// Live website using MQTT Websockets enabled //
//============================================//

var mqttConnected = false;

function ajaximages(section = false, reload_timer_interval_seconds = false) {
    // This function only runs if the elements have an img src.
    // Update images within the specific section
    if (!section || section == "radar") {
        belchertown_debug("Updating radar image");
        // Reload images
        if (document.querySelectorAll(".radar-map img").length > 0) {
            var radar_img = document.querySelectorAll(".radar-map img")[0].src;
            var new_radar_img = radar_img + "&t=" + Math.floor(Math.random() * 999999999);
            document.querySelectorAll(".radar-map img")[0].src = new_radar_img;
            //var radar_html = jQuery('.radar-map').children('img').attr('src').split('?')[0] // Get the img src and remove everything after "?" so we don't stack ?'s onto the image during updates
            //jQuery('.radar-map').children('img').attr('src', radar_html + "?" + Math.floor(Math.random() * 999999999));
        }
        // Reload iframe - https://stackoverflow.com/a/4249946/1177153
        if (document.querySelectorAll(".radar-map iframe").length > 0) {
            jQuery(".radar-map iframe").each(function() {
                jQuery(this).attr('src', function(i, val) {return val;});
            });
        }
    } else if (!section || section != "radar") {
        belchertown_debug("Updating " + section + " images");
        // Reload images
        jQuery('.' + section + ' img').each(function() {
            new_image_url = jQuery(this).attr('src').split('?')[0] + "?" + Math.floor(Math.random() * 999999999);
            jQuery(this).attr('src', new_image_url);
        });
        // Reload iframes
        jQuery('.' + section + ' iframe').each(function() {
            jQuery(this).attr('src', function(i, val) {return val;});
        });
    }
    // Set the new timer
    if (reload_timer_interval_seconds) {
        var reload_timer_ms = reload_timer_interval_seconds * 1000; // convert to millis
        setTimeout(function() {ajaximages(section, reload_timer_interval_seconds);}, reload_timer_ms);
    }
}

var reconnect_using_inactive_timestamp = false;
var inactive_timestamp = "";
var mqtt_connect_retry_count = 0;
var mqtt_max_connect_retries = 20;
var mqtt_activity_timeout = null;
var mqtt_stale_timeout = null;
var mqtt_last_message_received_ms = 0;
var mqtt_last_data_epoch = "";
var mqtt_inactive_disconnect_requested = false;
var mqtt_stale_timeout_seconds = parseFloat("$Extras.last_updated_alert_threshold");
var mqtt_relative_updated_epoch = null;
var mqtt_relative_updated_message = "";
var mqtt_relative_updated_timer = null;
var mqtt_receiving_indicator_timeout = null;
if (!isFinite(mqtt_stale_timeout_seconds) || mqtt_stale_timeout_seconds <= 0) {
    mqtt_stale_timeout_seconds = 1800;
}
mqtt_stale_timeout_seconds = Math.max(mqtt_stale_timeout_seconds, 30);
var mqtt_stale_timeout_ms = mqtt_stale_timeout_seconds * 1000;

function mqtt_restart_button_html() {
    return " <button type='button' class='btn btn-primary restart-interval'>$obs.label.mqtt_websockets_continue</button>";
}

function mqtt_relative_time(epoch) {
    var timestamp = parseFloat(epoch);
    return isFinite(timestamp) ? tzAdjustedMoment(timestamp).fromNow() : "";
}

function mqtt_absolute_time(epoch) {
    var timestamp = parseFloat(epoch);
    return isFinite(timestamp) ? tzAdjustedMoment(timestamp).format("$obs.label.time_last_updated") : "";
}

function mqtt_sentence_text(parts) {
    var text = parts
        .map(function(part) {
            return String(part || "").trim().replace(/[\.\s]+$/, "");
        })
        .filter(function(part) {
            return part !== "";
        })
        .join(" ");
    return text ? text + "." : "";
}

function mqtt_render_relative_updated_status() {
    if (mqtt_relative_updated_epoch === null || !mqtt_relative_updated_message) {
        return;
    }

    var relative_time = mqtt_relative_time(mqtt_relative_updated_epoch);
    var absolute_time = mqtt_absolute_time(mqtt_relative_updated_epoch);
    jQuery(".updated")
        .text(mqtt_sentence_text([mqtt_relative_updated_message, relative_time]))
        .attr("title", absolute_time ? mqtt_sentence_text([mqtt_relative_updated_message, absolute_time]) : "");
}

function mqtt_start_relative_updated_timer() {
    if (mqtt_relative_updated_timer !== null) {
        return;
    }
    mqtt_relative_updated_timer = setInterval(mqtt_render_relative_updated_status, 30000);
}

function mqtt_clear_relative_updated_status() {
    mqtt_relative_updated_epoch = null;
    mqtt_relative_updated_message = "";
    if (mqtt_relative_updated_timer !== null) {
        clearInterval(mqtt_relative_updated_timer);
        mqtt_relative_updated_timer = null;
    }
}

function mqtt_clear_receiving_indicator() {
    if (mqtt_receiving_indicator_timeout !== null) {
        clearTimeout(mqtt_receiving_indicator_timeout);
        mqtt_receiving_indicator_timeout = null;
    }
    jQuery(".onlineMarker").removeClass("mqtt-receiving");
}

function mqtt_mark_receiving_data() {
    var marker = jQuery(".onlineMarker");
    if (mqtt_receiving_indicator_timeout !== null) {
        clearTimeout(mqtt_receiving_indicator_timeout);
    }
    marker.removeClass("mqtt-receiving");
    if (marker.length) {
        marker[0].offsetWidth;
    }
    marker.addClass("mqtt-receiving");
    mqtt_receiving_indicator_timeout = setTimeout(function() {
        mqtt_receiving_indicator_timeout = null;
        mqtt_clear_receiving_indicator();
    }, 1000);
}

function mqtt_set_updated_html(html) {
    mqtt_clear_relative_updated_status();
    mqtt_clear_receiving_indicator();
    jQuery(".updated").removeAttr("title").html(html);
}

function mqtt_set_relative_updated_status(message, epoch) {
    var timestamp = parseFloat(epoch);
    if (!isFinite(timestamp)) {
        mqtt_set_updated_html(message);
        return;
    }

    mqtt_relative_updated_message = message;
    mqtt_relative_updated_epoch = timestamp;
    mqtt_render_relative_updated_status();
    mqtt_start_relative_updated_timer();
}

function mqtt_safe_client_connected() {
    try {
        return typeof client !== "undefined" && client && typeof client.isConnected === "function" && client.isConnected();
    } catch (e) {
        belchertown_debug("MQTT: Unable to read client connection state: " + e.message);
        return false;
    }
}

function mqtt_clear_activity_timeout() {
    if (mqtt_activity_timeout) {
        clearTimeout(mqtt_activity_timeout);
        mqtt_activity_timeout = null;
    }
}

function mqtt_clear_stale_timeout() {
    if (mqtt_stale_timeout) {
        clearTimeout(mqtt_stale_timeout);
        mqtt_stale_timeout = null;
    }
}

function mqtt_set_disconnected_status(message, epoch, show_restart) {
    mqttConnected = false;
    mqtt_clear_activity_timeout();
    mqtt_clear_stale_timeout();
    jQuery(".onlineMarker").hide();
    jQuery(".offlineMarker").show();
    jQuery(".loadingMarker").hide();

    var updated_epoch = epoch || mqtt_last_data_epoch || "$current.dateTime.raw";
    var updated = tzAdjustedMoment(updated_epoch).format("$obs.label.time_last_updated");
    var restart_button = show_restart ? mqtt_restart_button_html() : "";
    mqtt_set_updated_html(message + " $obs.label.header_last_updated " + updated + restart_button);
}

function mqtt_schedule_activity_timeout() {
    mqtt_clear_activity_timeout();

    var timeout_ms = parseFloat("$Extras.disconnect_live_website_visitor");
    if (!isFinite(timeout_ms) || timeout_ms <= 0) {
        belchertown_debug("MQTT: Inactivity timeout disabled by configuration");
        return;
    }
    if (getURLvar("stayconnected") && (getURLvar("stayconnected") == "true" || getURLvar("stayconnected") == "1")) {
        belchertown_debug("MQTT: URL parameter 'stayconnected' detected - inactivity timeout disabled");
        return;
    }
    if (pageName == "pi" || pageName == "kiosk.html") {
        belchertown_debug("MQTT: Page type '" + pageName + "' detected - inactivity timeout disabled");
        return;
    }

    belchertown_debug("MQTT: Inactivity timeout set to " + timeout_ms + " ms");
    mqtt_activity_timeout = setTimeout(inactive, timeout_ms);
}

function mqtt_schedule_stale_timeout() {
    mqtt_clear_stale_timeout();

    mqtt_stale_timeout = setTimeout(function() {
        if (!mqttConnected) {
            return;
        }

        var last_seen = mqtt_last_message_received_ms || 0;
        if (last_seen && (Date.now() - last_seen) < mqtt_stale_timeout_ms) {
            mqtt_schedule_stale_timeout();
            return;
        }

        var epoch = mqtt_last_data_epoch || parseFloat(Date.now() / 1000).toFixed(0);
        belchertown_debug("MQTT: No messages received for " + mqtt_stale_timeout_seconds + " seconds. Marking connection stale.");
        reconnect_using_inactive_timestamp = true;
        inactive_timestamp = epoch;
        mqtt_inactive_disconnect_requested = true;
        try {
            if (mqtt_safe_client_connected()) {
                client.disconnect();
            }
        } catch (e) {
            belchertown_debug("MQTT: Disconnect after stale timeout failed: " + e.message);
        }
        mqtt_set_disconnected_status("$obs.label.mqtt_websockets_lost", epoch, true);
    }, mqtt_stale_timeout_ms + 1000);
}

function mqtt_note_message_activity(data) {
    mqttConnected = true;
    mqtt_last_message_received_ms = Date.now();
    mqtt_mark_receiving_data();
    if (data && data.hasOwnProperty("dateTime")) {
        var data_epoch = parseFloat(data["dateTime"]);
        if (isFinite(data_epoch)) {
            mqtt_last_data_epoch = data_epoch.toFixed(0);
        }
    }
    mqtt_schedule_stale_timeout();
}

// MQTT connect
function connect() {
    mqtt_clear_activity_timeout();
    mqtt_clear_stale_timeout();
    mqtt_inactive_disconnect_requested = false;

    if (typeof window.Paho === "undefined" || typeof window.Paho.Client !== "function") {
        mqtt_connect_retry_count++;
        belchertown_debug("MQTT: Paho library not ready (attempt " + mqtt_connect_retry_count + "). Retrying shortly.");
        if (mqtt_connect_retry_count <= mqtt_max_connect_retries) {
            setTimeout(connect, 500);
        } else {
            console.error("MQTT: Paho library failed to load after retries. Aborting connect.");
            mqtt_set_disconnected_status("$obs.label.mqtt_websockets_failed", "$current.dateTime.raw", true);
        }
        return;
    }

    mqtt_connect_retry_count = 0;

    var clientId = (typeof mqttclient !== "undefined" && mqttclient)
        ? mqttclient
        : (window.mqttclient || (window.mqttclient = "website" + Math.floor(Math.random() * 999999999)));

    belchertown_debug("MQTT: [" + new Date().toISOString() + "] Starting connection sequence");
    if (reconnect_using_inactive_timestamp) {
        updated = tzAdjustedMoment(inactive_timestamp).format("$obs.label.time_last_updated");
        belchertown_debug("MQTT: Reconnecting using inactive timestamp: " + inactive_timestamp);
    } else {
        updated = tzAdjustedMoment("$current.dateTime.raw").format("$obs.label.time_last_updated");
        belchertown_debug("MQTT: Initial connection attempt");
    }
    reported = "$obs.label.mqtt_websockets_connecting $obs.label.header_last_updated " + updated;
    mqtt_set_updated_html(reported);
    jQuery(".onlineMarker").hide();
    jQuery(".offlineMarker").hide();
    jQuery(".loadingMarker").show();
    belchertown_debug("MQTT: UI markers updated for connection state");

    // #if $Extras.has_key("mqtt_websockets_host_kiosk") and $Extras.mqtt_websockets_host_kiosk != ""
    if (pageName == "kiosk.html") {
        // #if $Extras.has_key("mqtt_websockets_ssl_kiosk") and $Extras.mqtt_websockets_ssl_kiosk == '1'
        belchertown_debug("MQTT: [Kiosk Mode] Connecting to: $Extras.mqtt_websockets_host_kiosk:$mqtt_websockets_port_kiosk (SSL: Enabled)");
        var useSSL = true;
        // #else
        belchertown_debug("MQTT: [Kiosk Mode] Connecting to: $Extras.mqtt_websockets_host_kiosk:$mqtt_websockets_port_kiosk (SSL: Disabled)");
        var useSSL = false;
        // #end if
        belchertown_debug("MQTT: Creating Paho MQTT client for kiosk page");
        client = new Paho.Client("$Extras.mqtt_websockets_host_kiosk", $mqtt_websockets_port_kiosk, clientId);
    }
    else {
        // #if $Extras.has_key("mqtt_websockets_ssl") and $Extras.mqtt_websockets_ssl == '1'
        belchertown_debug("MQTT: [Standard Mode] Connecting to: $Extras.mqtt_websockets_host:$Extras.mqtt_websockets_port (SSL: Enabled)");
        var useSSL = true;
        // #else
        belchertown_debug("MQTT: [Standard Mode] Connecting to: $Extras.mqtt_websockets_host:$Extras.mqtt_websockets_port (SSL: Disabled)");
        var useSSL = false;
        // #end if
        belchertown_debug("MQTT: Creating Paho MQTT client for standard page");
        client = new Paho.Client("$Extras.mqtt_websockets_host", $Extras.mqtt_websockets_port, clientId);
    }
    // #else
    // #if $Extras.has_key("mqtt_websockets_ssl") and $Extras.mqtt_websockets_ssl == '1'
    belchertown_debug("MQTT: [Fallback] Connecting to: $Extras.mqtt_websockets_host:$Extras.mqtt_websockets_port (SSL: Enabled)");
    var useSSL = true;
    // #else
    belchertown_debug("MQTT: [Fallback] Connecting to: $Extras.mqtt_websockets_host:$Extras.mqtt_websockets_port (SSL: Disabled)");
    var useSSL = false;
    // #end if
    belchertown_debug("MQTT: Creating Paho MQTT client (fallback configuration)");
    client = new Paho.Client("$Extras.mqtt_websockets_host", $Extras.mqtt_websockets_port, clientId);
    // #end if
    client.onConnectionLost = onConnectionLost;
    client.onMessageArrived = onMessageArrived;
    belchertown_debug("MQTT: Event handlers registered (onConnectionLost, onMessageArrived)");
    var options = {
        useSSL: useSSL,
        // #if $Extras.has_key("mqtt_websockets_username") and $Extras.has_key("mqtt_websockets_password") and $Extras.mqtt_websockets_username != "" and $Extras.mqtt_websockets_password != ""
        userName: "$Extras.mqtt_websockets_username",
        password: "$Extras.mqtt_websockets_password",
        // #end if
        // mqttVersion: 4 is spec MQTTv3.1.1 - mqttVersion: 3 is spec MQTTv3.1
        mqttVersion: 4,
        // If mqttVersionExplicit is true, it will force the connection to use the selected MQTT Version or will fail to connect.
        // If mqttVersionExplicit is false and mqttVersion is 4, it will try mqttVersion: 4 and if it fails it will fallback to mqttVersion: 3
        // Here's the relevant code: https://github.com/eclipse/paho.mqtt.javascript/blob/f5859463aba9a9b7c19f99ab7c4849a723f8d832/src/paho-mqtt.js#L1610
        mqttVersionExplicit: false,
        reconnect: true,
        onSuccess: onConnect,
        onFailure: onFailure
    }
    belchertown_debug("MQTT: Connection options configured - MQTT Version: 4, Auto-reconnect: enabled, mqttVersionExplicit: false");
    // #if $Extras.has_key("mqtt_websockets_username") and $Extras.has_key("mqtt_websockets_password") and $Extras.mqtt_websockets_username != "" and $Extras.mqtt_websockets_password != ""
    belchertown_debug("MQTT: Authentication credentials configured");
    // #end if
    belchertown_debug("MQTT: [" + new Date().toISOString() + "] Initiating connection to broker");
    client.connect(options);
}

// MQTT connect callback
function onConnect() {
    mqttConnected = true;
    mqtt_inactive_disconnect_requested = false;
    mqtt_last_message_received_ms = Date.now();
    belchertown_debug("MQTT: [" + new Date().toISOString() + "] Successfully connected to broker");
    belchertown_debug("MQTT: Client state is now CONNECTED");
    if (reconnect_using_inactive_timestamp) {
        updated = tzAdjustedMoment(inactive_timestamp).format("$obs.label.time_last_updated");
        belchertown_debug("MQTT: Reconnection successful after inactivity");
    } else {
        updated = tzAdjustedMoment("$current.dateTime.raw").format("$obs.label.time_last_updated");
        belchertown_debug("MQTT: Initial connection successful");
    }
    if (pageName == "pi") {
        reported = "$obs.label.mqtt_websockets_waiting_pi $obs.label.header_last_updated " + updated;
    } else {
        reported = "$obs.label.mqtt_websockets_waiting $obs.label.header_last_updated " + updated;
    }
    mqtt_set_updated_html(reported);
    jQuery(".onlineMarker").hide();
    jQuery(".offlineMarker").hide();
    jQuery(".loadingMarker").show();
    belchertown_debug("MQTT: Subscribing to topic: $Extras.mqtt_websockets_topic");
    client.subscribe("$Extras.mqtt_websockets_topic");
    belchertown_debug("MQTT: Topic subscription request sent");
    mqtt_schedule_activity_timeout();
    mqtt_schedule_stale_timeout();
}

// MQTT Failure
function onFailure() {
    mqttConnected = false;
    var d = new Date();
    epoch = parseFloat((d / 1000)).toFixed(0); // Convert millis to seconds
    var timestamp = d.toISOString();
    belchertown_debug("MQTT: [" + timestamp + "] Connection FAILED");
    belchertown_debug("MQTT: Client state is now DISCONNECTED (failure)");
    if (!mqtt_safe_client_connected()) {
        epoch = mqtt_last_data_epoch || "$current.dateTime.raw";
    }
    reconnect_using_inactive_timestamp = true;
    inactive_timestamp = epoch;
    mqtt_set_disconnected_status("$obs.label.mqtt_websockets_failed", epoch, true);
    console.error("MQTT: " + timestamp + " - Connection Failed - Unable to connect to MQTT broker");
    belchertown_debug("MQTT: UI markers updated for failure state");
}

// MQTT connection lost
function onConnectionLost(responseObject) {
    if (mqtt_inactive_disconnect_requested) {
        belchertown_debug("MQTT: Connection lost after an intentional timeout disconnect; keeping stopped UI state");
        return;
    }

    responseObject = responseObject || {};
    mqttConnected = false;
    var d = new Date();
    epoch = parseFloat((d / 1000)).toFixed(0);  // Convert millis to seconds
    var timestamp = d.toISOString();
    belchertown_debug("MQTT: [" + timestamp + "] Connection LOST");
    belchertown_debug("MQTT: Client state is now DISCONNECTED (lost)");
    if (!mqtt_safe_client_connected()) {
        epoch = mqtt_last_data_epoch || "$current.dateTime.raw";
    }
    reconnect_using_inactive_timestamp = true;
    inactive_timestamp = epoch;
    mqtt_set_disconnected_status("$obs.label.mqtt_websockets_lost", epoch, true);
    if (typeof responseObject.errorCode !== "undefined" && responseObject.errorCode !== 0) {
        var errorMsg = "Error Code: " + responseObject.errorCode + " - " + (responseObject.errorMessage || "Unknown error");
        console.error("MQTT: " + timestamp + " - Connection Lost: " + errorMsg);
        belchertown_debug("MQTT: Error details - " + errorMsg);
    } else {
        console.error("MQTT: " + timestamp + " - Connection Lost (graceful disconnect)");
        belchertown_debug("MQTT: Connection lost (normal/graceful)");
    }
    belchertown_debug("MQTT: UI markers updated for disconnected state");
}

function inactive() {
    var timestamp = new Date().toISOString();
    var d = new Date();
    epoch = parseFloat((d / 1000)).toFixed(0);  // Convert millis to seconds
    belchertown_debug("MQTT: [" + timestamp + "] Inactivity timeout triggered - initiating disconnect");
    belchertown_debug("MQTT: Total messages received during session: " + mqtt_message_count);
    reconnect_using_inactive_timestamp = true; // Set a flag to use the inactive timestamp in case we reconnect we have the latest last updated time
    inactive_timestamp = epoch; // Store this timestamp in case we reconnect
    mqtt_inactive_disconnect_requested = true;
    try {
        if (mqtt_safe_client_connected()) {
            client.disconnect(); // Disconnect mqtt
            belchertown_debug("MQTT: Client disconnect command issued");
        } else {
            belchertown_debug("MQTT: Client was already disconnected before inactivity timeout cleanup");
        }
    } catch (e) {
        belchertown_debug("MQTT: Disconnect during inactivity timeout failed: " + e.message);
    }
    mqtt_set_disconnected_status("$obs.label.mqtt_websockets_stopped", epoch, true);
    belchertown_debug("MQTT: Inactive mode activated - awaiting user interaction to resume");
}

var mqtt_payload = "";
var mqtt_message_count = 0;
var mqtt_latest_payload = null;
var mqtt_update_scheduled = false;
var mqttStatusElements = null;
var mqttGtagConfigured = false;
var stationObservationElementsByKey = null;
var stationObservationUseGroupingByKey = null;

function get_mqtt_status_elements() {
    if (mqttStatusElements) {
        return mqttStatusElements;
    }

    mqttStatusElements = {
        onlineMarkerEl: jQuery(".onlineMarker"),
        offlineMarkerEl: jQuery(".offlineMarker"),
        loadingMarkerEl: jQuery(".loadingMarker")
    };

    return mqttStatusElements;
}

function get_station_observation_cache() {
    if (stationObservationElementsByKey && stationObservationUseGroupingByKey) {
        return;
    }

    stationObservationElementsByKey = {};
    stationObservationUseGroupingByKey = {};

    jQuery('.station-observations').find("span").each(function() {
        var rawClass = jQuery(this).attr("class");
        if (!rawClass) {
            return;
        }

        var elementClass = rawClass.split(/\s+/)[0];
        if (!elementClass) {
            return;
        }

        if (elementClass === "rainWithRainRate") {
            elementClass = "dayRain";
        }

        if (!stationObservationElementsByKey.hasOwnProperty(elementClass)) {
            stationObservationElementsByKey[elementClass] = jQuery("." + elementClass);
            stationObservationUseGroupingByKey[elementClass] = !(elementClass === "barometer" || elementClass === "pressure" || elementClass === "altimeter" || elementClass === "cloudbase");
        }
    });
}

function resolve_station_observation_key(mqttKey) {
    if (!mqttKey || !stationObservationElementsByKey) {
        return null;
    }

    if (stationObservationElementsByKey.hasOwnProperty(mqttKey)) {
        return mqttKey;
    }

    var separatorIndex = mqttKey.indexOf("_");
    if (separatorIndex > 0) {
        var baseKey = mqttKey.substring(0, separatorIndex);
        if (stationObservationElementsByKey.hasOwnProperty(baseKey)) {
            return baseKey;
        }
    }

    return null;
}

function schedule_mqtt_ui_update(payload) {
    mqtt_latest_payload = payload;

    if (mqtt_update_scheduled) {
        return;
    }

    mqtt_update_scheduled = true;

    var scheduleFn = (typeof window.requestAnimationFrame === "function")
        ? window.requestAnimationFrame.bind(window)
        : function(cb) { setTimeout(cb, 16); };

    scheduleFn(function() {
        mqtt_update_scheduled = false;
        if (!mqtt_latest_payload) {
            return;
        }

        var payloadToRender = mqtt_latest_payload;
        mqtt_latest_payload = null;
        update_current_wx(payloadToRender);
    });
}

// New message from mqtt, process it
function onMessageArrived(message) {
    mqtt_message_count++;
    var payload_size = message.payloadString.length;
    belchertown_debug("MQTT: [Msg #" + mqtt_message_count + "] Message received - Size: " + payload_size + " bytes, Topic: " + message.destinationName);
    try {
        mqtt_payload = jQuery.parseJSON(message.payloadString);
        schedule_mqtt_ui_update(mqtt_payload);
        belchertown_debug("MQTT: [Msg #" + mqtt_message_count + "] Message processed successfully");
    } catch (e) {
        console.error("MQTT: [Msg #" + mqtt_message_count + "] Error processing message: " + e.message);
        belchertown_debug("MQTT: [Msg #" + mqtt_message_count + "] Processing error: " + e.toString());
    }
}

function refreshHooks() {
    // Empty function for hooks to extend/re-use
    //belchertown_debug(mqtt_payload);
}

function normalize_mqtt_payload(payload) {
    if (!payload || typeof payload !== "object") {
        return payload;
    }

    var aliases = {
        "beaufort_count": "beaufort",
        "solarAzimuth_degree_angle": "solarAzimuth",
        "lunarAzimuth_degree_angle": "lunarAzimuth",
        "solarAltitude_degree_angle": "solarAltitude",
        "lunarAltitude_degree_angle": "lunarAltitude",
        "solarDistance_mile": "solarDistance",
        "lunarDistance_mile": "lunarDistance",
        "maxSolarRad_Wpm2": "maxSolarRad",
        "rainRate_inch_per_hour": "rainRate",
        "rainCountRate_per_hour": "rainCountRate",
        "rainCount_count": "rainCount"
    };

    Object.keys(aliases).forEach(function(aliasKey) {
        var canonicalKey = aliases[aliasKey];
        if (payload.hasOwnProperty(aliasKey) && !payload.hasOwnProperty(canonicalKey)) {
            payload[canonicalKey] = payload[aliasKey];
        }
    });

    return payload;
}

function parse_mqtt_number(payload, key) {
    if (!payload || !payload.hasOwnProperty(key)) {
        return null;
    }
    var value = parseFloat(payload[key]);
    return isFinite(value) ? value : null;
}

function update_almanac_diagram_from_mqtt(payload) {
    var diagram = jQuery(".almanac-diagram");
    if (!diagram.length) {
        return;
    }

    var solarAz = parse_mqtt_number(payload, "solarAzimuth");
    var lunarAz = parse_mqtt_number(payload, "lunarAzimuth");
    var solarAlt = parse_mqtt_number(payload, "solarAltitude");
    var lunarAlt = parse_mqtt_number(payload, "lunarAltitude");

    if (solarAz === null && lunarAz === null && solarAlt === null && lunarAlt === null) {
        return;
    }

    var getDiagramValue = function(dataKey) {
        var attrName = "data-" + dataKey.replace(/([A-Z])/g, "-$1").toLowerCase();
        var attrValue = parseFloat(diagram.attr(attrName));
        if (isFinite(attrValue)) {
            return attrValue;
        }

        var dataValue = parseFloat(diagram.data(dataKey));
        return isFinite(dataValue) ? dataValue : null;
    };

    var diagramData = {
        hasExtras: true,
        sun: {
            azimuth: getDiagramValue("sunAz"),
            altitude: getDiagramValue("sunAlt"),
            x_offset: getDiagramValue("sunXOffset")
        },
        moon: {
            azimuth: getDiagramValue("moonAz"),
            altitude: getDiagramValue("moonAlt"),
            x_offset: getDiagramValue("moonXOffset")
        },
        centering_mode: String(diagram.attr("data-centering-mode") || diagram.data("centeringMode") || "off").toLowerCase()
    };

    if (solarAz !== null) {
        diagramData.sun.azimuth = solarAz;
        diagram.data("sunAz", solarAz);
        diagram.attr("data-sun-az", solarAz.toFixed(3));
    }
    if (solarAlt !== null) {
        diagramData.sun.altitude = solarAlt;
        diagram.data("sunAlt", solarAlt);
        diagram.attr("data-sun-alt", solarAlt.toFixed(3));
    }
    if (lunarAz !== null) {
        diagramData.moon.azimuth = lunarAz;
        diagram.data("moonAz", lunarAz);
        diagram.attr("data-moon-az", lunarAz.toFixed(3));
    }
    if (lunarAlt !== null) {
        diagramData.moon.altitude = lunarAlt;
        diagram.data("moonAlt", lunarAlt);
        diagram.attr("data-moon-alt", lunarAlt.toFixed(3));
    }

    belchertown_debug(
        "Almanac MQTT live update: sun(az=" + diagramData.sun.azimuth + ", alt=" + diagramData.sun.altitude +
        "), moon(az=" + diagramData.moon.azimuth + ", alt=" + diagramData.moon.altitude + ")"
    );

    renderAlmanacDiagram(diagramData, true);
}

// Handle MQTT message
function update_current_wx(data) {
    if (typeof data === "string") {
        data = jQuery.parseJSON(data);
    }
    data = normalize_mqtt_payload(data);
    mqtt_note_message_activity(data);

    var statusEls = get_mqtt_status_elements();
    var onlineMarkerEl = statusEls.onlineMarkerEl;
    var offlineMarkerEl = statusEls.offlineMarkerEl;
    var loadingMarkerEl = statusEls.loadingMarkerEl;

    update_wind_compass_marker(data);
    update_almanac_diagram_from_mqtt(data);

    try {
        refreshHooks();
    } catch (e) {
    }

    // #if $Extras.has_key('googleAnalyticsId')
    // Send a pageview
    if (typeof gtag === "function" && !mqttGtagConfigured) {
        gtag('config', '$Extras.googleAnalyticsId');
        mqttGtagConfigured = true;
    }
    // #end if

    // This message is a WeeWX archive update. Update WeeWX data, forecast data and highcharts charts
    if (data.hasOwnProperty("interval_minute")) {
        // Delays are recommended to allow the other skins to complete processing
        belchertown_debug("MQTT: Archive interval detected - updating charts and data");
        belchertown_debug("MQTT: Archive interval: " + data.interval_minute + " minutes");
        if (pageName == "pi" || pageName == "kiosk.html") {
            belchertown_debug("Skipping chart update for page " + pageName + ", no charts to be updated.");
        }
        else {
            setTimeout(function() {
                if (typeof renderHomepageCharts === "function") {
                    renderHomepageCharts(true);
                } else if (typeof homepage_chartgroup !== "undefined" && homepage_chartgroup !== "") {
                    if (typeof belchertownEnsureHighcharts === "function") {
                        belchertownEnsureHighcharts().then(function() {
                            showChart(homepage_chartgroup);
                        }).catch(function(err) {
                            belchertown_debug("MQTT: Failed loading Highcharts assets: " + err.message);
                        });
                    } else {
                        showChart(homepage_chartgroup);
                    }
                }
            }, 30000); // Load updated charts.
        }
        ajaxweewx().then(function(weewx_data) { // This call will make sure json/weewx_data.json is loaded before anything else
            setTimeout(update_weewx_data.bind(null, weewx_data), 10000); // Initial call to update (date, daily high, low, etc)
            setTimeout(belchertown_debug.bind(null, weewx_data), 10000); // Make weewx_data.json available in debugging console
            // #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
            setTimeout(ajaxforecast, 10000); // Update forecast data
            // #end if
        }).catch(function(e) {
            console.log(e);
        });
    } else {
        // Only show the updated time on non-archive packets
        epoch = parseFloat(data["dateTime"]).toFixed(0);
        if (pageName == "pi") {
            updated_text = "$obs.label.mqtt_websockets_connected_pi";
        } else {
            updated_text = "$obs.label.mqtt_websockets_connected";
        }
        mqtt_set_relative_updated_status(updated_text, epoch);
    }
    // If we're in this function, show the online beacon and hide the others
    onlineMarkerEl.show(); // Show the online beacon
    offlineMarkerEl.hide();
    loadingMarkerEl.hide();

    // Update the station observation box elements
    station_mqtt_data = Object.keys(data); // Turn data (mqtt message) into an object we can forEach

    // If our rain payload is in cm, convert it as necessary to the desired UOM
    try {
        let conversionFactor = 1.0;
        let rateFactor = 1.0;
        if (unit_label_array["dayRain"].trim() == "in") {
            conversionFactor = 1.0 / 2.54;
        } else if (unit_label_array["dayRain"].trim() == "mm") {
            conversionFactor = 10;
        } // else we are assuming we want "cm"
        if (unit_label_array["rainRate"].trim() == "in/hr") {
            rateFactor = 1.0 / 2.54;
        } else if (unit_label_array["rainRate"].trim() == "mm/hr") {
            rateFactor = 10;
        } // else we are assuming we want "cm/hr"

        data["dayRain_cm"] = parseFloat(data["dayRain_cm"] * conversionFactor).toFixed(4);
        data["hourRain_cm"] = parseFloat(data["hourRain_cm"] * conversionFactor).toFixed(4);
        data["monthRain_cm"] = parseFloat(data["monthRain_cm"] * conversionFactor).toFixed(4);
        data["rain24_cm"] = parseFloat(data["rain24_cm"] * conversionFactor).toFixed(4);
        data["rainRate_cm_per_hour"] = parseFloat(data["rainRate_cm_per_hour"] * rateFactor).toPrecision(4);
        data["rain_cm"] = parseFloat(data["rain_cm"] * conversionFactor).toFixed(4);
        data["stormRain_cm"] = parseFloat(data["stormRain_cm"] * conversionFactor).toFixed(4);
        data["yearRain_cm"] = parseFloat(data["yearRain_cm"] * conversionFactor).toFixed(4);
    } catch (err) {
        // Silent
    }

    get_station_observation_cache();
    station_mqtt_data.forEach(function(mqttKey) {
        var observationKey = resolve_station_observation_key(mqttKey);
        if (!observationKey) {
            return;
        }

        if (!unit_rounding_array.hasOwnProperty(observationKey) || !unit_label_array.hasOwnProperty(observationKey)) {
            return;
        }

        var numericValue = parseFloat(data[mqttKey]);
        if (!isFinite(numericValue)) {
            return;
        }

        var html_output = numericValue.toLocaleString("$system_locale_js", {
            minimumFractionDigits: unit_rounding_array[observationKey],
            maximumFractionDigits: unit_rounding_array[observationKey],
            useGrouping: stationObservationUseGroupingByKey[observationKey]
        }) + unit_label_array[observationKey];

        stationObservationElementsByKey[observationKey].html(html_output);
    });
    // End dynamic station observation box

    // Temperature F
    if (data.hasOwnProperty("outTemp_F")) {
        // Inside parseFloat converts str to int. Outside parseFloat processes the locale string
        // Help from: https://stackoverflow.com/a/40152286/1177153 and https://stackoverflow.com/a/31581206/1177153
        outTemp = parseFloat(parseFloat(data["outTemp_F"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["outTemp"], maximumFractionDigits: unit_rounding_array["outTemp"]});
        get_outTemp_color("degree_F", outTemp);
        jQuery(".outtemp").html(outTemp);
    }

    // Temperature C
    if (data.hasOwnProperty("outTemp_C")) {
        outTemp = parseFloat(parseFloat(data["outTemp_C"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["outTemp"], maximumFractionDigits: unit_rounding_array["outTemp"]});
        get_outTemp_color("degree_C", outTemp);
        jQuery(".outtemp").html(outTemp);
    }

    // Apparent Temperature US
    if (data.hasOwnProperty("appTemp_F")) {
        jQuery(".feelslike").html("$obs.label.feels_like " + parseFloat(parseFloat(data["appTemp_F"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["outTemp"], maximumFractionDigits: unit_rounding_array["outTemp"]}) + " $unit.label.outTemp");
    }

    // Apparent Temperature Metric
    if (data.hasOwnProperty("appTemp_C")) {
        jQuery(".feelslike").html("$obs.label.feels_like " + parseFloat(parseFloat(data["appTemp_C"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["outTemp"], maximumFractionDigits: unit_rounding_array["outTemp"]}) + " $unit.label.outTemp");
    }

    // Wind
    if (data.hasOwnProperty("windDir")) {
        rotateThis(data["windDir"]);
        jQuery(".curwinddeg").html(parseFloat(data["windDir"]).toFixed(0) + "&deg;");
        jQuery(".curwinddir").html(highcharts_tooltip_factory(parseFloat(data["windDir"]).toFixed(0), "windDir"));
    }

    if (data.hasOwnProperty("windSpeed_mph")) {
        jQuery(".curwindspeed").html(parseFloat(parseFloat(data["windSpeed_mph"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
        jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort(parseFloat(data["windGust_mph"]) * 0.8689758)));
    }
    if (data.hasOwnProperty("windSpeed_kph")) {
        jQuery(".curwindspeed").html(parseFloat(parseFloat(data["windSpeed_kph"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
        jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort(parseFloat(data["windGust_kph"]) * 0.5399565)));
    }
    if (data.hasOwnProperty("windSpeed_mps")) {
        jQuery(".curwindspeed").html(parseFloat(parseFloat(data["windSpeed_mps"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
        jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort(parseFloat(data["windGust_mps"]) * 1.943844)));
    }
    if (data.hasOwnProperty("windSpeed_beaufort")) {
        jQuery(".curwindspeed").html(parseFloat(parseFloat(data["windSpeed_beaufort"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
        jQuery(".beaufort").html(beaufort_cat(parseFloat(data["windGust_beaufort"])));
    }
    if (data.hasOwnProperty("windSpeed_knot")) {
        jQuery(".curwindspeed").html(parseFloat(parseFloat(data["windSpeed_knot"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
        jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort(parseFloat(data["windGust_knot"]))));
    }

    if (data.hasOwnProperty("beaufort")) {
        jQuery(".beaufort").html(beaufort_cat(parseFloat(data["beaufort"])));
    }

    if (data.hasOwnProperty("windGust_mph")) {
        jQuery(".curwindgust").html(parseFloat(parseFloat(data["windGust_mph"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windGust"], maximumFractionDigits: unit_rounding_array["windGust"]}));
    }
    if (data.hasOwnProperty("windGust_kph")) {
        jQuery(".curwindgust").html(parseFloat(parseFloat(data["windGust_kph"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windGust"], maximumFractionDigits: unit_rounding_array["windGust"]}));
    }
    if (data.hasOwnProperty("windGust_mps")) {
        jQuery(".curwindgust").html(parseFloat(parseFloat(data["windGust_mps"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windGust"], maximumFractionDigits: unit_rounding_array["windGust"]}));
    }
    if (data.hasOwnProperty("windGust_beaufort")) {
        jQuery(".curwindgust").html(parseFloat(parseFloat(data["windGust_beaufort"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
    }
    if (data.hasOwnProperty("windGust_knot")) {
        jQuery(".curwindgust").html(parseFloat(parseFloat(data["windGust_knot"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windSpeed"], maximumFractionDigits: unit_rounding_array["windSpeed"]}));
    }

    if (data.hasOwnProperty("windchill")) {
        jQuery(".curwindchill").html(parseFloat(parseFloat(data["windchill"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windchill"], maximumFractionDigits: unit_rounding_array["windchill"]}) + "$unit.label.outTemp");
    }
    if (data.hasOwnProperty("windchill_C")) {
        jQuery(".curwindchill").html(parseFloat(parseFloat(data["windchill_C"])).toLocaleString("$system_locale_js", {minimumFractionDigits: unit_rounding_array["windchill"], maximumFractionDigits: unit_rounding_array["windchill"]}) + "$unit.label.outTemp");
    }
};
// #end if
