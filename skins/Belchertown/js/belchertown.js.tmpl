function knots_from_mqtt_payload(payload, obsName) {
    var windObs = obsName || "windSpeed";

    if (payload.hasOwnProperty(windObs + "_knot")) {
        return parseFloat(payload[windObs + "_knot"]);
    }
    if (payload.hasOwnProperty(windObs + "_mph")) {
        return parseFloat(payload[windObs + "_mph"]) * 0.8689758;
    }
    if (payload.hasOwnProperty(windObs + "_kph")) {
        return parseFloat(payload[windObs + "_kph"]) * 0.5399568;
    }
    if (payload.hasOwnProperty(windObs + "_mps")) {
        return parseFloat(payload[windObs + "_mps"]) * 1.943844;
    }
    if (payload.hasOwnProperty(windObs + "_beaufort")) {
        return beaufort_to_knots(payload[windObs + "_beaufort"]);
    }

    return null;
}

function build_windbarb_svg(knots) {
    var value = parseFloat(knots);
    if (!isFinite(value) || value < 0) {
        return "";
    }

    var rounded = Math.max(0, Math.round(value / 5) * 5);

    var color = "#c50a1d";
    var stroke = 5;
    var shaftX = 50;
    var shaftBottom = 88;
    // Keep the inner/center section invisible so the direction text remains clear.
    // Only render the outer/top part of the shaft.
    var shaftVisibleBottom = 44;
    var shaftTop = -12;
    var barbLen = 22;
    var barbStep = 8;
    var pennantLen = 34;
    var pennantHeight = 16;
    var pennantGap = 8;
    // Hard-coded visual slant tuned to match the pennant edge.
    var barbRise = 5.18;
    var barbY = shaftTop;

    var parts = [];
    parts.push('<line x1="' + shaftX + '" y1="' + shaftVisibleBottom + '" x2="' + shaftX + '" y2="' + shaftTop + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="butt"/>');

    if (rounded >= 5) {
        while (rounded >= 50) {
            parts.push('<polygon points="' + shaftX + ',' + barbY + ' ' + shaftX + ',' + (barbY + pennantHeight) + ' ' + (shaftX + pennantLen) + ',' + (barbY + (pennantHeight / 2)) + '" fill="' + color + '"/>');
            rounded -= 50;
            barbY += pennantHeight + pennantGap;
        }
        while (rounded >= 10) {
            parts.push('<line x1="' + shaftX + '" y1="' + barbY + '" x2="' + (shaftX + barbLen) + '" y2="' + (barbY - barbRise) + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="round"/>');
            rounded -= 10;
            barbY += barbStep;
        }
        if (rounded >= 5) {
            parts.push('<line x1="' + shaftX + '" y1="' + barbY + '" x2="' + (shaftX + barbLen * 0.55) + '" y2="' + (barbY - (barbRise * 0.55)) + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="round"/>');
        }
    }

    var viewBoxY = Math.min(0, shaftTop - pennantHeight - 4);
    var viewBoxHeight = 100 - viewBoxY;

    return '<svg class="windbarb-svg" viewBox="0 ' + viewBoxY + ' 100 ' + viewBoxHeight + '" aria-hidden="true" focusable="false">' + parts.join("") + '</svg>';
}

var live_wind_compass_state = {
    windSpeedKnots: null,
    windGustKnots: null,
    direction: null,
};

function render_wind_compass_marker(direction, windSpeedKnots, windGustKnots) {
    var rotation = parseFloat(direction);
    var selectedKnots = wind_compass_source == "windGust" ? parseFloat(windGustKnots) : parseFloat(windSpeedKnots);
    var calmThresholdKnots = 2.5;
    var speedIsCalm = isFinite(parseFloat(windSpeedKnots)) && parseFloat(windSpeedKnots) < calmThresholdKnots;
    var gustIsCalm = isFinite(parseFloat(windGustKnots)) && parseFloat(windGustKnots) < calmThresholdKnots;
    var arrow = jQuery(".arrow");

    if (arrow.length === 0 || !isFinite(rotation)) {
        return;
    }

    // Calm wind: hide both indicator styles (triangle and windbarb)
    // only when *both* speed and gust are below the calm threshold.
    if (speedIsCalm && gustIsCalm) {
        arrow.removeClass("windbarb-marker").empty().css("visibility", "hidden");
        jQuery(".wind-arrow").css("visibility", "hidden");
        return;
    }

    // Wind is not calm: ensure indicators are visible.
    arrow.css("visibility", "visible");
    jQuery(".wind-arrow").css("visibility", "visible");

    if (wind_compass_marker == "windbarb") {
        arrow.addClass("windbarb-marker");
        var svg = build_windbarb_svg(selectedKnots);
        if (svg) {
            arrow.html(svg);
        }
    } else {
        arrow.removeClass("windbarb-marker").empty();
    }

    rotateThis(rotation);
}

function initialize_wind_compass_marker(direction, windSpeedKnots, windGustKnots) {
    var parsedDirection = parseFloat(direction);
    var parsedWindSpeedKnots = parseFloat(windSpeedKnots);
    var parsedWindGustKnots = parseFloat(windGustKnots);

    if (isFinite(parsedDirection)) {
        live_wind_compass_state.direction = parsedDirection;
    }
    if (isFinite(parsedWindSpeedKnots)) {
        live_wind_compass_state.windSpeedKnots = parsedWindSpeedKnots;
    }
    if (isFinite(parsedWindGustKnots)) {
        live_wind_compass_state.windGustKnots = parsedWindGustKnots;
    }

    render_wind_compass_marker(
        live_wind_compass_state.direction,
        live_wind_compass_state.windSpeedKnots,
        live_wind_compass_state.windGustKnots
    );
}

function update_wind_compass_marker(payload) {
    var direction = payload.hasOwnProperty("windDir") ? parseFloat(payload["windDir"]) : live_wind_compass_state.direction;
    var windSpeedKnots = knots_from_mqtt_payload(payload, "windSpeed");
    var windGustKnots = knots_from_mqtt_payload(payload, "windGust");

    if (!isFinite(windSpeedKnots)) {
        windSpeedKnots = live_wind_compass_state.windSpeedKnots;
    }
    if (!isFinite(windGustKnots)) {
        windGustKnots = live_wind_compass_state.windGustKnots;
    }

    if (!isFinite(direction)) {
        return;
    }

    live_wind_compass_state.direction = direction;
    live_wind_compass_state.windSpeedKnots = windSpeedKnots;
    live_wind_compass_state.windGustKnots = windGustKnots;

    render_wind_compass_marker(direction, windSpeedKnots, windGustKnots);
}

function highcharts_tooltip_factory(obsvalue, point_obsType, highchartsReturn = false, rounding, mirrored = false, numberFormat) {
    // Mirrored values have the negative sign removed
    if (mirrored) {
        obsvalue = Math.abs(obsvalue);
    }

    if (point_obsType == "windDir") {
        // Map degrees to one of 16 compass sectors via arithmetic (replaces 17-branch if-else)
        const ordinal = ORDINATE_NAMES[Math.round(obsvalue / 22.5) % 16];

        // highchartsReturn returns the full wind direction string for highcharts tooltips. e.g "NNW (337)"
        if (highchartsReturn) {
            output = ordinal + " (" + Math.round(obsvalue) + "\xBA)";
        } else {
            output = ordinal;
        }
    } else {
        try {
            // Setup any charts.conf overrides on formatting
            var {decimals, decimalPoint, thousandsSep} = numberFormat;

            // Try to apply the highcharts numberFormat for locale awareness. Use rounding from weewx.conf StringFormats.
            // -1 is set from Python to notate no rounding data available and decimals from charts.conf is undefined.
            if (rounding == "-1" && typeof decimals === "undefined") {
                output = Highcharts.numberFormat(obsvalue);
            } else {
                // If the amount of decimal is defined, use that instead since rounding is provided to the function.
                if (typeof decimals !== "undefined") {
                    rounding = decimals;
                }
                // If decimalPoint is undefined, use the auto detect from the skin since this comes from the skin.
                if (typeof decimalPoint === "undefined") {
                    decimalPoint = "$highcharts_decimal";
                }
                // If thousandsSep is undefined, use the auto detect from the skin since this comes from the skin.
                if (typeof thousandsSep === "undefined") {
                    thousandsSep = "$highcharts_thousands";
                }

                output = Highcharts.numberFormat(obsvalue, rounding, decimalPoint, thousandsSep);
            }
        } catch (err) {
            // Fall back to just returning the highcharts point number value, which is a best guess.
            output = Highcharts.numberFormat(obsvalue);
        }
    }

    return output;
}

// Handle wind arrow rotation with the ability to "rollover" past 0 
// without spinning back around. e.g 350 to 3 would normally spin back around
// https://stackoverflow.com/a/19872672/1177153
function rotateThis(newRotation) {
    if (newRotation == "N/A") {return;}
    belchertown_debug("rotateThis: rotating to " + newRotation);
    var currentRotation;
    finalRotation = finalRotation || 0; // if finalRotation undefined or 0, make 0, else finalRotation
    currentRotation = finalRotation % 360;
    if (currentRotation < 0) {currentRotation += 360;}
    if (currentRotation < 180 && (newRotation > (currentRotation + 180))) {finalRotation -= 360;}
    if (currentRotation >= 180 && (newRotation <= (currentRotation - 180))) {finalRotation += 360;}
    finalRotation += (newRotation - currentRotation);
    jQuery(".wind-arrow").css("transform", "rotate(" + finalRotation + "deg)");
    jQuery(".arrow").css("transform", "rotate(" + finalRotation + "deg)");
}

// Title case strings. https://stackoverflow.com/a/45253072/1177153
function titleCase(str) {
    return str.toLowerCase().split(' ').map(function(word) {
        return word.replace(word[0], word[0].toUpperCase());
    }).join(' ');
}

function almanacSkyCoordinates(azimuth, altitude) {
    var az = parseFloat(azimuth);
    var alt = parseFloat(altitude);
    var minX = 16;
    var maxX = 204;
    var horizonY = 100;
    var maxAboveHorizon = 124;
    var maxBelowHorizon = 16;

    if (!isFinite(az) || !isFinite(alt)) {
        return null;
    }

    var wrappedAzimuth = ((az % 360) + 360) % 360;
    var x = minX + (wrappedAzimuth / 360) * (maxX - minX);

    var boundedAltitude = Math.max(-18, Math.min(90, alt));
    var y;
    if (boundedAltitude >= 0) {
        y = horizonY - (boundedAltitude / 90) * maxAboveHorizon;
    } else {
        y = horizonY + (Math.abs(boundedAltitude) / 18) * maxBelowHorizon;
    }

    return {
        x: x,
        y: y,
        belowHorizon: alt < 0
    };
}

function almanacBodyGeometry(bodyData) {
    var horizonY = 100;
    var minX = 16;
    var maxX = 204;
    var defaultApexY = 2;

    var risePoint = almanacSkyCoordinates(bodyData && bodyData.rise && bodyData.rise.azimuth, bodyData && bodyData.rise && bodyData.rise.altitude);
    var transitPoint = almanacSkyCoordinates(bodyData && bodyData.transit && bodyData.transit.azimuth, bodyData && bodyData.transit && bodyData.transit.altitude);
    var setPoint = almanacSkyCoordinates(bodyData && bodyData.set && bodyData.set.azimuth, bodyData && bodyData.set && bodyData.set.altitude);
    var currentPoint = almanacSkyCoordinates(bodyData && bodyData.azimuth, bodyData && bodyData.altitude);

    var riseX = risePoint ? risePoint.x : 68;
    var setX = setPoint ? setPoint.x : 152;
    if (riseX > setX) {
        var tmp = riseX;
        riseX = setX;
        setX = tmp;
    }

    var transitX = transitPoint ? transitPoint.x : ((riseX + setX) / 2);
    var transitY = transitPoint ? transitPoint.y : (currentPoint ? currentPoint.y : defaultApexY);

    var transitAlt = parseFloat(bodyData && bodyData.transit && bodyData.transit.altitude);
    var transitIsBelowHorizon = isFinite(transitAlt) && transitAlt < 0;
    transitY = transitIsBelowHorizon
        ? Math.max(horizonY + 6, Math.min(124, transitY))
        : Math.min(horizonY - 14, Math.max(-12, transitY));

    var nightY = isFinite(transitAlt)
        ? horizonY + Math.max(8, Math.min(18, Math.abs(transitAlt) * 0.22))
        : 114;

    return {
        minX: minX,
        maxX: maxX,
        horizonY: horizonY,
        riseX: Math.max(minX + 14, Math.min(maxX - 14, riseX)),
        setX: Math.max(minX + 14, Math.min(maxX - 14, setX)),
        transitX: Math.max(minX + 20, Math.min(maxX - 20, transitX)),
        transitY: transitY,
        nightY: Math.max(horizonY + 6, Math.min(124, nightY))
    };
}

function almanacBodyPath(bodyData) {
    var g = almanacBodyGeometry(bodyData);
    var leftCtrlX = g.minX + ((g.riseX - g.minX) * 0.55);
    var rightCtrlX = g.setX + ((g.maxX - g.setX) * 0.45);

    return "M " + g.minX.toFixed(1) + " " + g.nightY.toFixed(1) +
        " Q " + leftCtrlX.toFixed(1) + " " + g.nightY.toFixed(1) + " " + g.riseX.toFixed(1) + " " + g.horizonY.toFixed(1) +
        " Q " + g.transitX.toFixed(1) + " " + g.transitY.toFixed(1) + " " + g.setX.toFixed(1) + " " + g.horizonY.toFixed(1) +
        " Q " + rightCtrlX.toFixed(1) + " " + g.nightY.toFixed(1) + " " + g.maxX.toFixed(1) + " " + g.nightY.toFixed(1);
}

function almanacPathPointSamples(bodyData) {
    var g = almanacBodyGeometry(bodyData);
    var leftCtrlX = g.minX + ((g.riseX - g.minX) * 0.55);
    var rightCtrlX = g.setX + ((g.maxX - g.setX) * 0.45);
    var points = [];

    for (var i = 0; i <= 40; i++) {
        var t = i / 40;
        var omt = 1 - t;
        points.push({
            x: (omt * omt * g.minX) + (2 * omt * t * leftCtrlX) + (t * t * g.riseX),
            y: (omt * omt * g.nightY) + (2 * omt * t * g.nightY) + (t * t * g.horizonY)
        });
    }
    for (var j = 1; j <= 80; j++) {
        var u = j / 80;
        var omu = 1 - u;
        points.push({
            x: (omu * omu * g.riseX) + (2 * omu * u * g.transitX) + (u * u * g.setX),
            y: (omu * omu * g.horizonY) + (2 * omu * u * g.transitY) + (u * u * g.horizonY)
        });
    }
    for (var k = 1; k <= 40; k++) {
        var v = k / 40;
        var omv = 1 - v;
        points.push({
            x: (omv * omv * g.setX) + (2 * omv * v * rightCtrlX) + (v * v * g.maxX),
            y: (omv * omv * g.horizonY) + (2 * omv * v * g.nightY) + (v * v * g.nightY)
        });
    }

    return points;
}

function almanacPathYForX(bodyData, targetX, targetY) {
    if (!bodyData) {
        return null;
    }

    var points = almanacPathPointSamples(bodyData);
    if (!points.length) {
        return null;
    }

    var nearest = null;
    var bestScore = Number.POSITIVE_INFINITY;

    points.forEach(function(p) {
        var dx = Math.abs(p.x - targetX);
        var dy = isFinite(targetY) ? Math.abs(p.y - targetY) : 0;
        var score = (dx * 4) + dy;
        if (score < bestScore) {
            bestScore = score;
            nearest = p;
        }
    });

    return nearest ? nearest.y : null;
}

function setAlmanacDiagramPath(selector, d) {
    var path = jQuery(selector);

    if (!path.length) {
        return;
    }

    if (!d) {
        path.attr("d", "").hide();
        return;
    }

    path.attr("d", d).show();
}

function setAlmanacDiagramPaths(diagramData) {
    setAlmanacDiagramPath(".almanac-diagram-track--sun", almanacBodyPath(diagramData["sun"]));
    setAlmanacDiagramPath(".almanac-diagram-track--moon", almanacBodyPath(diagramData["moon"]));

    // Backward compatibility with older single-track markup.
    if (!jQuery(".almanac-diagram-track--sun, .almanac-diagram-track--moon").length) {
        setAlmanacDiagramPath(".almanac-diagram-track", almanacBodyPath(diagramData["sun"]));
    }
}

function setAlmanacDiagramObject(selector, label, azimuth, altitude, bodyData) {
    var point = almanacSkyCoordinates(azimuth, altitude);
    var marker = jQuery(selector);

    if (!marker.length) {
        return;
    }

    if (!point) {
        marker.hide();
        return;
    }

    var snappedY = almanacPathYForX(bodyData, point.x, point.y);
    if (snappedY !== null && isFinite(snappedY)) {
        point.y = snappedY;
    }

    marker
        .show()
        .attr("transform", "translate(" + point.x.toFixed(1) + " " + point.y.toFixed(1) + ")")
        .toggleClass("is-below-horizon", point.belowHorizon);

    marker.find("title").text(label);
}

function fitAlmanacDiagramViewBox(diagramData) {
    var svg = jQuery(".almanac-diagram-svg");

    if (!svg.length || !diagramData) {
        return;
    }

    var markerRadius = 15;
    var sidePadding = 4;
    var topPadding = 4;
    var bottomPadding = 8;
    var verticalShiftUpRatio = 0.2;

    var minX = Number.POSITIVE_INFINITY;
    var maxX = Number.NEGATIVE_INFINITY;
    var minY = Number.POSITIVE_INFINITY;
    var maxY = Number.NEGATIVE_INFINITY;

    function includePoint(x, y, withMarkerPadding) {
        if (!isFinite(x) || !isFinite(y)) {
            return;
        }

        var pad = withMarkerPadding ? markerRadius : 0;
        minX = Math.min(minX, x - pad);
        maxX = Math.max(maxX, x + pad);
        minY = Math.min(minY, y - pad);
        maxY = Math.max(maxY, y + pad);
    }

    function includeBody(bodyDataItem) {
        if (!bodyDataItem) {
            return;
        }

        var g = almanacBodyGeometry(bodyDataItem);
        includePoint(g.minX, g.nightY, false);
        includePoint(g.riseX, g.horizonY, false);
        includePoint(g.transitX, g.transitY, false);
        includePoint(g.setX, g.horizonY, false);
        includePoint(g.maxX, g.nightY, false);

        var bodyPoint = almanacSkyCoordinates(bodyDataItem.azimuth, bodyDataItem.altitude);
        if (bodyPoint) {
            var snappedY = almanacPathYForX(bodyDataItem, bodyPoint.x, bodyPoint.y);
            if (snappedY !== null && isFinite(snappedY)) {
                bodyPoint.y = snappedY;
            }
            includePoint(bodyPoint.x, bodyPoint.y, true);
        }
    }

    includeBody(diagramData["sun"]);
    includeBody(diagramData["moon"]);

    if (!isFinite(minX) || !isFinite(minY) || !isFinite(maxX) || !isFinite(maxY)) {
        return;
    }

    var contentHeight = Math.max(0, maxY - minY);
    var shiftUpAmount = Math.round(contentHeight * verticalShiftUpRatio);

    var viewBoxX = Math.max(0, Math.floor(minX - sidePadding));
    var baseViewBoxY = Math.floor(minY - topPadding);
    var viewBoxY = baseViewBoxY + shiftUpAmount;
    var viewBoxWidth = Math.max(40, Math.ceil((maxX + sidePadding) - viewBoxX));
    var viewBoxHeight = Math.max(28, Math.ceil((maxY + bottomPadding) - baseViewBoxY));

    svg.attr("viewBox", viewBoxX + " " + viewBoxY + " " + viewBoxWidth + " " + viewBoxHeight);
}

function renderAlmanacDiagram(diagramData) {
    var diagram = jQuery(".almanac-diagram");

    if (!diagram.length) {
        return;
    }

    if (!diagramData || diagramData["hasExtras"] !== true) {
        diagram.addClass("almanac-diagram--inactive");
        return;
    }

    diagram.removeClass("almanac-diagram--inactive");

    setAlmanacDiagramPaths(diagramData);

    setAlmanacDiagramObject(
        ".almanac-diagram-object--sun",
        "$obs.label.sun",
        diagramData["sun"]["azimuth"],
        diagramData["sun"]["altitude"],
        diagramData["sun"]
    );
    setAlmanacDiagramObject(
        ".almanac-diagram-object--moon",
        "$obs.label.moon",
        diagramData["moon"]["azimuth"],
        diagramData["moon"]["altitude"],
        diagramData["moon"]
    );

    fitAlmanacDiagramViewBox(diagramData);
}

function initializeAlmanacDiagramFromDOM() {
    var diagram = jQuery(".almanac-diagram");

    if (!diagram.length) {
        return;
    }

    renderAlmanacDiagram({
        hasExtras: true,
        sun: {
            azimuth: diagram.data("sunAz"),
            altitude: diagram.data("sunAlt"),
            rise: {
                azimuth: diagram.data("sunRiseAz"),
                altitude: diagram.data("sunRiseAlt")
            },
            transit: {
                azimuth: diagram.data("sunTransitAz"),
                altitude: diagram.data("sunTransitAlt")
            },
            set: {
                azimuth: diagram.data("sunSetAz"),
                altitude: diagram.data("sunSetAlt")
            }
        },
        moon: {
            azimuth: diagram.data("moonAz"),
            altitude: diagram.data("moonAlt"),
            rise: {
                azimuth: diagram.data("moonRiseAz"),
                altitude: diagram.data("moonRiseAlt")
            },
            transit: {
                azimuth: diagram.data("moonTransitAz"),
                altitude: diagram.data("moonTransitAlt")
            },
            set: {
                azimuth: diagram.data("moonSetAz"),
                altitude: diagram.data("moonSetAlt")
            }
        }
    });
}

function autoTheme(sunset_hour, sunset_min, sunrise_hour, sunrise_min) {
    // First check if ?theme= is in URL. If so, bail out and do not change anything.
    const themeParam = getURLvar("theme");
    if (themeParam && themeParam !== "auto") {
        belchertown_debug("Auto theme: theme override detected in URL. Skipping auto theme");
        return true;
    }
    belchertown_debug("Auto theme: checking to see if theme needs to be switched");

    var d = new Date();
    var nowHour = d.getHours();
    var nowMinutes = d.getMinutes();

    // Determine if it's day time. https://stackoverflow.com/a/14718577/1177153
    if (sunrise_hour <= nowHour && nowHour < sunset_hour) {
        dayTime = true;
    } else {
        dayTime = false;
    }

    belchertown_debug("Auto theme: sunrise: " + sunrise_hour);
    belchertown_debug("Auto theme: now: " + nowHour);
    belchertown_debug("Auto theme: sunset: " + sunset_hour);
    belchertown_debug("Auto theme: are we in daylight hours: " + dayTime);
    belchertown_debug("Auto theme: sessionStorage.getItem('theme') = " + sessionStorage.getItem('theme'));

    if (dayTime) {
        // Day time, set light if needed
        // Only change theme if user has not overridden the auto option with the toggle
        if (sessionStorage.getItem('theme') == "auto") {
            belchertown_debug("Auto theme: setting light theme since dayTime variable is true (day)");
            changeTheme("light");
        } else {
            belchertown_debug("Auto theme: cannot set light theme since visitor used toggle to override theme. Refresh to reset the override.");
        }
    } else {
        // Night time, set dark if needed
        // Only change theme if user has not overridden the auto option with the toggle
        if (sessionStorage.getItem('theme') == "auto") {
            belchertown_debug("Auto theme: setting dark theme since dayTime variable is false (night)");
            changeTheme("dark");
        } else {
            belchertown_debug("Auto theme: cannot set dark theme since visitor used toggle to override theme. Refresh to reset the override.");
        }
    }
}

function changeTheme(themeName, toggleOverride = false) {
    belchertown_debug("Theme: Changing to " + themeName);
    // If the configured theme is auto, but the user toggles light/dark, remove the auto option.
    if (toggleOverride) {
        belchertown_debug("Theme: toggle override clicked.");
        belchertown_debug("Theme: sessionStorage.getItem('theme') was previously: " + sessionStorage.getItem('theme'));
        // This was applied only to auto theme config, but now it's applied to all themes so visitor has full control on light/dark mode
        //if ( sessionStorage.getItem('theme') == "auto" ) { }
        sessionStorage.setItem('theme', 'toggleOverride');
        belchertown_debug("Theme: sessionStorage.getItem('theme') is now: " + sessionStorage.getItem('theme'));
    }
    if (themeName == "dark") {
        // Apply dark theme
        // #if $radar_html_dark != "None"
        jQuery('.radar_image').html('$radar_html_dark');
        // #end if
        jQuery('body').addClass("dark");
        jQuery('body').removeClass("light");
        // #if $Extras.has_key('theme_toggle_enabled') and $Extras.theme_toggle_enabled == '1'
        jQuery("#themeSwitch").prop("checked", true);
        // #end if
        // #if $Extras.has_key('logo_image_dark') and $Extras.logo_image_dark != ""
        belchertown_debug("Theme: logo_image_dark is defined.");
        jQuery("#logo_image").attr("src", "$Extras.logo_image_dark");
        // #end if
        sessionStorage.setItem('currentTheme', 'dark');
    } else if (themeName == "light") {
        // Apply light theme
        // #if $radar_html_dark != "None"
        jQuery('.radar_image').html('$radar_html');
        // #end if
        jQuery('body').addClass("light");
        jQuery('body').removeClass("dark");
        // #if $Extras.has_key('theme_toggle_enabled') and $Extras.theme_toggle_enabled == '1'
        jQuery("#themeSwitch").prop("checked", false);
        // #end if
        // #if $Extras.has_key('logo_image') and $Extras.logo_image != ""
        belchertown_debug("Theme: logo_image is defined.");
        jQuery("#logo_image").attr("src", "$Extras.logo_image");
        // #end if
        sessionStorage.setItem('currentTheme', 'light');
    }
}

