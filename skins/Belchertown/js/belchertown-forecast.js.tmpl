// #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
function ajaxforecast() {
    forecast_data = {};
    current_conditions_data = {};

    const pCurrent = jQuery
        .ajax({
            url: get_relative_url() + "/json/current_conditions.json",
            dataType: "json",
            headers: {"Cache-Control": "no-cache"},
        })
        .done(function(current_conditions) {
            current_conditions_data = current_conditions;
        });

    const pForecast = jQuery
        .ajax({
            url: get_relative_url() + "/json/forecast.json",
            dataType: "json",
            headers: {"Cache-Control": "no-cache"},
        })
        .done(function(forecast) {
            forecast_data = forecast;
        });

    const promises = [pCurrent, pForecast];

    jQuery.when.apply(jQuery, promises)
        .then(function() {
            update_current_conditions(current_conditions_data);
            update_forecast_data(forecast_data);
        })
        .fail(function(err) {
            console.error("Forecast fetch failed:", err);
        });
}

function forecast_trim_sentence_end(value) {
    return String(value || "").trim().replace(/[\.\s]+$/, "");
}

function forecast_sentence_text(parts) {
    const text = parts
        .map(forecast_trim_sentence_end)
        .filter(function(part) { return part !== ""; })
        .join(" ");
    return text ? text + "." : "";
}

function show_forcast_alert(data) {
    belchertown_debug("Forecast: Updating alert data");
    var i, forecast_alerts;
    forecast_alerts = [];

    // Empty anything that's been appended to the modal from the previous run
    jQuery(".wx-stn-alert-text").empty();

    if (Array.isArray(data['alerts'])) {
        for (i = 0; i < data['alerts'].length; i++) {
            const alertObj = data['alerts'][i] || {};
            const alertDescription = (alertObj['description'] == null)
                ? ""
                : String(alertObj['description']);
            forecast_alert_title = (alertObj['title'] == null)
                ? "Alert"
                : String(alertObj['title']);
            forecast_alert_body = alertDescription.replace(/\n/g, '<br>');
            forecast_alert_link = forecast_alert_title;
            forecast_alert_expires = (alertObj['expires'] != null)
                ? tzAdjustedMoment(alertObj['expires']).format('$obs.label.time_forecast_alert_expires')
                : "";
            forecast_alerts.push({"title": forecast_alert_title, "body": forecast_alert_body, "link": forecast_alert_link, "expires": forecast_alert_expires});
        }
    }

    if (forecast_alerts.length > 0) {
        belchertown_debug("Forecast: There are " + forecast_alerts.length + " alert(s).");
        for (i = 0; i < forecast_alerts.length; i++) {

            alert_link = "<i class='fa fa-exclamation-triangle'></i> <a href='#forecast-alert-" + i + "' data-toggle='modal' data-target='#forecast-alert-" + i + "'>" + forecast_alerts[i]["title"] + " $obs.label.alert_in_effect " + forecast_alerts[i]["expires"] + "</a><br>";
            jQuery(".wx-stn-alert-text").append(alert_link);

            var forecast_alert_modal = "";
            forecast_alert_modal += "<!-- Forecast Alert Modal " + i + " -->";
            forecast_alert_modal += "<div class='modal fade' id='forecast-alert-" + i + "' tabindex='-1' role='dialog' aria-labelledby='forecast-alert'>";
            forecast_alert_modal += "<div class='modal-dialog' role='document'>";
            forecast_alert_modal += "<div class='modal-content'>";
            forecast_alert_modal += "<div class='modal-header'>";
            forecast_alert_modal += "<button type='button' class='close' data-dismiss='modal' aria-label='Close'><span aria-hidden='true'>&times;</span></button>";
            forecast_alert_modal += "<h4 class='modal-title' id='forecast-alert'>" + forecast_alerts[i]["title"] + "</h4>";
            forecast_alert_modal += "</div>";
            forecast_alert_modal += "<div class='modal-body'>";
            forecast_alert_modal += forecast_alerts[i]["body"];
            forecast_alert_modal += "</div>";
            forecast_alert_modal += "<div class='modal-footer'>";
            forecast_alert_modal += "<button type='button' class='btn btn-primary' data-dismiss='modal'>$obs.label.close</button>";
            forecast_alert_modal += "</div>";
            forecast_alert_modal += "</div>";
            forecast_alert_modal += "</div>";
            forecast_alert_modal += "</div>";

            jQuery(".wx-stn-alert-text").append(forecast_alert_modal);
        }
        jQuery(".wx-stn-alert").show();
    } else {
        belchertown_debug("Forecast: There are no forecast alerts");
        jQuery(".wx-stn-alert").hide();
    }
}

function forecast_aqi_translate(data) {
    if (data === "good") data = "$obs.label.aqi_good";
    else if (data === "moderate") data = "$obs.label.aqi_moderate";
    else if (data === "usg") data = "$obs.label.aqi_usg";
    else if (data === "unhealthy") data = "$obs.label.aqi_unhealthy";
    else if (data === "very unhealthy") data = "$obs.label.aqi_very_unhealthy";
    else if (data === "hazardous") data = "$obs.label.aqi_hazardous";
    else data = "$obs.label.aqi_unknown";

    return data;
}

function update_current_conditions(data) {
    forecast_provider = "$Extras.forecast_provider";
    if (forecast_provider == "openmeteo" || forecast_provider == "open_meteo") {
        forecast_provider = "open-meteo";
    }
    belchertown_debug("Current Conditions: Provider is " + forecast_provider);
    belchertown_debug("Current Conditions: Updating data");
    belchertown_debug(data);

    if (!data["current"] || !data["current"][0]) {
        belchertown_debug("Current Conditions: Missing normalized current data");
        return false;
    }

    try {
        const cc = data["current"][0];
        const w34icon = resolveIconForProvider(cc["icon"] || "unknown", "pirateweather");
        const wxicon = get_relative_url() + "/images/" + w34icon + ".png";
        jQuery("#wxicon").attr("src", wxicon);

        try {
            jQuery(".current-obs-text").html(cc["summary"] || "");
        } catch (err) { /* silent */}

        try {
            const visibility = cc["visibility"];
            const visibility_output = (visibility != null)
                ? parseFloat(parseFloat(visibility)).toLocaleString(
                    "$system_locale_js",
                    {
                        minimumFractionDigits: unit_rounding_array["visibility"],
                        maximumFractionDigits: unit_rounding_array["visibility"]
                    }
                ) + " " + unit_label_array["visibility"]
                : "N/A";
            jQuery(".station-observations .visibility").html(visibility_output);
        } catch (err) { /* silent */}

        if ("$Extras.current_conditions_timestamp_enabled" == "1") {
            const ts = data["timestamp"];
            const current_subtitle = tzAdjustedMoment(ts).format('$obs.label.time_current_conditions_last_updated');
            jQuery(".current-conditions-subtitle").html(forecast_sentence_text([current_subtitle]));
        }
    } catch (error) {
        belchertown_debug("Current Conditions: Normalized render failed: " + error);
    }
    return true;
}

function forecast_number(value) {
    const numberValue = parseFloat(value);
    return isFinite(numberValue) ? numberValue : null;
}

function forecast_temp_text(value) {
    const numberValue = forecast_number(value);
    return numberValue !== null ? numberValue.toFixed(0) + '&deg;' : 'N/A';
}

function forecast_plain_number_text(value) {
    const numberValue = forecast_number(value);
    return numberValue !== null ? numberValue.toFixed(0) : 'N/A';
}

function forecast_percent_text(value, fallback) {
    const numberValue = forecast_number(value);
    if (numberValue === null) return fallback || null;
    const percentValue = Math.abs(numberValue) <= 1 ? numberValue * 100 : numberValue;
    return percentValue.toFixed(0) + '%';
}

function forecast_icon_url(iconValue) {
    const iconBase = resolveIconForProvider(iconValue || "unknown", "pirateweather");
    return get_relative_url() + "/images/" + iconBase + ".png";
}

function forecast_daily_link(timestamp) {
    var showDailyLink = "0";
    // #if $Extras.has_key("forecast_show_daily_forecast_link")
    showDailyLink = "$Extras.forecast_show_daily_forecast_link";
    // #end if
    if (showDailyLink != "1") return "";

    const linkMoment = tzAdjustedMoment(timestamp || (Date.now() / 1000));
    const link = "$Extras.forecast_daily_forecast_link"
        .replace("YYYY", linkMoment.format("YYYY"))
        .replace("MM", linkMoment.format("MM"))
        .replace("DD", linkMoment.format("DD"));
    return '<a href="' + link + '" target="_blank">$obs.label.daily_forecast</a>';
}

function forecast_metric_rows(row) {
    var humidityMode = "0";
    // #if $Extras.has_key("forecast_show_humidity_dewpoint")
    humidityMode = "$Extras.forecast_show_humidity_dewpoint";
    // #end if

    let html = "";
    if (humidityMode == "1") {
        const humidityText = forecast_percent_text(row["humidity"]);
        if (humidityText !== null) {
            html += '<div><i class="wi wi-humidity rain-precip"></i> <span>' + humidityText + '</span></div>';
        }
    } else if (humidityMode == "2") {
        const dewPointText = forecast_temp_text(row["dewPoint"]);
        if (dewPointText != 'N/A') {
            html += '<div><i class="wi wi-raindrops rain-precip"></i> <span>' + dewPointText + '</span></div>';
        }
    }

    const snowDepth = forecast_number(row["snowDepth"]);
    if (snowDepth !== null && snowDepth > 0) {
        const snowUnit = row["snowUnit"] || "";
        html += '<div class="snow-precip">';
        html += '<img src="' + get_relative_url() + '/images/snowflake-icon-15px.png" alt="" width="15" height="15" loading="lazy" decoding="async"> <span>' + snowDepth.toFixed(0) + '<span> ' + snowUnit;
        html += '</div>';
    } else {
        const precipText = forecast_percent_text(row["precipProbability"], '0%');
        const rainClass = precipText == '0%' ? 'rain-no-precip' : 'rain-precip';
        html += '<div><i class="wi wi-raindrop wi-rotate-45 ' + rainClass + '"></i> <span>' + precipText + '</span></div>';
    }

    return html;
}

function forecast_wind_html(row, includeGust) {
    const windSpeedText = forecast_plain_number_text(row["windSpeed"]);
    let html = '<div class="forecast-wind">';
    html += '<i class="wi wi-strong-wind"></i> <span>' + windSpeedText + '</span>';
    if (includeGust) {
        html += ' | <span> ' + forecast_plain_number_text(row["windGust"]) + '$unit.label.windSpeed';
    }
    html += '</div>';
    return html;
}

function forecast_is_three_hour_boundary(epoch) {
    const hour = parseInt(tzAdjustedMoment(epoch).format("H"), 10);
    return isFinite(hour) && hour % 3 === 0;
}

function forecast_current_period_slice(rows, periodHours, requireThreeHourBoundary) {
    if (!Array.isArray(rows) || rows.length === 0) return [];

    const nowEpoch = Date.now() / 1000;
    const periodNumber = parseFloat(periodHours);
    const periodSeconds = (isFinite(periodNumber) && periodNumber > 0 ? periodNumber : 1) * 3600;
    let firstFuture = -1;
    let foundTimestamp = false;
    let foundBoundaryTimestamp = !requireThreeHourBoundary;

    for (let i = 0; i < rows.length; i++) {
        const rowEpoch = forecast_number(rows[i] && rows[i]["time"]);
        if (rowEpoch === null) continue;

        foundTimestamp = true;
        if (requireThreeHourBoundary) {
            if (!forecast_is_three_hour_boundary(rowEpoch)) continue;
            foundBoundaryTimestamp = true;
        }

        if (rowEpoch <= nowEpoch && nowEpoch < rowEpoch + periodSeconds) {
            return rows.slice(i);
        }
        if (rowEpoch >= nowEpoch && firstFuture === -1) {
            firstFuture = i;
        }
    }

    if (firstFuture !== -1) {
        return rows.slice(firstFuture);
    }

    if (!foundBoundaryTimestamp) {
        return forecast_current_period_slice(rows, periodHours, false);
    }

    return foundTimestamp ? [] : rows.slice(0);
}

function forecast_pick_three_hourly_from_current_period(hourlyArray) {
    const rows = forecast_current_period_slice(hourlyArray, 3, true);
    const output = [];
    for (let i = 0; i < rows.length; i += 3) {
        output.push(rows[i]);
    }
    return output;
}

function forecast_render_hourly_tiles(hourlySource, maxTiles, tileClass) {
    let html = "";
    const forecastInterval = (tileClass === "forecast-3hour") ? "forecast_3hr" : "forecast_1hr";
    const periodHours = forecastInterval === "forecast_3hr" ? 3 : 1;
    const displayRows = forecast_current_period_slice(hourlySource, periodHours, forecastInterval === "forecast_3hr");
    const tileCount = Math.min(maxTiles, displayRows.length);
    let lowTemp = null;
    let highTemp = null;

    if (forecastInterval === "forecast_1hr") {
        for (let rangeIndex = 0; rangeIndex < tileCount; rangeIndex++) {
            const rangeTempNum = forecast_number(displayRows[rangeIndex]["temperature"]);
            if (rangeTempNum !== null) {
                if (lowTemp === null || lowTemp > rangeTempNum) lowTemp = rangeTempNum;
                if (highTemp === null || highTemp < rangeTempNum) highTemp = rangeTempNum;
            }
        }
    }

    let rangeTemp = 2;
    let offset = 0;
    if (forecastInterval === "forecast_1hr" && lowTemp !== null && highTemp !== null) {
        rangeTemp = highTemp - lowTemp;
        if (rangeTemp < 2) {
            if (rangeTemp == 0) offset = 1;
            else if (rangeTemp == 1) offset = 0.67;
            rangeTemp = 2;
        }
    }

    for (let i = 0; i < tileCount; i++) {
        const row = displayRows[i] || {};
        const rowMoment = tzAdjustedMoment(row["time"]);
        const rawLabel = rowMoment.format("$obs.label.time_forecast_time");
        const previousTime = i === 0 ? Date.now() / 1000 : (displayRows[i - 1] || {})["time"];
        const showDay = !rowMoment.isSame(tzAdjustedMoment(previousTime), "day");
        const timeLabel = forecast_time(i, forecastInterval, rawLabel, showDay);
        const tempNum = forecast_number(row["temperature"]);
        const imageUrl = forecast_icon_url(row["icon"]);

        html += '<div class="forecast-day ' + tileClass + ' pirateweather-forecast ' + (i === 0 ? 'forecast-today' : 'border-left') + '" style="flex:0 0 calc(100%/' + maxTiles + '); max-width:calc(100%/' + maxTiles + ');">';
        html += '<div class="forecast-card-label"><span id="weekday">' + timeLabel + '</span></div>';

        if (forecastInterval === "forecast_1hr") {
            const tempChartPadding = (tempNum !== null && highTemp !== null)
                ? parseInt((highTemp - tempNum + offset) * 76 / rangeTemp)
                : 0;
            html += '<div class="forecast-conditions"';
            html += ' style="min-height:155px">'
            html += '<div class="forecast-temp-chart forecast-temp-chart-1hour">';
            html += '<div class="forecast-temp-chart-marker" style="top:' + tempChartPadding + 'px">';
            html += '<div class="forecast-image">';
            html += '<img id="icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async">';
            html += '</div>';
            html += '<span class="forecast-chart-temp">' + forecast_temp_text(row["temperature"]) + '</span>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
        } else {
            html += '<div class="forecast-conditions">';
            html += '<img id="icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async"><br>';
            html += '<span class="forecast-condition-text">' + (row["summary"] || "") + '</span>';
            html += '</div>';
        }

        html += '<div class="forecast-card-bottom">';
        if (forecastInterval !== "forecast_1hr") {
            html += '<span class="forecast-high">' + forecast_temp_text(row["temperature"]) + '</span>';
            html += '<br>';
        }
        html += '<div class="forecast-precip">' + forecast_metric_rows(row) + '</div>';
        html += forecast_wind_html(row, forecastInterval !== "forecast_1hr");
        html += forecast_daily_link(row["time"]);
        html += '</div>';
        html += '</div>';
    }

    return html;
}

function forecast_render_daily_tiles(dailySource, maxTiles) {
    let html = "";
    const tileCount = Math.min(maxTiles, dailySource.length);

    for (let i = 0; i < tileCount; i++) {
        const row = dailySource[i] || {};
        const dayLabel = tzAdjustedMoment((row["time"] || 0) + 7200).format("$obs.label.time_forecast_date");
        const imageUrl = forecast_icon_url(row["icon"]);

        html += '<div class="forecast-day forecast-24hour pirateweather-forecast ' + (i === 0 ? 'forecast-today' : 'border-left') + '" style="flex:0 0 calc(100%/7); max-width:calc(100%/7);">';
        html += '<div class="forecast-card-label"><span id="weekday">' + dayLabel + '</span></div>';
        html += '<div class="forecast-conditions">';
        html += '<img id="icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async">';
        html += '<br>';
        html += '<span class="forecast-condition-text">' + (row["summary"] || "") + '</span>';
        html += '</div>';
        html += '<div class="forecast-card-bottom">';
        html += '<span class="forecast-high">' + forecast_temp_text(row["temperatureHigh"]) + '</span> | <span class="forecast-low">' + forecast_temp_text(row["temperatureLow"]) + '</span>';
        html += '<br>';
        html += '<div class="forecast-precip">' + forecast_metric_rows(row) + '</div>';
        html += forecast_wind_html(row, true);
        html += forecast_daily_link(row["time"]);
        html += '</div>';
        html += '</div>';
    }

    return html;
}

function forecast_update_aqi(data) {
    try {
        if (data["aqi"] && data["aqi"][0] && data["aqi"][0]["success"] && !data["aqi"][0]["error"]) {
            const aqiPeriod = data["aqi"][0]["response"][0]["periods"][0];
            const aqiValue = aqiPeriod["aqi"];
            const aqiCategory = forecast_aqi_translate(aqiPeriod["category"]);
            jQuery(".wx-aqi").html(aqiValue);
            jQuery(".wx-aqi-category").html(aqiCategory);
            if ("$Extras.aqi_location_enabled" === "1") {
                const aqiPlace = data["aqi"][0]["response"][0]["place"]["name"] || "";
                jQuery(".aqi_location_outer").html(aqiPlace ? "<br>" + aqiPlace : "").css('textTransform', 'capitalize');
            }
            try {
                jQuery(".station-observations .aqi").html(aqiValue + " (" + aqiCategory + ")");
            } catch (err) {
                // AQI not in the station observation table, so silently exit
            }
        } else if (data["aqi"] && data["aqi"][0] && data["aqi"][0]["success"] && data["aqi"][0]["error"] && data["aqi"][0]["error"]["code"] === "warn_no_data") {
            const aqiNoDataCategory = forecast_aqi_translate("");
            jQuery(".wx-aqi").html("No Data");
            jQuery(".wx-aqi-category").html(aqiNoDataCategory);
            if ("$Extras.aqi_location_enabled" === "1") jQuery(".aqi_location_outer").html("");
            try {
                jQuery(".station-observations .aqi").html("No Data (" + aqiNoDataCategory + ")");
            } catch (err) {
                // AQI not in the station observation table, so silently exit
            }
        }
    } catch (err) {
        belchertown_debug("Forecast: AQI data missing or malformed, skipping: " + err);
    }
}

function forecast_has_common_schema(data) {
    return data && Array.isArray(data["hourly"]) && Array.isArray(data["daily"]);
}

function forecast_render_common(data) {
    forecast_update_aqi(data);

    const hourly = Array.isArray(data["hourly"]) ? data["hourly"] : [];
    const threeHourly = Array.isArray(data["threeHourly"]) ? data["threeHourly"] : forecast_pick_three_hourly_from_current_period(hourly);
    const daily = Array.isArray(data["daily"]) ? data["daily"] : [];
    const lastUpdated = data["generated_at"] || data["timestamp"] || (Date.now() / 1000);
    const lastUpdatedText = tzAdjustedMoment(lastUpdated).format('$obs.label.time_forecast_last_updated');

    jQuery(".forecast-subtitle").html(forecast_sentence_text(["$obs.label.forecast_last_updated", lastUpdatedText]));
    jQuery(".onehr_forecasts").html(forecast_render_hourly_tiles(hourly, 16, "forecast-1hour"));
    jQuery(".threehr_forecasts").html(forecast_render_hourly_tiles(threeHourly, 8, "forecast-3hour"));
    jQuery(".day_forecasts").html(forecast_render_daily_tiles(daily, 7));
    show_forcast_alert(data);
}

function update_forecast_data(data) {
    forecast_provider = "$Extras.forecast_provider";
    if (forecast_provider == "openmeteo" || forecast_provider == "open_meteo") {
        forecast_provider = "open-meteo";
    }
    belchertown_debug("Forecast: Provider is " + forecast_provider);
    belchertown_debug("Forecast: Updating data");
    belchertown_debug(data);

    if (forecast_provider == "N/A") {
        jQuery(".forecastrow").hide();
        belchertown_debug("Forecast: No provider, hiding forecastrow");
        return;
    } else if (forecast_has_common_schema(data)) {
        forecast_render_common(data);
        return;
    } else {
        belchertown_debug("Forecast: Missing normalized forecast schema");
    }
}

