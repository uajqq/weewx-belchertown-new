#errorCatcher Echo
##
## Specifying an encoding of UTF-8 is usually safe, but if your text is 
## actually in Latin-1, then you should replace the string "UTF-8" with "latin-1"
## If you do this, you should also change the 'Content-Type' metadata below.
#encoding UTF-8
#import math
#from user.belchertown import build_almanac_template_context
##
#set global $page = "home"

#include "header.html.tmpl"

<script type="text/javascript">
    (function() {
    function initHomePage() {
    window.finalRotation = window.finalRotation || 0;
    // #if $Extras.has_key("mqtt_websockets_enabled") and $Extras.mqtt_websockets_enabled == '1'
    window.mqttMsg = window.mqttMsg || null;
    window.mqttclient = "website" + Math.floor(Math.random() * 999999999);
    // #end if
    var defaultForecastInterval = 24;
    // #if $Extras.has_key("forecast_interval_hours") and $Extras.forecast_interval_hours == '1'
    defaultForecastInterval = 1;
    // #elif $Extras.has_key("forecast_interval_hours") and $Extras.forecast_interval_hours == '3'
    defaultForecastInterval = 3;
    // #elif $Extras.has_key("forecast_interval_hours") and $Extras.forecast_interval_hours == '24'
    defaultForecastInterval = 24;
    // #end if
    window.moment_locale = "$system_locale_js";
    moment.locale(window.moment_locale);

    window.homepage_chartgroup = "$Extras.highcharts_homepage_chartgroup";
    window.homepageChartsInitialized = false;

    window.renderHomepageCharts = function(forceRender = false) {
        if (!forceRender && window.homepageChartsInitialized) {
            return;
        }

        var renderChartsNow = function() {
            showChart(window.homepage_chartgroup);
            window.homepageChartsInitialized = true;
        };

        if (typeof belchertownEnsureHighcharts === "function") {
            belchertownEnsureHighcharts().then(function() {
                renderChartsNow();
            }).catch(function(err) {
                console.log("ERROR: Failed loading Highcharts assets: " + err.message);
            });
            return;
        }

        renderChartsNow();
    };

    function autoRefreshPage() {
        location.reload();
    }

    ajaxweewx().then(function(weewx_data) { // This call will make sure json/weewx_data.json is loaded before anything else
        update_weewx_data(weewx_data); // Initial call to update (date, daily high, low, etc)
        belchertown_debug(weewx_data); // Make weewx_data.json available in debugging console
        // #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
        // Load forecast
        ajaxforecast(); // Initial call to load forecast data like 8 day outlook, weather icon and observation text
        // #end if

        // #if $Extras.has_key("mqtt_websockets_enabled") and $Extras.mqtt_websockets_enabled == '0' and $Extras.has_key("webpage_autorefresh") and $Extras.webpage_autorefresh != '0'
        // Reload the page on an interval for updated data. This is for non-mqtt websocket websites
        setTimeout(autoRefreshPage, $Extras.webpage_autorefresh);
        // #end if

        jQuery(document).ready(function() {
            // #if $Extras.has_key("aqi_enabled") and $Extras.aqi_enabled == '1'
            get_aqi_color("$aqi");
            // #end if

            // #if $Extras.has_key("beaufort_category") and $Extras.beaufort_category == '1' and $Extras.beaufort_category_gusts != '1'
            jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort("$current.windSpeed.knot.toString(addLabel=False)")));
            // #else
            jQuery(".beaufort").html(beaufort_cat(kts_to_beaufort("$current.windGust.knot.toString(addLabel=False)")));
            // #end if

            get_outTemp_color("$unit.unit_type.outTemp", "$current.outTemp.formatted");

            initialize_wind_compass_marker(
                "$current.windDir.formatted",
                "$current.windSpeed.knot.toString(addLabel=False, NONE_string='')",
                "$current.windGust.knot.toString(addLabel=False, NONE_string='')"
            );

            // Update the Last Updated timestamp with moment.js,
            updated = tzAdjustedMoment($current.dateTime.raw).format("$obs.label.time_last_updated");
            updated_text = "$obs.label.header_last_updated " + updated;
            jQuery(".updated").html(updated_text);

            // #if $Extras.has_key('earthquake_enabled') and $Extras.earthquake_enabled == '1'            
            if (moment.unix("$earthquake_time").isValid()) {
                // Check that the time is the time (number) and not the "no earthquake available" wording
                jQuery(".earthquake-time").html(tzAdjustedMoment("$earthquake_time").format("$obs.label.time_earthquake"));
            } else {
                jQuery(".earthquake-time").html("$earthquake_time");
            }
            // #end if

            // #if $Extras.has_key('highcharts_enabled') and $Extras.highcharts_enabled == '1'
            var chartgroups_raw = $charts; // All charts and IDs
            var thisPageCharts = chartgroups_raw[window.homepage_chartgroup]; // Filter all charts down to the ones we want for this page
            // Loop through the chart groups for this page and add the chart divs to the page
            try {
                thisPageCharts.forEach(chartID => {
                    jQuery(".chart-outer").append('<div class="homepage-chart-panel"><div id="' + chartID + '" style="width:100%;height:100%;"></div></div>');
                });

                belchertown_run_when_visible(".homepage-card--charts", function() {
                    window.renderHomepageCharts(false);
                }, {
                    rootMargin: "350px 0px",
                    threshold: 0.01,
                    fallbackDelayMs: 8000,
                });
            } catch (err) {
                console.log("ERROR: Cannot add charts from [" + window.homepage_chartgroup + "] chart group: " + err.message);
            }
            // #end if

            // #if $Extras.has_key("mqtt_websockets_enabled") and $Extras.mqtt_websockets_enabled == '1'
            if (getURLvar("offline") && (getURLvar("offline") == "true" || getURLvar("offline") == "1")) {
                belchertown_debug("MQTT: offline url var detected. Skipping MQTT connect.");
            } else {
                connect(); // Begin mqtt after WeeWX initial load
                // If the Restart button is clicked, reconnect to mqtt and update WeeWX and forecast data
                jQuery(document).on('click', '.restart-interval', function() {
                    ajaxweewx().then(function(weewx_data) { // This call will make sure json/weewx_data.json is loaded before anything else
                        update_weewx_data(weewx_data); // Initial call to update (date, daily high, low, etc)
                        belchertown_debug(weewx_data); // Make weewx_data.json available in debugging console

                        // #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
                        ajaxforecast(); // Update forecast data
                        // #end if
                        ajaximages(); // Update radar and home page hook "img src" if present
                        connect(); // Restart mqtt after WeeWX data's re-loaded
                        // #if $Extras.has_key('highcharts_enabled') and $Extras.highcharts_enabled == '1'
                        window.renderHomepageCharts(true);
                        // #end if
                    }).catch(function(e) {
                        console.log(e);
                    });
                });
            }

            // #if $Extras.has_key("reload_hook_images") and $Extras.reload_hook_images == '1'
            // Update any images in the radar section or hooks

            // #if $Extras.has_key("reload_images_radar") and $Extras.reload_images_radar != '-1'
            var reload_radar_timer = $Extras.reload_images_radar * 1000; // convert to millis
            setTimeout(function() {ajaximages("radar", $Extras.reload_images_radar);}, reload_radar_timer);
            // #end if

            // #if $Extras.has_key("reload_images_hook_asi") and $Extras.reload_images_hook_asi != '-1'
            var reload_asi_timer = $Extras.reload_images_hook_asi * 1000; // convert to millis
            setTimeout(function() {ajaximages("index-hook-after-station-info", $Extras.reload_images_hook_asi);}, reload_asi_timer);
            // #end if

            // #if $Extras.has_key("reload_images_hook_af") and $Extras.reload_images_hook_af != '-1'
            var reload_af_timer = $Extras.reload_images_hook_af * 1000; // convert to millis
            setTimeout(function() {ajaximages("index-hook-after-forecast", $Extras.reload_images_hook_af);}, reload_af_timer);
            // #end if

            // #if $Extras.has_key("reload_images_hook_as") and $Extras.reload_images_hook_as != '-1'
            var reload_as_timer = $Extras.reload_images_hook_as * 1000; // convert to millis
            setTimeout(function() {ajaximages("index-hook-after-snapshot", $Extras.reload_images_hook_as);}, reload_as_timer);
            // #end if

            // #if $Extras.has_key("reload_images_hook_ac") and $Extras.reload_images_hook_ac != '-1'
            var reload_ac_timer = $Extras.reload_images_hook_ac * 1000; // convert to millis
            setTimeout(function() {ajaximages("index-hook-after-charts", $Extras.reload_images_hook_ac);}, reload_ac_timer);
            // #end if

            // #end if

            // #else
            // MQTT Websockets not enabled

            // #if $Extras.has_key("show_last_updated_alert") and $Extras.show_last_updated_alert == '1'
            // Check if we need to alert on old information - if time now, minus the last update is greater than the threshold, show an alert.
            if ((Math.floor(new Date().getTime() / 1000.0) - $Extras.last_updated_alert_threshold) > $current.dateTime.raw) {
                belchertown_debug("Last Updated Alert: The WeeWX report timestamp is " + $current.dateTime.raw + ". The current timestamp is " + Math.floor(new Date().getTime() / 1000.0) + ". The threshold is " + $Extras.last_updated_alert_threshold + ". Report timestamp is greater than threshold of current time, showing no update alert.");
                last_updated_alert_text = "<i class='fa fa-exclamation-triangle' style='color:red;'></i> $obs.label.header_last_updated_alert";
                jQuery(".last-updated-alert").html(last_updated_alert_text);
                jQuery(".last-updated-alert").show();
            }
            // #end if

            // Update the Last Updated timestamp with moment.js,
            updated = tzAdjustedMoment($current.dateTime.raw).format("$obs.label.time_last_updated");
            updated_text = "$obs.label.header_last_updated " + updated;
            jQuery(".updated").html(updated_text);

            // #end if

            //  display the relevant forecast; a new session will display the default forecast, a reloaded session the currently displayed forecast
            if (typeof forecast_default === "function") {
                forecast_default(defaultForecastInterval);
            }
            if (sessionStorage.getItem("forecastInterval")) {
                interval = sessionStorage.getItem("forecastInterval");
                sessionStorage.setItem("forecastInterval", null);
                forecast_select(interval);
            } else {
                sessionStorage.setItem("forecastInterval", null);
                forecast_select(sessionStorage.getItem("defaultInterval"));
            }
        });
    }).catch(function(e) {
        console.log(e);
    });

    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initHomePage);
    } else {
        initHomePage();
    }
    })();

</script>

<div class="site-inner">
    <main class="content">    

        <article class="weewx frontpage" itemscope="" itemtype="http://schema.org/CreativeWork">
        
            <!-- Top bar with city and share -->
            <div class="wx-stn-info-container">
                <div class="wx-stn-name">
                    <h1>$obs.label.home_page_header</h1>                    
                </div>
                <div class="wx-stn-info">
                    $obs.label.powered_by
                </div>
                <div class="clear"></div>
                <!-- Updated time ago -->
                <div class="updated-wrapper">
                    <div class="onlineMarkerOuter">
                        <span class="loadingMarker" style="display:none"></span>
                        <span class="onlineMarker" style="display:none"></span>
                        <span class="offlineMarker" style="display:none"></span>
                    </div>
                    <div class="updated"></div><!-- AJAX moment.js -->
                </div>
                #if $social_html != ""
                $social_html
                #end if
                <div class="clear"></div>
                <div class="last-updated-alert" style="display:none;"></div><!-- AJAX moment.js -->
                #if $Extras.has_key("forecast_alert_enabled") and $Extras.forecast_alert_enabled == '1'
                <div class="wx-stn-alert"><span class="wx-stn-alert-text"></span></div><!-- AJAX -->
                #end if
            </div>
            
            <div class="homepage-layout">
                <div class="homepage-hero">
                    <div class="homepage-primary-grid">
                        <section class="homepage-card homepage-card--temperature">
                            <div class="homepage-card-body homepage-temperature-content">
                                <div class="row temp-observation">
                                    <div class="col-sm-6 current_obs_top">
                                        #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
                                            #set $homepage_current_icon = "unknown.png"
                                            #if $current_obs_icon != ""
                                                #set $homepage_current_icon = $current_obs_icon
                                            #end if
                                            <img id="wxicon" src="$relative_url/images/$homepage_current_icon" alt="Current conditions" width="128" height="101" loading="eager" decoding="async" fetchpriority="high">
                                        #end if
                                    </div>
                                    <div class="col-sm-6 current_temp">
                                        <div class="outtemp_outer">
                                            <span class="outtemp">$current.outTemp.formatted</span>
                                            <sup class="outtempunitlabelsuper">$unit.label.outTemp</sup>
                                        </div><!-- AJAX -->
                                    </div>
                                </div>
                                <div class="row homepage-temperature-details">
                                    <div class="col-sm-6 current-obs-container">
                                        <div class="current-obs-text">
                                            $current_obs_summary
                                        </div>
                                        #if $Extras.has_key("aqi_enabled") and $Extras.aqi_enabled == '1'
                                        <div class="aqi_outer">
                                            $obs.label.aqi: <span class="wx-aqi">$aqi</span> (<span class="wx-aqi-category">$aqi_category</span>)
                                            #if $Extras.has_key("aqi_location_enabled") and $Extras.aqi_location_enabled == '1'
                                            <span class="aqi_location_outer"><br>$aqi_location</span>
                                            #end if
                                        </div>
                                        #end if
                                    </div>
                                    <div class="col-sm-6 homepage-temperature-sidebar">
                                        #if $current.appTemp.has_data
                                        <div class="feelslike">$obs.label.feels_like $current.appTemp</div><!-- AJAX -->
                                        #end if
                                        <div class="stn-high-low">
                                            <table class="stn-high-low-table">
                                                <tbody>
                                                    <tr>
                                                        <td class="stn-high-low-table-title">$obs.label.highest_temperature</td>
                                                        <td class="stn-high-low-table-title border-left">$obs.label.lowest_temperature</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="high">$day.outTemp.max</td>
                                                        <td class="border-left low">$day.outTemp.min</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <section class="homepage-card homepage-card--observations">
                            <div class="homepage-card-body station-observations">
                                <table cellpadding="0" cellspacing="0">
                                    <tbody>
                                        $station_obs_html
                                    </tbody>
                                </table>
                                #if os.path.exists("index_hook_after_station_observations.inc")
                                <div class="index_hook_after_station_observations">
                                    #include "index_hook_after_station_observations.inc"
                                </div>
                                #end if
                            </div>
                        </section>

                        <section class="homepage-card homepage-card--wind">
                            <div class="homepage-card-body">
                                <div class="windrow">
                                    <div class="col-sm-12 current_wind">
                                        <div class="col-sm-6">
                                            <div class="compass">
                                                <div class="direction">
                                                    <span class="curwinddir">
                                                    #if $current.windDir.ordinal_compass == "N/A"
                                                    --
                                                    #else
                                                    $current.windDir.ordinal_compass
                                                    #end if
                                                    </span>
                                                    <span class="curwinddeg">
                                                    #if $current.windDir.raw is None:
                                                    -
                                                    #else
                                                    $current.windDir.format("%.0f")
                                                    #end if
                                                    </span>
                                                </div>
                                                <div class="arrow"></div>
                                            </div>
                                        </div>
                                        <div class="col-sm-6 windspeedtable">
                                            <table class="wind-table">
                                                <tbody>
                                                    <tr>
                                                        <td class="windtext">$obs.label.wind_speed</td>
                                                        <td class="windtext border-left gust">$obs.label.wind_gust</td>
                                                    </tr>
                                                    <tr>
                                                        <td>
                                                            <span class="curwindspeed">
                                                                $current.windSpeed.toString(addLabel=False, NONE_string="--")
                                                            </span>
                                                        </td>
                                                        <td class="border-left gust">&nbsp;
                                                            <span class="curwindgust">
                                                                $current.windGust.toString(addLabel=False, NONE_string="--")
                                                            </span>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="mph" colspan="3">$unit.label.windSpeed</td>
                                                    </tr>
                                                    #if $Extras.has_key("beaufort_category") and $Extras.beaufort_category == '1'
                                                    <tr>
                                                        <td class="beaufort" colspan="4"></td>
                                                    </tr>
                                                    #end if
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    #if os.path.exists("index_hook_after_wind_table.inc")
                                    <div class="index_hook_after_wind_table">
                                        #include "index_hook_after_wind_table.inc"
                                    </div>
                                    #end if
                                </div>
                            </div>
                        </section>

                        <section class="homepage-card homepage-card--almanac">
                            <div class="homepage-card-body">
                                <div class="almanac-main">
                                #set $almanac_diagram_context = build_almanac_template_context($almanac, $current.dateTime.raw, $almanac.hasExtras, $relative_url)
                                #set $almanac_inline_markup_attr = $almanac_diagram_context.get("almanac_inline_markup_attr", "")
                                #if $almanac.hasExtras or ($almanac_inline_markup_attr != "" and $almanac_inline_markup_attr != "None")
                                $almanac_inline_markup_attr
                                #end if
                                </div>
                                #if $Extras.has_key("almanac_extras") and $Extras.almanac_extras == '1'
                                <div class="daylight-change">
                                    #include "daylight.inc"
                                </div>
                                #end if
                                <div class="row small-almanac">
                                    <div class="moon almanac-meta-block almanac-meta-block--moon">
                                        <div class="moon-container">
                                            <span class="moon-icon">
                                                <div class="moon-icon"></div><!-- JS -->
                                            </span>
                                            <strong><span class="moon-phase">#echo $almanac.moon_phase.title()#</span></strong><!-- AJAX -->
                                            <span class="moon-visible"><strong>$almanac.moon_fullness%</strong> $obs.label.moon_visible</span><!-- AJAX -->
                                        </div>
                                    </div>
                                    #if $Extras.has_key("almanac_extras") and $Extras.almanac_extras == '1' and $almanac.hasExtras
                                    <div class="almanac-details-link almanac-details-link--inline">
                                        <a href="#almanac" data-toggle="modal" data-target="#almanac">$obs.label.almanac_more_details</a>
                                    </div>
                                    #end if
                                </div>
                                    #if $Extras.has_key("almanac_extras") and $Extras.almanac_extras == '1' and $almanac.hasExtras
                                    <div class="modal fade" id="almanac" tabindex="-1" role="dialog" aria-labelledby="almanac" aria-hidden="true">
                                        <div class="modal-dialog modal-lg" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                    <h4 class="modal-title" id="almanac">$obs.label.almanac_modal_title</h4>
                                                </div>
                                                <div class="almanac-extras-modal-body modal-body">
                                                    #include "celestial.inc"
                                                </div><!-- AJAX -->
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-primary" data-dismiss="modal">$obs.label.close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    #end if
                                </div>
                        </section>
                    </div>

                    <section class="homepage-card homepage-card--radar">
                        <div class="homepage-card-body homepage-radar-content">
                            #if os.path.exists("index_radar.inc")
                            #include "index_radar.inc"
                            #else
                            <div class="radar_image">$radar_html</div>
                            #end if
                        </div>
                    </section>
                </div>

            #if os.path.exists("index_hook_after_station_info.inc")
            <div class="homepage-hook index-hook-after-station-info">
                #include "index_hook_after_station_info.inc"
            </div>
            #end if
            #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1' and (($Extras.has_key("forecast_interval_hours") and $Extras.forecast_interval_hours != '0') or not ($Extras.has_key("forecast_interval_hours")))
            <section class="homepage-card homepage-card--forecast">
                <div class="homepage-card-header homepage-card-header--forecast">
                    <div class="forecast-header-text">
                        <h2>
                            $obs.label.forecast_header.rstrip('. '). <span class="forecast-subtitle"></span><!-- moment.js -->
                            #if $Extras.has_key("current_conditions_timestamp_enabled") and $Extras.current_conditions_timestamp_enabled == '1'
                            <span class="forecast-current-conditions-inline"> $obs.label.current_conditions_last_updated.rstrip('. ')&nbsp;<span class="current-conditions-subtitle"></span><!-- moment.js --></span>
                            #end if
                        </h2>
                    </div>
                    <div class="forecast-menu forecast-menu--header">
                        $obs.label.forecast_interval_caption <div class="forecast-button" onclick="forecast_select(1);" id="button1">1</div>
                        <div class="forecast-button" onclick="forecast_select(3);" id="button3">3</div>
                        <div class="forecast-button" onclick="forecast_select(24);" id="button24">24</div>
                    </div>
                </div>
                <div class="row forecastrow">
                    #if $Extras.has_key("forecast_interval_hours") and $Extras.forecast_interval_hours != '0'
                    <div id="1hour-selected-forecast" style="display: none;">
                        <div class="col-lg-12 row onehr_forecasts row-no-padding"></div><!-- JS -->
                    </div>
                    #end if

                    <div id="3hour-selected-forecast" style="display: none;">
                        <div class="col-lg-12 row threehr_forecasts row-no-padding"></div><!-- JS -->
                    </div>

                    <div id="24hour-selected-forecast" style="display: none;">
                        <div class="col-lg-12 row day_forecasts row-no-padding"></div><!-- JS -->
                    </div>
                </div>
            </section>

            #end if

            #if os.path.exists("index_hook_after_forecast.inc")
            <div class="homepage-hook index-hook-after-forecast">
                #include "index_hook_after_forecast.inc"
            </div>
            #end if                        
            #if $Extras.has_key('earthquake_enabled') and $Extras.earthquake_enabled == '1'
            #set $homepage_secondary_row_class = "homepage-secondary-row homepage-secondary-row--with-earthquake"
            #else
            #set $homepage_secondary_row_class = "homepage-secondary-row homepage-secondary-row--single"
            #end if
            <div class="$homepage_secondary_row_class">
                <section class="homepage-card homepage-card--records">
                    <div class="homepage-card-header">
                        <h2>$obs.label.weather_snapshots.rstrip('. '). <a href="$relative_url/records" class="homepage-card-link-inline">$obs.label.weather_snapshots_link</a></h2>
                    </div>
                    <div class="homepage-card-body">
                        <div class="row">
                            <div class="col-sm-6 stn-quick-stats">
                                <div class="stats-title">
                                    <select id="snapshot-day-select" class="snapshot-period-select">
                                        <option value="day">$obs.label.snapshot_period_today</option>
                                        <option value="yesterday">$obs.label.snapshot_period_yesterday</option>
                                        <option value="week">$obs.label.snapshot_period_7days</option>
                                    </select>
                                </div>
                                <div class="snapshot-metric-grid">
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_high</span>
                                        <span class="snapshot-metric-value dailystatshigh">$day.outTemp.max</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_low</span>
                                        <span class="snapshot-metric-value dailystatslow">$day.outTemp.min</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_today_avg_wind</span>
                                        <span class="snapshot-metric-value dailystatswindavg">$day.wind.avg</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_today_high_wind</span>
                                        <span class="snapshot-metric-value dailystatswindmax">$day.wind.max</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_today_rain</span>
                                        <span class="snapshot-metric-value dailystatsrain">$day.rain.sum</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_today_rainrate</span>
                                        <span class="snapshot-metric-value dailystatsrainrate">$day.rainRate.max</span><!-- AJAX -->
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6 stn-quick-stats homepage-snapshot-column homepage-snapshot-column--secondary">
                                <div class="stats-title">
                                    <select id="snapshot-month-select" class="snapshot-period-select">
                                        <option value="month">$obs.label.snapshot_period_month</option>
                                        <option value="year">$obs.label.snapshot_period_ytd</option>
                                        <option value="last365">$obs.label.snapshot_period_last365</option>
                                        <option value="alltime">$obs.label.snapshot_period_alltime</option>
                                    </select>
                                </div>
                                <div class="snapshot-metric-grid">
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_high</span>
                                        <span class="snapshot-metric-value monthstatshigh">$month.outTemp.max</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_low</span>
                                        <span class="snapshot-metric-value monthstatslow">$month.outTemp.min</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_month_avg_wind</span>
                                        <span class="snapshot-metric-value monthstatswindavg">$month.wind.avg</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_month_high_wind</span>
                                        <span class="snapshot-metric-value monthstatswindmax">$month.wind.max</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_month_rain</span>
                                        <span class="snapshot-metric-value monthstatsrain">$month.rain.sum</span><!-- AJAX -->
                                    </div>
                                    <div class="snapshot-metric">
                                        <span class="snapshot-metric-label">$obs.label.snapshot_month_rainrate</span>
                                        <span class="snapshot-metric-value monthstatsrainrate">$month.rainRate.max</span><!-- AJAX -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                #if $Extras.has_key('earthquake_enabled') and $Extras.earthquake_enabled == '1'
                <section class="homepage-card homepage-card--earthquake earthquake-container">
                    <div class="homepage-card-header">
                        <h2>$obs.label.earthquake_title</h2>
                    </div>
                    <div class="homepage-card-body eq-region">
                        <div class="earthquake-subcard earthquake-subcard--summary">
                            <span class="earthquake-time"></span><!-- moment.js -->
                        </div>
                        <div class="earthquake-subcard earthquake-subcard--stats">
                            <a class="earthquake-info-link" href="$earthquake_url" target="_blank">
                                <div class="row earthquake-info">
                                    <div class="col-sm-6 earthquake-stat earthquake-stat--magnitude">
                                        <i class="wi wi-earthquake" aria-hidden="true"></i><span class="earthquake-stat-label">$obs.label.earthquake_magnitude</span> <span class="magnitude">$earthquake_magnitude</span>
                                    </div>
                                    <div class="col-sm-6 earthquake-distance-outer border-left earthquake-stat earthquake-stat--distance">
                                        <span class="earthquake-distance">$earthquake_distance_away $earthquake_distance_label $earthquake_bearing</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                        #if $earthquake_lat != '' and $earthquake_lon != ''
                        #set $eq_lat = float($earthquake_lat)
                        #set $eq_lon = float($earthquake_lon)
                        #set $eq_zoom = 6
                        #set $eq_n = 2 ** $eq_zoom
                        #set $eq_lat_rad = math.radians($eq_lat)
                        #set $eq_tile_x = int((($eq_lon + 180.0) / 360.0) * $eq_n)
                        #set $eq_tile_y = int((1.0 - math.log(math.tan($eq_lat_rad) + (1.0 / math.cos($eq_lat_rad))) / math.pi) / 2.0 * $eq_n)
                        <div class="earthquake-subcard earthquake-subcard--map">
                            <div class="earthquake-map-wrap">
                                <img
                                    class="earthquake-map"
                                    alt="$obs.label.earthquake_title"
                                    loading="lazy"
                                    decoding="async"
                                    fetchpriority="low"
                                    src="https://tile.openstreetmap.org/${eq_zoom}/${eq_tile_x}/${eq_tile_y}.png"
                                    onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='https://a.tile.openstreetmap.org/${eq_zoom}/${eq_tile_x}/${eq_tile_y}.png';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='https://b.tile.openstreetmap.org/${eq_zoom}/${eq_tile_x}/${eq_tile_y}.png';}else if(this.dataset.fallback==='2'){this.dataset.fallback='3';this.src='https://c.tile.openstreetmap.org/${eq_zoom}/${eq_tile_x}/${eq_tile_y}.png';}" />
                                <span class="earthquake-map-marker" aria-hidden="true"></span>
                            </div>
                        </div>
                        #end if
                    </div>
                </section>
                #end if
            </div>
            
            #if os.path.exists("index_hook_after_snapshot.inc")
            <div class="homepage-hook index-hook-after-snapshot">
                #include "index_hook_after_snapshot.inc"
            </div>
            #end if                          
            
            #if $Extras.has_key('highcharts_enabled') and $Extras.highcharts_enabled == '1'
            <section class="homepage-card homepage-card--charts">
                <div class="homepage-card-header">
                    <h2><span class="homepage-chartgroup-title">$chartpage_titles_dict[$Extras.highcharts_homepage_chartgroup].rstrip('. ').</span> <a href="$relative_url/charts" class="homepage-card-link-inline">$homepage_charts_link_label.strip()</a></h2>
                </div>
                <div class="chart-outer"></div><!-- JS populated -->
            </section>
            #end if
            </div>
            
            <div class="clear"></div>
            
            #if os.path.exists("index_hook_after_charts.inc")
            <div class="homepage-hook index-hook-after-charts">
                #include "index_hook_after_charts.inc"
            </div>
            #end if  
            
        </article>

    </main>
</div>

