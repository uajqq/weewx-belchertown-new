function belchertown_decode_document_labels(root) {
    belchertown_decode_text_nodes(root);
    belchertown_decode_label_attributes(root);
    belchertown_decode_meta_labels(root);
}

function tzAdjustedMoment(input) {
    let tz = "$moment_js_tz";
    if (!tz) {
        return moment.unix(input).utcOffset($moment_js_utc_offset);
    } else {
        return moment.unix(input).tz(tz);
    }
}
