var pages = ["charts", "records", "reports", "about", "pi"];
var pageName = "";

// If this page we're on now is listed as a subpage, use ".." to get to the relative root
function get_relative_url() {
    var sPath = window.location.pathname.replace(/\/$/, "");
    pageName = sPath.substring(sPath.lastIndexOf('/') + 1);
    const relative_url = pages.includes(pageName) ? ".." : ".";

    // belchertown_debug is defined in new-belchertown.js.tmpl and may not exist yet
    // when this utility file is parsed.
    if (typeof belchertown_debug === "function") {
        belchertown_debug("URL: Relative URL is: " + relative_url);
    }

    return relative_url;
}

// Get the URL variables. Source: https://stackoverflow.com/a/26744533/1177153
function getURLvar(k) {
    var p = {};
    location.search.replace(/[?&]+([^=&]+)=([^&]*)/gi, function(s, k, v) {p[k] = v});
    return k ? p[k] : p;
}

// Title case strings. https://stackoverflow.com/a/45253072/1177153
function titleCase(str) {
    str = belchertown_decode_html_entities(str);
    return str.toLowerCase().split(' ').map(function(word) {
        return word.replace(word[0], word[0].toUpperCase());
    }).join(' ');
}

function belchertown_decode_html_entities(value) {
    var text = value == null ? "" : String(value);
    var textarea = document.createElement("textarea");
    var decoded = text;
    var previous;
    var i;

    for (i = 0; i < 3 && decoded.indexOf("&") !== -1; i++) {
        previous = decoded;
        textarea.innerHTML = previous;
        decoded = textarea.value;
        if (decoded === previous) {
            break;
        }
    }

    return decoded;
}

function belchertown_escape_html(value) {
    var div = document.createElement("div");
    div.textContent = value == null ? "" : String(value);
    return div.innerHTML;
}

function belchertown_label_text(value) {
    return belchertown_decode_html_entities(value);
}

function belchertown_label_html(value) {
    return belchertown_escape_html(belchertown_label_text(value));
}

function belchertown_locale_date_order(localeName) {
    var localeValue = localeName || "$system_locale_js" || "$moment_locale_js" || "en-US";
    var sampleDate = new Date(Date.UTC(2020, 10, 22, 12, 0, 0));
    var i;

    if (typeof Intl !== "undefined" && typeof Intl.DateTimeFormat === "function") {
        try {
            var parts = new Intl.DateTimeFormat(localeValue, {
                day: "numeric",
                month: "numeric"
            }).formatToParts(sampleDate);

            for (i = 0; i < parts.length; i++) {
                if (parts[i].type === "day") {
                    return "day_month";
                }
                if (parts[i].type === "month") {
                    return "month_day";
                }
            }
        } catch (e) {
            // Fall back below.
        }
    }

    localeValue = String(localeValue || "").toLowerCase();
    if (localeValue === "c" || localeValue === "posix") {
        return "month_day";
    }
    if (/^en-(gb|au|nz|ie|za|in|sg|my|hk)\b/.test(localeValue)) {
        return "day_month";
    }
    if (/^en\b/.test(localeValue)) {
        return "month_day";
    }
    return "day_month";
}

function belchertown_moment_compact_date_format(includeYear) {
    if (belchertown_locale_date_order() === "month_day") {
        return includeYear ? "MMM D, YYYY" : "MMM D";
    }
    return includeYear ? "D MMM YYYY" : "D MMM";
}

function belchertown_forecast_date_format(configuredFormat) {
    var format = belchertown_label_text(configuredFormat);
    if (format && format !== "time_forecast_date" && format !== "ddd M/DD" && format !== "ddd M/D") {
        return format;
    }

    return belchertown_locale_date_order() === "month_day" ? "ddd M/D" : "ddd D/M";
}

function belchertown_highcharts_compact_date_format(includeTime) {
    var baseFormat = belchertown_locale_date_order() === "month_day" ? "%b %e" : "%e %b";
    return includeTime ? baseFormat + " %H:%M" : baseFormat;
}

function belchertown_date_time_parse_formats() {
    var monthFirstFormats = [
        "MM/DD/YYYY HH:mm:ss",
        "M/D/YYYY H:mm:ss",
        "MM/DD/YYYY HH:mm",
        "M/D/YYYY H:mm",
        "MM/DD/YYYY h:mm:ss A",
        "M/D/YYYY h:mm:ss A",
        "MM/DD/YYYY h:mm A",
        "M/D/YYYY h:mm A"
    ];
    var dayFirstFormats = [
        "DD/MM/YYYY HH:mm:ss",
        "D/M/YYYY H:mm:ss",
        "DD/MM/YYYY HH:mm",
        "D/M/YYYY H:mm",
        "DD/MM/YYYY h:mm:ss A",
        "D/M/YYYY h:mm:ss A",
        "DD/MM/YYYY h:mm A",
        "D/M/YYYY h:mm A"
    ];
    var commonFormats = [
        "YYYY-MM-DD HH:mm:ss",
        "YYYY-MM-DD HH:mm",
        "YYYY-MM-DD h:mm A",
        "ll LT",
        "lll",
        "LLL"
    ];
    var formats = belchertown_locale_date_order() === "month_day"
        ? monthFirstFormats.concat(dayFirstFormats)
        : dayFirstFormats.concat(monthFirstFormats);

    if (typeof moment !== "undefined" && moment.ISO_8601) {
        formats.unshift(moment.ISO_8601);
    }

    return formats.concat(commonFormats);
}

function belchertown_decode_text_node_filter(textNode) {
    var parent = textNode.parentNode;
    var tagName;

    while (parent && parent.nodeType === 1) {
        tagName = parent.tagName ? parent.tagName.toLowerCase() : "";
        if (tagName === "script" || tagName === "style" || tagName === "textarea" || tagName === "code" || tagName === "pre") {
            return false;
        }
        parent = parent.parentNode;
    }

    return true;
}

function belchertown_decode_text_nodes(root) {
    var node = root && root.jquery ? root[0] : root;
    var walker;
    var textNode;
    var showText = typeof NodeFilter !== "undefined" ? NodeFilter.SHOW_TEXT : 4;
    var filterAccept = typeof NodeFilter !== "undefined" ? NodeFilter.FILTER_ACCEPT : 1;
    var filterReject = typeof NodeFilter !== "undefined" ? NodeFilter.FILTER_REJECT : 2;

    if (!node || typeof document.createTreeWalker !== "function") {
        return;
    }

    walker = document.createTreeWalker(node, showText, {
        acceptNode: function(textNode) {
            return belchertown_decode_text_node_filter(textNode) ? filterAccept : filterReject;
        }
    }, false);
    while ((textNode = walker.nextNode())) {
        textNode.nodeValue = belchertown_decode_html_entities(textNode.nodeValue);
    }
}

function belchertown_decode_label_attributes(root) {
    var node = root && root.jquery ? root[0] : root;
    var selector = "[aria-label], [alt], [title], [placeholder], [data-original-title], [data-responsive-menu-label]";
    var attrs = ["aria-label", "alt", "title", "placeholder", "data-original-title", "data-responsive-menu-label"];
    var elements = [];

    function decodeElementAttributes(element) {
        attrs.forEach(function(attr) {
            if (element.hasAttribute(attr)) {
                element.setAttribute(attr, belchertown_decode_html_entities(element.getAttribute(attr)));
            }
        });
    }

    if (!node) {
        return;
    }

    if (node.nodeType === 1 && typeof node.matches === "function" && node.matches(selector)) {
        elements.push(node);
    }
    if (typeof node.querySelectorAll === "function") {
        elements = elements.concat(Array.prototype.slice.call(node.querySelectorAll(selector)));
    }

    elements.forEach(decodeElementAttributes);
}

function belchertown_decode_meta_labels(root) {
    var node = root && root.jquery ? root[0] : root;
    var selector = "meta[name='description'], meta[property='og:title'], meta[property='og:description'], meta[property='og:site_name']";
    var elements;

    if (!node || typeof node.querySelectorAll !== "function") {
        return;
    }

    elements = Array.prototype.slice.call(node.querySelectorAll(selector));
    elements.forEach(function(element) {
        if (element.hasAttribute("content")) {
            element.setAttribute("content", belchertown_decode_html_entities(element.getAttribute("content")));
        }
    });
