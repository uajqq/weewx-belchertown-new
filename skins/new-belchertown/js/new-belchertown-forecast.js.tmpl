// #if $Extras.has_key("forecast_enabled") and $Extras.forecast_enabled == '1'
var forecast_last_updated_epoch = null;
var forecast_relative_timer = null;
var forecast_refresh_timer = null;
var forecast_refresh_in_progress = false;
var forecast_last_fetch_ms = 0;
var forecast_resume_refresh_min_ms = 60000;
var forecast_refresh_interval_seconds = 3540;
var forecast_current_conditions_refresh_interval_seconds = 3540;
var forecast_resume_events_bound = false;
var forecast_external_observations = {};
var forecast_observation_info_bound = false;
var forecast_station_observation_sources = $station_obs_source_json;
if (typeof moment !== "undefined" && typeof moment.relativeTimeThreshold === "function") {
    moment.relativeTimeThreshold("m", 60);
}
// #if $Extras.has_key("forecast_stale")
forecast_refresh_interval_seconds = "$Extras.forecast_stale";
// #end if
// #if $Extras.has_key("current_conditions_stale")
forecast_current_conditions_refresh_interval_seconds = "$Extras.current_conditions_stale";
// #end if

function forecast_refresh_seconds(value, fallback) {
    const seconds = parseFloat(value);
    return isFinite(seconds) && seconds > 0 ? seconds : fallback;
}

function forecast_refresh_interval_ms() {
    const forecastSeconds = forecast_refresh_seconds(forecast_refresh_interval_seconds, 3540);
    const currentConditionsSeconds = forecast_refresh_seconds(forecast_current_conditions_refresh_interval_seconds, 3540);
    return Math.max(Math.min(forecastSeconds, currentConditionsSeconds), 60) * 1000;
}

function forecast_json_url(filename) {
    return get_relative_url() + "/json/" + filename + "?_=" + Date.now();
}

function ajaxforecast() {
    const nowMs = Date.now();
    forecast_bind_resume_events();
    forecast_start_refresh_timer();

    if (forecast_refresh_in_progress) {
        return jQuery.Deferred().resolve().promise();
    }

    forecast_refresh_in_progress = true;
    forecast_last_fetch_ms = nowMs;
    forecast_data = {};
    current_conditions_data = {};

    const pCurrent = jQuery
        .ajax({
            url: forecast_json_url("current_conditions.json"),
            dataType: "json",
            cache: false,
            headers: {"Cache-Control": "no-cache, no-store"},
        })
        .done(function(current_conditions) {
            current_conditions_data = current_conditions;
        });

    const pForecast = jQuery
        .ajax({
            url: forecast_json_url("forecast.json"),
            dataType: "json",
            cache: false,
            headers: {"Cache-Control": "no-cache, no-store"},
        })
        .done(function(forecast) {
            forecast_data = forecast;
        });

    const promises = [pCurrent, pForecast];

    return jQuery.when.apply(jQuery, promises)
        .then(function() {
            update_current_conditions(current_conditions_data, forecast_data);
            update_forecast_data(forecast_data);
        })
        .fail(function(err) {
            console.error("Forecast fetch failed:", err);
        })
        .always(function() {
            forecast_refresh_in_progress = false;
        });
}

function forecast_start_refresh_timer() {
    if (forecast_refresh_timer !== null) {
        return;
    }
    forecast_refresh_timer = window.setInterval(function() {
        if (!document.hidden) {
            ajaxforecast();
        }
    }, forecast_refresh_interval_ms());
}

function forecast_refresh_after_resume() {
    if (document.hidden) {
        return;
    }
    forecast_render_relative_timestamps();
    if (forecast_last_fetch_ms && (Date.now() - forecast_last_fetch_ms) < forecast_resume_refresh_min_ms) {
        return;
    }
    ajaxforecast();
}

function forecast_bind_resume_events() {
    if (forecast_resume_events_bound) {
        return;
    }
    forecast_resume_events_bound = true;

    document.addEventListener("visibilitychange", forecast_refresh_after_resume);
    window.addEventListener("focus", forecast_refresh_after_resume);
    window.addEventListener("pageshow", forecast_refresh_after_resume);
    window.addEventListener("online", forecast_refresh_after_resume);
}

function forecast_trim_sentence_end(value) {
    return belchertown_decode_html_entities(value).trim().replace(/[\.\s]+$/, "");
}

function forecast_label_text(value) {
    return belchertown_decode_html_entities(value).trim().replace(/\s+([.,;:!?])/g, "$1");
}

function forecast_sentence_text(parts) {
    const text = parts
        .map(forecast_trim_sentence_end)
        .filter(function(part) { return part !== ""; })
        .join(" ");
    return text ? text + "." : "";
}

function forecast_timestamp_label(value) {
    return forecast_trim_sentence_end(value).replace(/\s+(on|at)$/i, "");
}

function forecast_relative_time_locale_name() {
    let localeName;
    if (typeof window !== "undefined" && window.moment_locale) {
        localeName = window.moment_locale;
    } else if (typeof moment !== "undefined" && typeof moment.locale === "function") {
        localeName = moment.locale();
    }
    return localeName ? String(localeName).replace(/_/g, "-") : undefined;
}

function forecast_join_relative_time_parts(parts) {
    if (parts.length <= 1) {
        return parts[0] || "";
    }

    if (typeof Intl !== "undefined" && typeof Intl.ListFormat === "function") {
        try {
            return new Intl.ListFormat(forecast_relative_time_locale_name(), {
                style: "long",
                type: "conjunction",
            }).format(parts);
        } catch (e) {
            // Fall through to the plain join if the browser rejects the locale.
        }
    }

    return parts.join(" ");
}

function forecast_relative_time_unit(localeData, value, singularKey, pluralKey, isFuture) {
    const key = value === 1 ? singularKey : pluralKey;
    return localeData.relativeTime(value, true, key, isFuture);
}

function forecast_relative_time_hour_threshold() {
    if (typeof moment !== "undefined" && typeof moment.relativeTimeThreshold === "function") {
        const threshold = moment.relativeTimeThreshold("h");
        if (isFinite(threshold) && threshold > 0) {
            return threshold;
        }
    }
    return 22;
}

function forecast_compound_relative_time(targetMoment, nowMoment) {
    const diffMs = targetMoment.diff(nowMoment);
    const absSeconds = Math.floor(Math.abs(diffMs) / 1000);
    const totalMinutes = Math.floor(absSeconds / 60);
    const hours = Math.floor(totalMinutes / 60);
    const minutes = totalMinutes % 60;
    const hourThreshold = forecast_relative_time_hour_threshold();

    if (hours < 1 || minutes === 0 || hours >= hourThreshold) {
        return targetMoment.from(nowMoment);
    }

    const localeData = targetMoment.localeData();
    if (
        !localeData ||
        typeof localeData.relativeTime !== "function" ||
        typeof localeData.pastFuture !== "function"
    ) {
        return targetMoment.from(nowMoment);
    }

    const isFuture = diffMs > 0;
    const parts = [
        forecast_relative_time_unit(localeData, hours, "h", "hh", isFuture),
        forecast_relative_time_unit(localeData, minutes, "m", "mm", isFuture),
    ];
    return localeData.pastFuture(diffMs, forecast_join_relative_time_parts(parts));
}

function forecast_relative_time(epoch) {
    const timestamp = forecast_number(epoch);
    if (timestamp === null) {
        return "";
    }

    return forecast_compound_relative_time(tzAdjustedMoment(timestamp), tzAdjustedMoment(Date.now() / 1000));
}

function forecast_absolute_time(epoch, formatString) {
    const timestamp = forecast_number(epoch);
    return timestamp === null ? "" : tzAdjustedMoment(timestamp).format(belchertown_label_text(formatString));
}

function forecast_escape_html(value) {
    return belchertown_escape_html(value);
}

function forecast_template_text(template, replacements) {
    template = belchertown_decode_html_entities(template);
    var index = 0;
    return String(template || "").replace(/%s/g, function() {
        var value = replacements[index++];
        return belchertown_decode_html_entities(value);
    });
}

function forecast_template_html(template, replacements) {
    template = belchertown_decode_html_entities(template);
    replacements = replacements || [];

    var index = 0;
    return String(template || "").split("%s").map(function(part) {
        var html = forecast_escape_html(part);
        if (index < replacements.length) {
            html += replacements[index++];
        }
        return html;
    }).join("");
}

function forecast_provider_label(provider) {
    const providerKey = String(provider || "");
    if (providerKey === "nws") return "NWS";
    if (providerKey === "open-meteo") return "Open-Meteo";
    if (providerKey === "pirateweather") return "Pirate Weather";
    if (providerKey === "xweather") return "Xweather";
    if (providerKey === "aeris") return "Aeris/Xweather";
    return provider ? String(provider) : forecast_label_text("$obs.label.forecast_data");
}

function forecast_payload_source(data, fallbackProvider) {
    data = data || {};
    return forecast_provider_label(data["provider"] || fallbackProvider || "$Extras.forecast_provider");
}

function forecast_render_source(data) {
    const source = forecast_payload_source(data, "");
    jQuery(".forecast-source")
        .text(forecast_sentence_text([forecast_label_text("$obs.label.source") + ": " + source]))
        .attr("title", forecast_label_text("$obs.label.forecast_source") + ": " + source);
}

function forecast_current_observation_epoch(data) {
    const cc = data && data["current"] && data["current"][0] ? data["current"][0] : {};
    return forecast_number(cc["time"] || data["timestamp"] || data["generated_at"]);
}

function forecast_observation_label(row, fallback) {
    const labelCell = row.find(".station-observations-label").first().clone();
    labelCell.find(".observation-source-info").remove();
    return jQuery.trim(labelCell.text()) || fallback;
}

function forecast_observation_age_sentence(epoch) {
    const timestamp = forecast_number(epoch);
    if (timestamp === null) {
        return forecast_label_text("$obs.label.observation_time_unavailable");
    }

    return forecast_template_text("$obs.label.observation_time_reported", [forecast_relative_time(timestamp)]);
}

function forecast_ensure_observation_modal() {
    if (jQuery("#observation-source-modal").length) {
        return;
    }

    var modal = "";
    modal += "<div class='modal fade observation-source-modal' id='observation-source-modal' tabindex='-1' role='dialog' aria-labelledby='observation-source-modal-title'>";
    modal += "<div class='modal-dialog modal-sm' role='document'>";
    modal += "<div class='modal-content'>";
    modal += "<div class='modal-header'>";
    modal += "<button type='button' class='close' data-dismiss='modal' aria-label='" + forecast_escape_html(forecast_label_text("$obs.label.close")) + "'><span aria-hidden='true'>&times;</span></button>";
    modal += "<h4 class='modal-title' id='observation-source-modal-title'>" + forecast_escape_html(forecast_label_text("$obs.label.observation_source")) + "</h4>";
    modal += "</div>";
    modal += "<div class='modal-body observation-source-modal-body'></div>";
    modal += "<div class='modal-footer'>";
    modal += "<button type='button' class='btn btn-primary' data-dismiss='modal'>" + forecast_escape_html(forecast_label_text("$obs.label.close")) + "</button>";
    modal += "</div>";
    modal += "</div>";
    modal += "</div>";
    modal += "</div>";
    jQuery("body").append(modal);
}

function forecast_render_observation_modal(observationKey) {
    const info = forecast_external_observations[observationKey];
    if (!info) {
        return;
    }

    const label = forecast_escape_html(info["label"]);
    const source = forecast_escape_html(info["source"]);
    const observedAt = forecast_absolute_time(info["epoch"], '$obs.label.time_current_conditions_last_updated');
    let body = "<p>" + forecast_template_html("$obs.label.observation_source_provider", ["<strong>" + label + "</strong>", source]) + "</p>";
    body += "<p>" + forecast_escape_html(forecast_observation_age_sentence(info["epoch"])) + "</p>";
    if (observedAt) {
        body += "<p class='observation-source-modal-time'>" + forecast_escape_html(observedAt) + "</p>";
    }

    jQuery("#observation-source-modal")
        .data("observation", observationKey)
        .find(".observation-source-modal-body")
        .html(body);
}

function forecast_bind_observation_info() {
    if (forecast_observation_info_bound) {
        return;
    }

    forecast_observation_info_bound = true;
    jQuery(document).on("click", ".observation-source-info", function(event) {
        event.preventDefault();
        forecast_ensure_observation_modal();
        forecast_render_observation_modal(jQuery(this).data("observation"));
        jQuery("#observation-source-modal").modal("show");
    });
}

function forecast_register_external_observation(observationKey, data, options) {
    options = options || {};
    let row = jQuery(".station-observations tr").filter(function() {
        return jQuery(this).data("observation") === observationKey;
    }).first();
    if (!row.length) {
        row = jQuery(".station-observations ." + observationKey).closest("tr");
    }
    if (!row.length) {
        return;
    }

    const label = forecast_observation_label(row, observationKey);
    const metadata = options["metadata"] || {};
    const sourceProvider = options["sourceProvider"] || metadata["provider"];
    const source = forecast_payload_source(data, sourceProvider);
    let observationEpoch = forecast_number(options["epoch"] || metadata["epoch"]);
    if (observationEpoch === null) {
        observationEpoch = forecast_current_observation_epoch(data);
    }

    forecast_external_observations[observationKey] = {
        label: label,
        source: source,
        epoch: observationEpoch
    };

    row.addClass("station-observation-row station-observation-row--external");

    let button = row.find(".observation-source-info").first();
    if (!button.length) {
        button = jQuery("<button type='button' class='observation-source-info'><i class='fa fa-info' aria-hidden='true'></i></button>");
        row.find(".station-observations-label").first().append(button);
    }

    button
        .data("observation", observationKey)
        .attr("aria-label", forecast_template_text("$obs.label.observation_source_information", [label]))
        .attr("title", forecast_template_text("$obs.label.observation_source_information", [label]));

    forecast_bind_observation_info();
}

function forecast_register_external_observations(sourceKey, data, options) {
    const observationSources = forecast_station_observation_sources || {};
    jQuery.each(observationSources, function(observationKey, metadata) {
        metadata = metadata || {};
        if (metadata["source_key"] !== sourceKey) {
            return;
        }
        forecast_register_external_observation(observationKey, data, {
            metadata: metadata,
            sourceProvider: options && options["sourceProvider"],
            epoch: options && options["epoch"]
        });
    });
}

function forecast_render_relative_timestamps() {
    if (forecast_last_updated_epoch !== null) {
        const forecastLabel = forecast_timestamp_label("$obs.label.forecast_last_updated");
        jQuery(".forecast-subtitle")
            .text(forecast_sentence_text([forecastLabel, forecast_relative_time(forecast_last_updated_epoch)]))
            .attr("title", forecast_absolute_time(forecast_last_updated_epoch, '$obs.label.time_forecast_last_updated'));
    }

    const activeObservation = jQuery("#observation-source-modal").data("observation");
    if (activeObservation) {
        forecast_render_observation_modal(activeObservation);
    }

    if (typeof forecast_sync_row_height === "function") {
        forecast_sync_row_height();
    }
}

function forecast_start_relative_timer() {
    if (forecast_relative_timer !== null) {
        return;
    }
    forecast_relative_timer = window.setInterval(forecast_render_relative_timestamps, 30000);
}

function forecast_compact_alert_title(title) {
    if (title == null) {
        return forecast_label_text("$obs.label.alert");
    }

    var compactTitle = String(title).replace(/\s+/g, " ").trim();
    if (!compactTitle) {
        return forecast_label_text("$obs.label.alert");
    }

    var lowerTitle = compactTitle.toLowerCase();
    var markers = [
        " issued ",
        " updated ",
        " extended ",
        " continued ",
        " continues ",
        " remains in effect ",
        " in effect until ",
        " until ",
        " from ",
        " cancelled ",
        " canceled ",
    ];
    for (var markerIndex = 0; markerIndex < markers.length; markerIndex++) {
        var titleCutoff = lowerTitle.indexOf(markers[markerIndex]);
        if (titleCutoff > 0) {
            compactTitle = compactTitle.slice(0, titleCutoff).replace(/[ :\-]+$/, "");
            break;
        }
    }

    return compactTitle || forecast_label_text("$obs.label.alert");
}

function forecast_format_alert_time(timestamp) {
    if (timestamp == null || timestamp === "") {
        return "";
    }

    return tzAdjustedMoment(timestamp).format(belchertown_label_text('$obs.label.time_forecast_alert_expires'));
}

function forecast_format_alert_start_time(timestamp) {
    if (timestamp == null || timestamp === "") {
        return "";
    }

    return forecast_relative_time(timestamp);
}

function forecast_alert_in_effect_text(alertObj) {
    var startTimestamp = alertObj['effective'] || alertObj['onset'];
    var endTimestamp = alertObj['ends'];
    var startEpoch = forecast_number(startTimestamp);
    var startIsPast = startEpoch !== null && startEpoch <= (Date.now() / 1000);
    var startText = forecast_format_alert_start_time(startTimestamp);
    var endText = forecast_format_alert_time(endTimestamp);

    if (startText && endText) {
        if (startIsPast) {
            return forecast_label_text("$obs.label.alert_in_effect_now") + " " + forecast_label_text("$obs.label.alert_until") + " " + endText;
        }
        return forecast_label_text("$obs.label.alert_in_effect_starting") + " " + startText + " " + forecast_label_text("$obs.label.alert_until") + " " + endText;
    }
    if (startText) {
        if (startIsPast) {
            return forecast_label_text("$obs.label.alert_in_effect_now");
        }
        return forecast_label_text("$obs.label.alert_in_effect_starting") + " " + startText;
    }
    if (endText) {
        return forecast_label_text("$obs.label.alert_in_effect") + " " + endText;
    }

    return "";
}

function forecast_active_alert_modal() {
    return jQuery(".modal.in[id^='forecast-alert-'], .modal.show[id^='forecast-alert-']").first();
}

function forecast_alert_modal_by_id(id) {
    return id ? jQuery(document.getElementById(id)) : jQuery();
}

function forecast_alert_modal_html(forecastAlertId, forecastAlertTitleId, alertData) {
    var modal = "";
    modal += "<!-- Forecast Alert Modal -->";
    modal += "<div class='modal fade forecast-alert-modal' id='" + forecastAlertId + "' tabindex='-1' role='dialog' aria-labelledby='" + forecastAlertTitleId + "'>";
    modal += "<div class='modal-dialog' role='document'>";
    modal += "<div class='modal-content'>";
    modal += "<div class='modal-header'>";
    modal += "<button type='button' class='close' data-dismiss='modal' aria-label='" + forecast_escape_html(forecast_label_text("$obs.label.close")) + "'><span aria-hidden='true'>&times;</span></button>";
    modal += "<h4 class='modal-title' id='" + forecastAlertTitleId + "'>" + forecast_escape_html(alertData["title"]) + "</h4>";
    modal += "</div>";
    modal += "<div class='modal-body'>";
    modal += alertData["body"];
    modal += "</div>";
    modal += "<div class='modal-footer'>";
    modal += "<button type='button' class='btn btn-primary' data-dismiss='modal'>" + forecast_escape_html(forecast_label_text("$obs.label.close")) + "</button>";
    modal += "</div>";
    modal += "</div>";
    modal += "</div>";
    modal += "</div>";
    return modal;
}

function forecast_update_alert_modal(modal, forecastAlertTitleId, alertData) {
    modal
        .addClass("forecast-alert-modal")
        .attr("aria-labelledby", forecastAlertTitleId);
    modal.find(".modal-title")
        .attr("id", forecastAlertTitleId)
        .html(forecast_escape_html(alertData["title"]));
    modal.find(".modal-body").html(alertData["body"]);
}

function forecast_remove_stale_alert_modals(currentAlertIds, activeAlertId) {
    jQuery(".forecast-alert-modal, .modal[id^='forecast-alert-']").each(function() {
        var modal = jQuery(this);
        var modalId = modal.attr("id");

        if (currentAlertIds[modalId]) {
            return;
        }

        if (modalId === activeAlertId) {
            modal.one("hidden.bs.modal", function() {
                jQuery(this).remove();
            });
            return;
        }

        modal.remove();
    });
}

function show_forcast_alert(data) {
    belchertown_debug("Forecast: Updating alert data");
    var i, forecast_alerts, forecast_alert_title, forecast_alert_body;
    var forecast_alert_link, forecast_alert_expires, forecast_alert_in_effect, alert_link;
    var activeAlertModal = forecast_active_alert_modal();
    var activeAlertId = activeAlertModal.attr("id") || "";
    var currentAlertIds = {};
    var alertContainer = jQuery(".wx-stn-alert-text");
    forecast_alerts = [];

    if (activeAlertModal.length && activeAlertModal.closest(".wx-stn-alert-text").length) {
        activeAlertModal.detach().appendTo("body");
    }

    // Empty the alert links from the previous run without removing any active modal node.
    alertContainer.empty();

    if (Array.isArray(data['alerts'])) {
        for (i = 0; i < data['alerts'].length; i++) {
            const alertObj = data['alerts'][i] || {};
            const alertDescription = (alertObj['description'] == null)
                ? ""
                : String(alertObj['description']);
            forecast_alert_title = (alertObj['title'] == null)
                ? forecast_label_text("$obs.label.alert")
                : forecast_compact_alert_title(alertObj['title']);
            forecast_alert_body = forecast_escape_html(alertDescription).replace(/\n/g, '<br>');
            forecast_alert_link = forecast_alert_title;
            forecast_alert_expires = forecast_format_alert_time(alertObj['expires']);
            forecast_alert_in_effect = forecast_alert_in_effect_text(alertObj);
            forecast_alerts.push({
                "title": forecast_alert_title,
                "body": forecast_alert_body,
                "link": forecast_alert_link,
                "expires": forecast_alert_expires,
                "in_effect": forecast_alert_in_effect
            });
        }
    }

    if (forecast_alerts.length > 0) {
        belchertown_debug("Forecast: There are " + forecast_alerts.length + " alert(s).");
        for (i = 0; i < forecast_alerts.length; i++) {

            var forecastAlertId = "forecast-alert-" + i;
            var forecastAlertTitleId = forecastAlertId + "-title";
            var alertLinkText = forecast_alerts[i]["title"];
            if (forecast_alerts[i]["in_effect"]) {
                alertLinkText += " " + forecast_alerts[i]["in_effect"];
            }

            currentAlertIds[forecastAlertId] = true;
            alert_link = "<i class='fa fa-exclamation-triangle' aria-hidden='true'></i> <a href='#" + forecastAlertId + "' data-toggle='modal' data-target='#" + forecastAlertId + "'>" + forecast_escape_html(alertLinkText) + "</a><br>";
            alertContainer.append(alert_link);

            var forecast_alert_modal = forecast_alert_modal_by_id(forecastAlertId);
            if (forecast_alert_modal.length) {
                forecast_update_alert_modal(forecast_alert_modal, forecastAlertTitleId, forecast_alerts[i]);
            } else {
                jQuery("body").append(forecast_alert_modal_html(forecastAlertId, forecastAlertTitleId, forecast_alerts[i]));
            }
        }
        jQuery(".wx-stn-alert").show();
    } else {
        belchertown_debug("Forecast: There are no forecast alerts");
        jQuery(".wx-stn-alert").hide();
    }

    forecast_remove_stale_alert_modals(currentAlertIds, activeAlertId);
}

function forecast_aqi_translate(data) {
    if (data === "good") data = "$obs.label.aqi_good";
    else if (data === "moderate") data = "$obs.label.aqi_moderate";
    else if (data === "usg") data = "$obs.label.aqi_usg";
    else if (data === "unhealthy") data = "$obs.label.aqi_unhealthy";
    else if (data === "very unhealthy") data = "$obs.label.aqi_very_unhealthy";
    else if (data === "hazardous") data = "$obs.label.aqi_hazardous";
    else data = "$obs.label.aqi_unknown";

    return forecast_label_text(data);
}

function forecast_current_fallback_period(forecastData) {
    const sections = ["hourly", "threeHourly", "daily"];

    for (let s = 0; s < sections.length; s++) {
        const rows = (forecastData || {})[sections[s]] || [];
        if (rows.length && rows[0]) {
            return rows[0];
        }
    }

    return {};
}

function update_current_conditions(data, forecastData) {
    forecast_provider = "$Extras.forecast_provider";
    belchertown_debug("Current Conditions: Provider is " + forecast_provider);
    belchertown_debug("Current Conditions: Updating data");
    belchertown_debug(data);

    if (!data["current"] || !data["current"][0]) {
        belchertown_debug("Current Conditions: Missing normalized current data");
        return false;
    }

    try {
        const cc = data["current"][0];
        const fallbackPeriod = forecast_current_fallback_period(forecastData);
        const sourceProvider = data["provider"] || forecast_provider;
        let w34icon = resolveIconForProvider(cc["icon"] || "", sourceProvider);
        if (w34icon === "unknown" && cc["summary"]) {
            w34icon = resolveIconForProvider(cc["summary"], sourceProvider);
        }
        if (w34icon === "unknown" && fallbackPeriod["icon"]) {
            w34icon = resolveIconForProvider(fallbackPeriod["icon"], sourceProvider);
        }
        if (w34icon === "unknown" && fallbackPeriod["summary"]) {
            w34icon = resolveIconForProvider(fallbackPeriod["summary"], sourceProvider);
        }
        const wxicon = get_relative_url() + "/images/" + w34icon + ".png";
        jQuery("#wxicon").attr("src", wxicon);

        try {
            jQuery(".current-obs-text").html(cc["summary"] || fallbackPeriod["summary"] || "");
        } catch (err) { /* silent */}

        try {
            jQuery(".station-observations .visibility").html(forecast_visibility_text(cc["visibility"], cc["visibilityQualifier"]));
        } catch (err) { /* silent */}

        forecast_register_external_observations("current_conditions", data);

    } catch (error) {
        belchertown_debug("Current Conditions: Normalized render failed: " + error);
    }
    return true;
}

function forecast_number(value) {
    const numberValue = parseFloat(value);
    return isFinite(numberValue) ? numberValue : null;
}

function forecast_temp_text(value) {
    const numberValue = forecast_number(value);
    return numberValue !== null ? numberValue.toFixed(0) + '&deg;' : 'N/A';
}

function forecast_plain_number_text(value) {
    const numberValue = forecast_number(value);
    return numberValue !== null ? numberValue.toFixed(0) : 'N/A';
}

function forecast_percent_text(value, fallback) {
    const numberValue = forecast_number(value);
    if (numberValue === null) return fallback || null;
    const percentValue = Math.abs(numberValue) <= 1 ? numberValue * 100 : numberValue;
    return percentValue.toFixed(0) + '%';
}

function forecast_visibility_unit_label() {
    if (
        unit_label_array &&
        typeof unit_label_array === "object" &&
        unit_label_array.hasOwnProperty("visibility") &&
        unit_label_array["visibility"] != null
    ) {
        return String(unit_label_array["visibility"]);
    }

    const forecastUnits = "$Extras.forecast_units";
    return (forecastUnits === "si" || forecastUnits === "ca") ? "km" : "miles";
}

function forecast_visibility_text(value, qualifier) {
    const numberValue = forecast_number(value);
    if (numberValue === null) return "N/A";

    const rounding = (
        unit_rounding_array &&
        typeof unit_rounding_array === "object" &&
        unit_rounding_array.hasOwnProperty("visibility")
    ) ? unit_rounding_array["visibility"] : 2;
    const unitLabel = forecast_visibility_unit_label();
    const visibilityQualifier = (qualifier === "<" || qualifier === ">") ? qualifier : "";

    return visibilityQualifier + numberValue.toLocaleString(
        "$system_locale_js",
        {
            minimumFractionDigits: rounding,
            maximumFractionDigits: rounding
        }
    ) + (unitLabel ? " " + unitLabel : "");
}

function forecast_icon_url(iconValue) {
    const iconBase = resolveIconForProvider(iconValue || "unknown", "pirateweather");
    return get_relative_url() + "/images/" + iconBase + ".png";
}

function forecast_daily_link(timestamp) {
    var showDailyLink = "0";
    // #if $Extras.has_key("forecast_show_daily_forecast_link")
    showDailyLink = "$Extras.forecast_show_daily_forecast_link";
    // #end if
    if (showDailyLink != "1") return "";

    const linkMoment = tzAdjustedMoment(timestamp || (Date.now() / 1000));
    const link = "$Extras.forecast_daily_forecast_link"
        .replace("YYYY", linkMoment.format("YYYY"))
        .replace("MM", linkMoment.format("MM"))
        .replace("DD", linkMoment.format("DD"));
    return '<a href="' + link + '" target="_blank">' + forecast_escape_html(forecast_label_text("$obs.label.daily_forecast")) + '</a>';
}

function forecast_metric_rows(row) {
    var humidityMode = "0";
    // #if $Extras.has_key("forecast_show_humidity_dewpoint")
    humidityMode = "$Extras.forecast_show_humidity_dewpoint";
    // #end if

    let html = "";
    if (humidityMode == "1") {
        const humidityText = forecast_percent_text(row["humidity"]);
        if (humidityText !== null) {
            html += '<div><i class="wi wi-humidity rain-precip"></i> <span>' + humidityText + '</span></div>';
        }
    } else if (humidityMode == "2") {
        const dewPointText = forecast_temp_text(row["dewPoint"]);
        if (dewPointText != 'N/A') {
            html += '<div><i class="wi wi-raindrops rain-precip"></i> <span>' + dewPointText + '</span></div>';
        }
    }

    const snowDepth = forecast_number(row["snowDepth"]);
    if (snowDepth !== null && snowDepth > 0) {
        const snowUnit = row["snowUnit"] || "";
        html += '<div class="snow-precip">';
        html += '<img src="' + get_relative_url() + '/images/snowflake-icon-15px.png" alt="" width="15" height="15" loading="lazy" decoding="async"> <span>' + snowDepth.toFixed(0) + '<span> ' + snowUnit;
        html += '</div>';
    } else {
        const precipText = forecast_percent_text(row["precipProbability"], '0%');
        const rainClass = precipText == '0%' ? 'rain-no-precip' : 'rain-precip';
        html += '<div><i class="wi wi-raindrop wi-rotate-45 ' + rainClass + '"></i> <span>' + precipText + '</span></div>';
    }

    return html;
}

function forecast_wind_html(row, includeGust) {
    const windSpeedText = forecast_plain_number_text(row["windSpeed"]);
    let html = '<div class="forecast-wind">';
    html += '<i class="wi wi-strong-wind"></i> <span class="forecast-wind-speed">' + windSpeedText + '</span>';
    if (includeGust) {
        html += '<span class="forecast-wind-separator">|</span><span class="forecast-wind-gust">' + forecast_plain_number_text(row["windGust"]) + belchertown_label_html("$unit.label.windSpeed") + '</span>';
    }
    html += '</div>';
    return html;
}

function forecast_is_three_hour_boundary(epoch) {
    const hour = parseInt(tzAdjustedMoment(epoch).format("H"), 10);
    return isFinite(hour) && hour % 3 === 0;
}

function forecast_current_period_slice(rows, periodHours, requireThreeHourBoundary) {
    if (!Array.isArray(rows) || rows.length === 0) return [];

    const nowEpoch = Date.now() / 1000;
    const periodNumber = parseFloat(periodHours);
    const periodSeconds = (isFinite(periodNumber) && periodNumber > 0 ? periodNumber : 1) * 3600;
    let firstFuture = -1;
    let foundTimestamp = false;
    let foundBoundaryTimestamp = !requireThreeHourBoundary;

    for (let i = 0; i < rows.length; i++) {
        const rowEpoch = forecast_number(rows[i] && rows[i]["time"]);
        if (rowEpoch === null) continue;

        foundTimestamp = true;
        if (requireThreeHourBoundary) {
            if (!forecast_is_three_hour_boundary(rowEpoch)) continue;
            foundBoundaryTimestamp = true;
        }

        if (rowEpoch <= nowEpoch && nowEpoch < rowEpoch + periodSeconds) {
            return rows.slice(i);
        }
        if (rowEpoch >= nowEpoch && firstFuture === -1) {
            firstFuture = i;
        }
    }

    if (firstFuture !== -1) {
        return rows.slice(firstFuture);
    }

    if (!foundBoundaryTimestamp) {
        return forecast_current_period_slice(rows, periodHours, false);
    }

    return foundTimestamp ? [] : rows.slice(0);
}

function forecast_pick_three_hourly_from_current_period(hourlyArray) {
    const rows = forecast_current_period_slice(hourlyArray, 3, true);
    const output = [];
    for (let i = 0; i < rows.length; i += 3) {
        output.push(rows[i]);
    }
    return output;
}

function forecast_render_hourly_tiles(hourlySource, maxTiles, tileClass) {
    let html = "";
    const forecastInterval = (tileClass === "forecast-3hour") ? "forecast_3hr" : "forecast_1hr";
    const periodHours = forecastInterval === "forecast_3hr" ? 3 : 1;
    const displayRows = forecast_current_period_slice(hourlySource, periodHours, forecastInterval === "forecast_3hr");
    const tileCount = Math.min(maxTiles, displayRows.length);
    let lowTemp = null;
    let highTemp = null;

    if (forecastInterval === "forecast_1hr") {
        for (let rangeIndex = 0; rangeIndex < tileCount; rangeIndex++) {
            const rangeTempNum = forecast_number(displayRows[rangeIndex]["temperature"]);
            if (rangeTempNum !== null) {
                if (lowTemp === null || lowTemp > rangeTempNum) lowTemp = rangeTempNum;
                if (highTemp === null || highTemp < rangeTempNum) highTemp = rangeTempNum;
            }
        }
    }

    let rangeTemp = 2;
    let offset = 0;
    if (forecastInterval === "forecast_1hr" && lowTemp !== null && highTemp !== null) {
        rangeTemp = highTemp - lowTemp;
        if (rangeTemp < 2) {
            if (rangeTemp == 0) offset = 1;
            else if (rangeTemp == 1) offset = 0.67;
            rangeTemp = 2;
        }
    }

    for (let i = 0; i < tileCount; i++) {
        const row = displayRows[i] || {};
        const rowMoment = tzAdjustedMoment(row["time"]);
        const rawLabel = rowMoment.format(belchertown_label_text("$obs.label.time_forecast_time"));
        const previousTime = i === 0 ? Date.now() / 1000 : (displayRows[i - 1] || {})["time"];
        const showDay = !rowMoment.isSame(tzAdjustedMoment(previousTime), "day");
        const timeLabel = forecast_time(i, forecastInterval, rawLabel, showDay);
        const tempNum = forecast_number(row["temperature"]);
        const imageUrl = forecast_icon_url(row["icon"]);

        html += '<div class="forecast-day ' + tileClass + ' forecast-tile ' + (i === 0 ? 'forecast-today' : 'border-left') + '">';
        html += '<div class="forecast-card-label"><span id="weekday">' + timeLabel + '</span></div>';

        if (forecastInterval === "forecast_1hr") {
            const tempChartPadding = (tempNum !== null && highTemp !== null)
                ? parseInt((highTemp - tempNum + offset) * 76 / rangeTemp)
                : 0;
            html += '<div class="forecast-conditions forecast-conditions-1hour">';
            html += '<div class="forecast-temp-chart forecast-temp-chart-1hour">';
            html += '<div class="forecast-temp-chart-marker" style="top:' + tempChartPadding + 'px">';
            html += '<div class="forecast-image">';
            html += '<img class="forecast-icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async">';
            html += '</div>';
            html += '<span class="forecast-chart-temp">' + forecast_temp_text(row["temperature"]) + '</span>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
        } else {
            html += '<div class="forecast-conditions">';
            html += '<img class="forecast-icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async"><br>';
            html += '<span class="forecast-condition-text">' + (row["summary"] || "") + '</span>';
            html += '</div>';
        }

        html += '<div class="forecast-card-bottom">';
        if (forecastInterval !== "forecast_1hr") {
            html += '<span class="forecast-high">' + forecast_temp_text(row["temperature"]) + '</span>';
            html += '<br>';
        }
        html += '<div class="forecast-precip">' + forecast_metric_rows(row) + '</div>';
        html += forecast_wind_html(row, forecastInterval !== "forecast_1hr");
        html += forecast_daily_link(row["time"]);
        html += '</div>';
        html += '</div>';
    }

    return html;
}

function forecast_render_daily_tiles(dailySource, maxTiles) {
    let html = "";
    const tileCount = Math.min(maxTiles, dailySource.length);

    for (let i = 0; i < tileCount; i++) {
        const row = dailySource[i] || {};
        const dayLabel = tzAdjustedMoment((row["time"] || 0) + 7200).format(belchertown_forecast_date_format("$obs.label.time_forecast_date"));
        const imageUrl = forecast_icon_url(row["icon"]);

        html += '<div class="forecast-day forecast-24hour forecast-tile ' + (i === 0 ? 'forecast-today' : 'border-left') + '">';
        html += '<div class="forecast-card-label"><span id="weekday">' + dayLabel + '</span></div>';
        html += '<div class="forecast-conditions">';
        html += '<img class="forecast-icon" src="' + imageUrl + '" alt="" width="128" height="101" loading="lazy" decoding="async">';
        html += '<br>';
        html += '<span class="forecast-condition-text">' + (row["summary"] || "") + '</span>';
        html += '</div>';
        html += '<div class="forecast-card-bottom">';
        html += '<span class="forecast-temp-range"><span class="forecast-high">' + forecast_temp_text(row["temperatureHigh"]) + '</span> | <span class="forecast-low">' + forecast_temp_text(row["temperatureLow"]) + '</span></span>';
        html += '<br>';
        html += '<div class="forecast-precip">' + forecast_metric_rows(row) + '</div>';
        html += forecast_wind_html(row, true);
        html += forecast_daily_link(row["time"]);
        html += '</div>';
        html += '</div>';
    }

    return html;
}

function forecast_fit_daily_condition_text() {
    const minFontSize = 11;

    jQuery(".day_forecasts .forecast-day.forecast-tile").each(function() {
        const tile = this;
        const conditions = tile.querySelector(".forecast-conditions");
        const text = tile.querySelector(".forecast-condition-text");
        if (!conditions || !text || conditions.offsetParent === null) {
            return;
        }

        tile.style.removeProperty("--forecast-condition-band-height");
        text.style.removeProperty("font-size");
        text.style.removeProperty("line-height");

        let fontSize = parseFloat(window.getComputedStyle(text).fontSize) || 14;
        while (fontSize > minFontSize && conditions.scrollHeight > conditions.clientHeight + 1) {
            fontSize -= 1;
            text.style.fontSize = fontSize + "px";
            text.style.lineHeight = "1.08";
        }

        if (conditions.scrollHeight > conditions.clientHeight + 1) {
            tile.style.setProperty("--forecast-condition-band-height", Math.ceil(conditions.scrollHeight) + "px");
        }
    });
}

function forecast_update_aqi(data) {
    try {
        const aqiPayload = data["aqi"] && data["aqi"][0] ? data["aqi"][0] : null;
        if (data["aqi"] && data["aqi"][0] && data["aqi"][0]["success"] && !data["aqi"][0]["error"]) {
            const aqiPeriod = data["aqi"][0]["response"][0]["periods"][0];
            const aqiValue = aqiPeriod["aqi"];
            const aqiCategory = forecast_aqi_translate(aqiPeriod["category"]);
            jQuery(".wx-aqi").text(aqiValue);
            jQuery(".wx-aqi-category").text(aqiCategory);
            get_aqi_color(aqiValue);
            if ("$Extras.aqi_location_enabled" === "1") {
                const aqiPlace = data["aqi"][0]["response"][0]["place"]["name"] || "";
                jQuery(".aqi_location_outer").html(aqiPlace ? "<br>" + aqiPlace : "").css('textTransform', 'capitalize');
            }
            try {
                jQuery(".station-observations .aqi").text(aqiValue + " (" + aqiCategory + ")");
            } catch (err) {
                // AQI not in the station observation table, so silently exit
            }
            forecast_register_external_observations("aqi", data, {
                sourceProvider: aqiPayload["provider"],
                epoch: aqiPeriod["timestamp"] || data["generated_at"] || data["timestamp"]
            });
        } else if (data["aqi"] && data["aqi"][0] && data["aqi"][0]["success"] && data["aqi"][0]["error"] && data["aqi"][0]["error"]["code"] === "warn_no_data") {
            const aqiNoDataCategory = forecast_aqi_translate("");
            jQuery(".wx-aqi").text(forecast_label_text("$obs.label.no_data"));
            jQuery(".wx-aqi-category").text(aqiNoDataCategory);
            clear_aqi_color();
            if ("$Extras.aqi_location_enabled" === "1") jQuery(".aqi_location_outer").html("");
            try {
                jQuery(".station-observations .aqi").text(forecast_label_text("$obs.label.no_data") + " (" + aqiNoDataCategory + ")");
            } catch (err) {
                // AQI not in the station observation table, so silently exit
            }
            forecast_register_external_observations("aqi", data, {
                sourceProvider: aqiPayload["provider"],
                epoch: data["generated_at"] || data["timestamp"]
            });
        }
    } catch (err) {
        belchertown_debug("Forecast: AQI data missing or malformed, skipping: " + err);
    }
}

function forecast_has_common_schema(data) {
    return data && Array.isArray(data["hourly"]) && Array.isArray(data["daily"]);
}

function forecast_render_common(data) {
    forecast_update_aqi(data);

    const hourly = Array.isArray(data["hourly"]) ? data["hourly"] : [];
    const threeHourly = Array.isArray(data["threeHourly"]) ? data["threeHourly"] : forecast_pick_three_hourly_from_current_period(hourly);
    const daily = Array.isArray(data["daily"]) ? data["daily"] : [];
    const lastUpdated = data["generated_at"] || data["timestamp"] || (Date.now() / 1000);
    forecast_last_updated_epoch = forecast_number(lastUpdated);

    forecast_render_source(data);
    forecast_register_external_observations("forecast", data, {epoch: lastUpdated});
    jQuery(".onehr_forecasts").html(forecast_render_hourly_tiles(hourly, 16, "forecast-1hour"));
    jQuery(".threehr_forecasts").html(forecast_render_hourly_tiles(threeHourly, 8, "forecast-3hour"));
    jQuery(".day_forecasts").html(forecast_render_daily_tiles(daily, 7));
    forecast_render_relative_timestamps();
    forecast_start_relative_timer();
    if (typeof forecast_sync_row_height === "function") {
        forecast_sync_row_height();
    }
    show_forcast_alert(data);
}

function update_forecast_data(data) {
    forecast_provider = "$Extras.forecast_provider";
    belchertown_debug("Forecast: Provider is " + forecast_provider);
    belchertown_debug("Forecast: Updating data");
    belchertown_debug(data);

    if (forecast_provider == "N/A") {
        jQuery(".forecastrow").hide();
        belchertown_debug("Forecast: No provider, hiding forecastrow");
        return;
    } else if (forecast_has_common_schema(data)) {
        forecast_render_common(data);
        return;
    } else {
        belchertown_debug("Forecast: Missing normalized forecast schema");
    }
}

