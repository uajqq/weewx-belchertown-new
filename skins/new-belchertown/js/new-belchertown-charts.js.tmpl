                // Gauge chart works best with only one data point, so the most recent (last) data point
                // is used
                options.series[0].data = [{
                    y: 9999999,
                    color: '#e6e6e6',
                    className: 'highcharts-pane',
                    zIndex: 0,
                    dataLabels: {enabled: false}
                }, {
                    y: gaugeNumericValue,
                    color: options.series[0].color,
                }]
                options.chart.type = "solidgauge"
                options.pane = {
                    startAngle: -140,
                    endAngle: 140,
                    background: [{
                        outerRadius: 0,
                        innerRadius: 0,
                    }]
                }

                // Set up yAxis min/max first — needed before color stop fraction calculation
                options.yAxis = {
                    min: 0,
                    max: 100,
                    lineColor: null,
                    tickPositions: []
                }
                if (isFiniteNumber(options.series[0].yAxis_max)) {
                    options.yAxis.max = parseFloat(options.series[0].yAxis_max);
                }
                if (isFiniteNumber(options.series[0].yAxis_min)) {
                    options.yAxis.min = parseFloat(options.series[0].yAxis_min);
                }
                if (options.yAxis.min === options.yAxis.max) {
                    options.yAxis.max = options.yAxis.min + 1;
                }
                options.yAxis.title = {
                    text: null,
                    enabled: false,
                }

                var gaugeUnitLabel = options.series[0].yAxis_label_unit;
                if (!gaugeUnitLabel && options.series[0].yAxis_label) {
                    var gaugeUnitMatch = String(options.series[0].yAxis_label).match(/\(([^)]+)\)\s*$/);
                    if (gaugeUnitMatch) {
                        gaugeUnitLabel = gaugeUnitMatch[1];
                    }
                }
                if (observation_type == "aqi" && !gaugeUnitLabel) {
                    gaugeUnitLabel = belchertown_label_text("$obs.label.aqi_unknown");
                }

                // Build color stops from colorX / colorX_position pairs if defined
                var customColorStops = [];
                for (var ci = 1; ci <= 20; ci++) {
                    var cPos = options.series[0]["color" + ci + "_position"];
                    var cVal = options.series[0]["color" + ci];
                    if (cPos === undefined || cVal === undefined) break;
                    // Strip any surrounding quotes added by charts.conf string quoting
                    var cColor = String(cVal).replace(/^["']|["']$/g, '');
                    customColorStops.push([parseFloat(cPos), cColor]);
                }

                if (customColorStops.length > 0) {
                    // Determine which color applies to the current value
                    var currentVal = options.series[0].data[1]["y"];
                    var currentColor = customColorStops[0][1];
                    for (var si = 0; si < customColorStops.length; si++) {
                        if (currentVal >= customColorStops[si][0]) {
                            currentColor = customColorStops[si][1];
                        }
                    }
                    options.series[0].data[1].color = currentColor;
                } else if (options.series[0].colors_enabled) {
                    // Fall back to rainbow gradient coloring
                    options.series[0].data[1].color = new_gradient_temp(options.series[0].data[1]["y"], options.yAxis.min, options.yAxis.max)
                }

                // Always resolve a concrete gauge color for both the gauge and
                // data labels, even if no custom color thresholds are defined.
                if (!options.series[0].data[1].color) {
                    options.series[0].data[1].color = options.series[0].color || (options.colors && options.colors[0]) || '#7cb5ec';
                }

                var gaugeDecimals = options.series[0].rounding >= 0 ? parseInt(options.series[0].rounding, 10) : 0;
                var gaugeDisplayColor = options.series[0].data[1].color;
                var gaugeDataLabelFormat = '<span style="display:block;text-align:center;color:' + gaugeDisplayColor + ' !important;">{y:.' + gaugeDecimals + 'f}</span>';
                var gaugeDataLabelYOffset = -22;
                var gaugeDataLabelLineHeight = '0.9em';
                if (gaugeUnitLabel) {
                    gaugeDataLabelFormat = gaugeDataLabelFormat + '<span style="display:block;font-size:17px;line-height:1em;margin-top:2px;text-align:center;color:' + gaugeDisplayColor + ' !important;">' + gaugeUnitLabel + '</span>';
                    gaugeDataLabelYOffset = -24;
                    gaugeDataLabelLineHeight = '0.95em';
                }

                options.plotOptions = {
                    solidgauge: {
                        dataLabels: {
                            useHTML: true,
                            enabled: true,
                            y: gaugeDataLabelYOffset,
                            borderWidth: 0,
                            format: gaugeDataLabelFormat,
                            style: {
                                fontWeight: 'bold',
                                lineHeight: gaugeDataLabelLineHeight,
                                textAlign: 'center',
                                fontSize: '50px',
                                // Match color if set by user
                                color: gaugeDisplayColor,
                                textOutline: 'none'
                            }
                        },
                    }
                }
                options.tooltip.enabled = false
                options.xAxis.crosshair = false
            }

            // If Hays chart is present, configure a special chart to show that data
            if (observation_type == "haysChart") {
                options.chart.type = "arearange"
                options.chart.polar = true;
                options.plotOptions = {
                    turboThreshold: 0,
                    series: {
                        marker: {
                            enabled: false
                        }
                    }
                };
                var currentSeriesData = options.series[0].data;
                var range_unit = options.series[0].range_unit;
                var rounding = options.series[0].rounding;
                var newSeriesData = [];
                var currentSeriesColor = options.series[0].color;
                var range_max = null;
                currentSeriesData.forEach(seriesData => {
                    if (isFiniteNumber(seriesData[2])) {
                        var highValue = parseFloat(seriesData[2]);
                        if (range_max === null || highValue > range_max) {
                            range_max = highValue;
                        }
                    }
                    newSeriesData.push({
                        x: seriesData[0],
                        low: seriesData[1],
                        high: seriesData[2],
                    });
                });
                if (isFiniteNumber(options.series[0].yAxis_softMax)) {
                    range_max = parseFloat(options.series[0].yAxis_softMax);
                }
                if (range_max === null) {
                    range_max = 0;
                }
                options.legend = {"enabled": false}
                options.yAxis = {
                    showFirstLabel: false,
                    tickInterval: 2,
                    tickmarkPlacement: 'on',
                    min: -1,
                    softMax: range_max,
                    title: {
                        text: options.series[0].yAxis_label,
                    },
                    labels: {
                        align: 'center',
                        x: 0,
                        y: 0
                    },
                }
                options.tooltip = {
                    split: false,
                    shared: true,
                    followPointer: true,
                    useHTML: true,
                    formatter: function(tooltip) {
                        return this.points.map(function(point) {
                            var rounding = point.series.userOptions.rounding;
                            var mirrored = point.series.userOptions.mirrored_value;
                            var numberFormat = point.series.userOptions.numberFormat ? point.series.userOptions.numberFormat : "";
                            return "<strong>" + belchertown_escape_html(tzAdjustedMoment(point.x / 1000).format(tooltip_date_format)) + "</strong><br><span style='color:" + options.series[0].color + "'>●</span> " + belchertown_label_html("$obs.label.highest_temperature") + ": " + highcharts_tooltip_factory(point.point.high, observation_type, true, rounding, mirrored, numberFormat) + "<br><span style='color:" + options.series[0].color + "'>●</span> " + belchertown_label_html("$obs.label.lowest_temperature") + ": " + highcharts_tooltip_factory(point.point.low, observation_type, true, rounding, mirrored, numberFormat);
                        });
                    }
                }
                options.series = [];
                options.series.push({
                    data: newSeriesData,
                    obsType: "haysChart",
                    obsUnit: range_unit,
                    rounding: rounding,
                    color: currentSeriesColor,
                    fillColor: currentSeriesColor,
                    connectEnds: false,
                });
            }

            // If weather range is present, configure a special chart to show that data
            // https://www.highcharts.com/blog/tutorials/209-the-art-of-the-chart-weather-radials/
            if (observation_type == "weatherRange") {
                if (options.series[0].area_display) {
                    options.chart.type = "arearange";
                } else {
                    options.chart.type = "columnrange";
                }

                // If polar is defined, use it and add a special dark mode CSS class
                if (JSON.parse(String(options.series[0].polar.toLowerCase()))) {
                    options.chart.polar = true; // Make sure the option is a string, then convert to bool
                    options.chart.className = "highcharts-weatherRange belchertown-polar"; // Used for dark mode
                } else {
                    options.chart.className = "highcharts-weatherRange"; // Used for dark mode
                }

                options.legend = {"enabled": false}

                var currentSeriesData = options.series[0].data;
                var range_unit = options.series[0].range_unit;
                var rounding = options.series[0].rounding;
                var newSeriesData = [];
                var range_min = null;
                var range_max = null;
                currentSeriesData.forEach(seriesData => {
                    if (isFiniteNumber(seriesData[1])) {
                        var lowValue = parseFloat(seriesData[1]);
                        if (range_min === null || lowValue < range_min) {
                            range_min = lowValue;
                        }
                    }
                    if (isFiniteNumber(seriesData[2])) {
                        var highValue = parseFloat(seriesData[2]);
                        if (range_max === null || highValue > range_max) {
                            range_max = highValue;
                        }
                    }
                    var color = options.series[0].color;
                    if (!color) {
                        // Set color of the column based on the average temperature, or return default if not temperature
                        if (seriesData[3] == null) {
                            console.log("Requesting " + seriesData[0] + ". Value is " + seriesData[3])
                        }
                        color = get_outTemp_color(range_unit, seriesData[3], true);
                    }
                    newSeriesData.push({
                        x: seriesData[0],
                        low: seriesData[1],
                        high: seriesData[2],
                        average: seriesData[3],
                        color: color
                    });
                });
                // Guard all-zero (or flat) datasets so yAxis math never produces
                // tickInterval=0 / min==max, which can prevent chart rendering.
                if (range_min === null) {
                    range_min = 0;
                }
                if (range_max === null) {
                    range_max = 0;
                }
                if (range_min === range_max) {
                    range_max = range_min + 1;
                }

                var yAxis_tickInterval = Math.ceil(Math.round(range_max / 5) / 5) * 5; // Divide max outTemp by 5 and round it, then round that value up to the nearest 5th multiple. This gives clean yAxis tick lines.
                if (!isFinite(yAxis_tickInterval) || yAxis_tickInterval <= 0) {
                    yAxis_tickInterval = 1;
                }

                options.yAxis = {
                    showFirstLabel: true,
                    tickInterval: yAxis_tickInterval,
                    min: range_min,
                    max: range_max,
                    title: {
                        text: options.series[0].yAxis_label,
                    },
                }

                options.xAxis = {
                    dateTimeLabelFormats: {
                        day: belchertown_highcharts_compact_date_format(false),
                        week: belchertown_highcharts_compact_date_format(false),
                        month: belchertown_highcharts_compact_date_format(false),
                    },
                    showLastLabel: true,
                    crosshair: true,
                    type: "datetime",
                    units: [
                        ['minute', [1, 2, 5, 10, 15, 30]],
                        ['hour',   [1, 2, 3, 4, 6, 8, 12]],
                        ['day',    [1]],
                        ['week',   [1]],
                        ['month',  [1]],
                        ['year',   null]
                    ],
                    labels: xAxis_categories.length >= 1 ? {
                        formatter: function() {
                            return xAxis_categories[new Date(this.value).getMonth()];
                        }
                    } : {}
                };

                options.plotOptions = {}
                options.plotOptions = {
                    series: {
                        turboThreshold: 0,
                        showInLegend: false,
                        borderWidth: 0,
                        marker: {
                            enabled: false,
                        },
                    }
                }

                if (options.series[0].area_display) {
                    if (options.series[0].range_unit == "degree_F") {
                        options.plotOptions.series.zones = [
                            {value: 0, color: "#1278c8"},
                            {value: 25, color: "#30bfef"},
                            {value: 32, color: "#1fafdd"},
                            {value: 40, color: "rgba(0,172,223,1)"},
                            {value: 50, color: "#71bc3c"},
                            {value: 55, color: "rgba(90,179,41,0.8)"},
                            {value: 65, color: "rgba(131,173,45,1)"},
                            {value: 70, color: "rgba(206,184,98,1)"},
                            {value: 75, color: "rgba(255,174,0,0.9)"},
                            {value: 80, color: "rgba(255,153,0,0.9)"},
                            {value: 85, color: "rgba(255,127,0,1)"},
                            {value: 90, color: "rgba(255,79,0,0.9)"},
                            {value: 95, color: "rgba(255,69,69,1)"},
                            {value: 110, color: "rgba(255,104,104,1)"},
                            {color: "rgba(218,113,113,1)"},
                        ]
                    } else {
                        options.plotOptions.series.zones = [
                            {value: -5, color: "#1278c8"},
                            {value: -3.8, color: "#30bfef"},
                            {value: 0, color: "#1fafdd"},
                            {value: 4.4, color: "rgba(0,172,223,1)"},
                            {value: 10, color: "#71bc3c"},
                            {value: 12.7, color: "rgba(90,179,41,0.8)"},
                            {value: 18.3, color: "rgba(131,173,45,1)"},
                            {value: 21.1, color: "rgba(206,184,98,1)"},
                            {value: 23.8, color: "rgba(255,174,0,0.9)"},
                            {value: 26.6, color: "rgba(255,153,0,0.9)"},
                            {value: 29.4, color: "rgba(255,127,0,1)"},
                            {value: 32.2, color: "rgba(255,79,0,0.9)"},
                            {value: 35, color: "rgba(255,69,69,1)"},
                            {value: 43.3, color: "rgba(255,104,104,1)"},
                            {color: "rgba(218,113,113,1)"},
                        ]
                    }
                } else {
                    options.plotOptions.series.stacking = "normal"
                }

                options.tooltip = {
                    split: false,
                    shared: true,
                    followPointer: true,
                    useHTML: true,
                    formatter: function(tooltip) {
                        return this.points.map(function(point) {
                            var rounding = point.series.userOptions.rounding;
                            var mirrored = point.series.userOptions.mirrored_value;
                            var numberFormat = point.series.userOptions.numberFormat ? point.series.userOptions.numberFormat : "";
                            var header = (xAxis_categories.length >= 1)
                                ? xAxis_categories[point.x]
                                : tzAdjustedMoment(point.x / 1000).format(tooltip_date_format);
                            return "<strong>" + belchertown_escape_html(header) + "</strong><br><span style='color:" + get_outTemp_color(point.series.userOptions.obsUnit, point.point.high, true) + "'>●</span> " + belchertown_label_html("$obs.label.highest_temperature") + ": " + highcharts_tooltip_factory(point.point.high, observation_type, true, rounding, mirrored, numberFormat) + "<br><span style='color:" + get_outTemp_color(point.series.userOptions.obsUnit, point.point.low, true) + "'>●</span> " + belchertown_label_html("$obs.label.lowest_temperature") + ": " + highcharts_tooltip_factory(point.point.low, observation_type, true, rounding, mirrored, numberFormat) + "<br><span style='color:" + get_outTemp_color(point.series.userOptions.obsUnit, point.point.average, true) + "'>●</span> " + belchertown_label_html("$obs.label.average_temperature") + ": " + highcharts_tooltip_factory(point.point.average, observation_type, true, rounding, mirrored, numberFormat);
                        });
                    }
                }

                options.series = [];
                options.series.push({
                    data: newSeriesData,
                    obsType: "weatherRange",
                    obsUnit: range_unit,
                    rounding: rounding
                });
            }

            // Apply any width, height CSS overrides to the parent div of the chart
            if (css_height != "") {
                jQuery("#" + options.chart.renderTo).parent().css({
                    'height': css_height,
                    'padding': '0px 15px',
                    'margin-bottom': '20px'
                });
            }
            if (css_width != "") {
                jQuery("#" + options.chart.renderTo).parent().css('width', css_width);
            }

            if (credits != "highcharts_default") {
                options.credits.text = credits;
            }

            if (credits_url != "highcharts_default") {
                options.credits.href = credits_url;
            }

            if (credits_position != "highcharts_default") {
                options.credits.position = JSON.parse(credits_position);
            }

            // Finally all options are done, now show the chart
            // Datetime charts use stockChart for consistent axis behavior.
            // Wind rose and category charts must use Highcharts.chart() because
            // Highstock forces a datetime axis internally and ignores type: 'category'.
            // weatherRange always uses datetime data even when xAxis_categories provides custom labels

            // Wind barb chart: mirrors https://www.highcharts.com/samples/highcharts/demo/windbarb-series
            // A line series shows wind speed; a windbarb series shows direction/Beaufort.
            // shared:true tooltip combines both rows into one popup automatically.
            // Search all series for the windBarb one so its position in charts.conf does not matter.
            var windBarbSeries = null;
            for (var wbj = 0; wbj < options.series.length; wbj++) {
                if (options.series[wbj].obsType === "windBarb") {
                    windBarbSeries = options.series[wbj];
                    break;
                }
            }
            if (windBarbSeries) {
                // Build timestamp → direction lookup and converted windbarb
                // points in one pass through the raw data.
                var wbDataMap = {};
                var windBarbData = [];
                var calmThresholdMs = 2.5 * 0.514444;
                var rawWindBarbData = Array.isArray(windBarbSeries.data) ? windBarbSeries.data : [];
                var windSpeedLineData = Array.isArray(windBarbSeries.windspeedData) ? windBarbSeries.windspeedData : [];

                // Wind speed line series — carry rounding/obsType so the default formatter works
                options.series.push({
                    type: "line",
                    id: "windbarb-windspeed",
                    name: windBarbSeries.name,
                    data: windSpeedLineData,
                    color: windBarbSeries.color,
                    obsType: windBarbSeries.obsType,
                    rounding: windBarbSeries.rounding,
                    numberFormat: windBarbSeries.numberFormat,
                    showInLegend: true,
                    showInNavigator: true,
                    dataGrouping: {
                        enabled: false
                    },
                    states: {
                        inactive: { opacity: 1 }
                    }
                });

                // Reconfigure as a Highcharts windbarb series
                windBarbSeries.type = "windbarb";
                windBarbSeries.showInLegend = false;
                windBarbSeries.showInNavigator = false;
                windBarbSeries.vectorLength = 24;
                windBarbSeries.enableMouseTracking = false;
                delete windBarbSeries.tooltip;

                // Convert [[ts, m/s, dir], ...] to [{x: , value: , direction: }, ...]
                // Keep calm points (<2.5 knots) even when direction is null; Highcharts
                // windbarb renders a circle for calm conditions.
                rawWindBarbData.forEach(function(d) {
                    if (d[2] !== null) {
                        wbDataMap[d[0]] = d[2]; // d[0]=ts, d[2]=direction
                    }
                    if (d[1] !== null && (d[2] !== null || d[1] < calmThresholdMs)) {
                        windBarbData.push({x: d[0], value: d[1], direction: d[2] !== null ? d[2] : 0});
                    }
                });
                windBarbSeries.data = windBarbData;

                options.series.forEach(function(series) {
                    if (series.type !== "windbarb") {
                        series.dataGrouping = {
                            enabled: false
                        };
                    }
                });

                // Custom tooltip: show wind speed (respecting rounding) plus direction.
                // The windbarb series is excluded from this.points (enableMouseTracking:false),
                // so direction is appended via wbDataMap instead.
                options.tooltip = {
                    split: true,
                    formatter: function() {
                        var header = tzAdjustedMoment(this.x / 1000).format(tooltip_date_format);
                        var direction = wbDataMap[this.x];
                        var rows = this.points.map(function(point) {
                            var point_obsType = point.series.userOptions.observation_type ? point.series.userOptions.observation_type : point.series.userOptions.obsType;
                            var rounding = point.series.userOptions.rounding;
                            var mirrored = point.series.userOptions.mirrored_value;
                            var numberFormat = point.series.userOptions.numberFormat ? point.series.userOptions.numberFormat : "";
                            var row = "<span style='color:" + point.series.color + "'>●</span> " +
                                point.series.name + ": " +
                                highcharts_tooltip_factory(point.y, point_obsType, true, rounding, mirrored, numberFormat);
                            if (typeof direction !== "undefined") {
                                row += "<br/>" + highcharts_tooltip_factory(direction, "windDir", true, 0, false, "");
                            }
                            return row;
                        });
                        return [header].concat(rows);
                    }
                };

                options.xAxis.type = "datetime";
                options.xAxis.offset = 40;
            }

            var zoomRequested = JSON.parse(String(zoom_enabled));
            var useStockChart = (observation_type !== "windRose") && (xAxis_categories.length === 0 || observation_type === "weatherRange");
            var zoomControlsEnabled = zoomRequested && useStockChart;
            if (zoomControlsEnabled) {
                options.chart.zooming.type = "x";
                options.chart.zooming.mouseWheel.enabled = true;
                options.scrollbar.enabled = true;
                options.navigator.enabled = true;
                options.rangeSelector.enabled = true;
                options.rangeSelector.buttons = [{
                    type: "day",
                    count: 1,
                    text: "1d"
                }, {
                    type: "week",
                    count: 1,
                    text: "1w"
                }, {
                    type: "month",
                    count: 1,
                    text: "1m"
                }, {
                    type: "month",
                    count: 3,
                    text: "3m"
                }, {
                    type: "ytd",
                    text: "YTD"
                }, {
                    type: "year",
                    count: 1,
                    text: "1y"
                }, {
                    type: "all",
                    text: $charts_page_all_button_label_json
                }];
            }
            var chart = useStockChart ? Highcharts.stockChart(options) : Highcharts.chart(options);
            if (zoomControlsEnabled) {
                belchertown_apply_initial_zoom_range(chart, zoom_range);
            }

            // If using debug, show a copy paste debug for use with jsfiddle
            belchertown_debug(options);
            belchertown_debug("Highcharts.chart('container', " + JSON.stringify(options) + ");");

            } catch (e) {
                // Keep rendering other charts even if one chart has invalid
                // series/observation data.

                // Add a visible placeholder for the skipped chart so users
                // know why this chart is empty.
                if (typeof options !== "undefined" && options.chart && options.chart.renderTo) {
                    var failedChart = jQuery("#" + options.chart.renderTo);
                    if (failedChart.length) {
                        var unavailableObs = observation_type || plotname || belchertown_label_text("$obs.label.unknown_observation");
                        failedChart.html(
                            '<div class="chart-unavailable" style="padding:14px 10px;text-align:center;color:#888;">' +
                            '<div>' + belchertown_label_html("$obs.label.chart_unavailable") + ' (' + belchertown_label_html("$obs.label.chart_unavailable_detail") + ')</div>' +
                            '<div style="margin-top:6px;font-weight:500;">' + belchertown_label_html("$obs.label.observation") + ': ' + belchertown_escape_html(unavailableObs) + '</div>' +
                            '</div>'
                        );
                    }
                }

                return true;
            }

        });

        };

        var requiredModules = belchertown_detect_highcharts_modules(data);
        highchartsCorePromise.then(function(coreError) {
            if (coreError) {
                throw coreError;
            }
            return belchertown_ensure_highcharts_modules(requiredModules);
        }).then(function() {
            belchertown_configure_highcharts_defaults();
            renderCharts();
        }).catch(function(err) {
            if (typeof Highcharts === "undefined") {
                belchertown_debug("Highcharts load error: " + err.message + ". Skipping chart render.");
                return;
            }

            belchertown_debug("Highcharts module preload error: " + err.message + ". Continuing render with available modules.");
            belchertown_configure_highcharts_defaults();
            renderCharts();
        });

    });

};
