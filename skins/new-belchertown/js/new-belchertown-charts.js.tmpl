var belchertown_highcharts_defaults_applied = false;

function belchertown_ensure_highcharts_core() {
    if (typeof Highcharts !== "undefined") {
        return Promise.resolve(Highcharts);
    }

    if (typeof window.belchertownEnsureHighcharts === "function") {
        return window.belchertownEnsureHighcharts();
    }

    return Promise.reject(new Error("Highcharts loader is not available"));
}

function belchertown_configure_highcharts_defaults() {
    if (belchertown_highcharts_defaults_applied || typeof Highcharts === "undefined") {
        return;
    }

    Highcharts.setOptions({
        time: {
            timezoneOffset: $highcharts_timezoneoffset
        },
        chart: {
            style: {
                fontFamily: 'Roboto, sans-serif',
                fontSize: '14px',
                fontWeight: '500'
            }
        },
        title: {
            style: {
                fontFamily: 'Roboto, sans-serif',
                fontSize: '20px'
            }
        },
        subtitle: {
            style: {
                fontFamily: 'Roboto, sans-serif',
                fontWeight: '300'
            }
        },
        lang: {
            months: moment.months(),
            shortMonths: moment.monthsShort(),
            weekdays: moment.weekdays(),
            shortWeekdays: moment.weekdaysShort(),
            decimalPoint: "$highcharts_decimal",
            thousandsSep: "$highcharts_thousands"
        }
    });

    belchertown_highcharts_defaults_applied = true;
}

function belchertown_zoom_range_to_ms(zoomRange) {
    if (typeof zoomRange === "undefined" || zoomRange === null) {
        return null;
    }

    var normalized = String(zoomRange).trim().toLowerCase();
    if (!normalized || normalized === "false" || normalized === "none") {
        return null;
    }

    var keywordRanges = {
        hour: 3600000,
        day: 86400000,
        today: 86400000,
        week: 604800000,
        month: 2592000000,
        year: 31536000000
    };
    if (Object.prototype.hasOwnProperty.call(keywordRanges, normalized)) {
        return keywordRanges[normalized];
    }

    var seconds = parseFloat(normalized);
    if (isFinite(seconds) && seconds > 0) {
        return seconds * 1000;
    }

    return null;
}

function belchertown_apply_initial_zoom_range(chart, zoomRange) {
    var rangeMs = belchertown_zoom_range_to_ms(zoomRange);
    if (!rangeMs || !chart || !chart.xAxis || !chart.xAxis[0]) {
        return;
    }

    var axis = chart.xAxis[0];
    var dataMax = typeof axis.dataMax === "number" ? axis.dataMax : axis.max;
    var dataMin = typeof axis.dataMin === "number" ? axis.dataMin : axis.min;
    if (!isFinite(dataMax) || !isFinite(dataMin) || dataMax <= dataMin) {
        return;
    }

    var min = Math.max(dataMin, dataMax - rangeMs);
    if (min < dataMax) {
        axis.setExtremes(min, dataMax, true, false);
    }
}

function belchertown_is_element_near_viewport(element, rootMarginPx = 0) {
    if (!element || !element.getBoundingClientRect) {
        return true;
    }

    var rect = element.getBoundingClientRect();
    var margin = parseInt(rootMarginPx, 10);
    if (!isFinite(margin)) {
        margin = 0;
    }

    var viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
    return rect.top <= (viewportHeight + margin) && rect.bottom >= (0 - margin);
}

function belchertown_run_when_visible(target, onVisible, config = {}) {
    var rootMargin = typeof config.rootMargin === "string" ? config.rootMargin : "400px 0px";
    var threshold = typeof config.threshold === "number" ? config.threshold : 0.01;
    var fallbackDelayMs = typeof config.fallbackDelayMs === "number" ? config.fallbackDelayMs : 3000;
    var element = (typeof target === "string") ? document.querySelector(target) : target;
    var done = false;
    var observer = null;
    var fallbackTimer = null;

    var complete = function() {
        if (done) {
            return;
        }
        done = true;

        if (observer && observer.disconnect) {
            observer.disconnect();
        }
        if (fallbackTimer) {
            clearTimeout(fallbackTimer);
        }

        try {
            onVisible();
        } catch (err) {
            belchertown_debug("LazyLoad: onVisible callback failed: " + err.message);
        }
    };

    if (!element) {
        complete();
        return {
            disconnect: function() {},
            triggerNow: complete,
        };
    }

    // Immediate fast-path if already near viewport.
    var rootMarginPx = parseInt(String(rootMargin).split("px")[0], 10);
    if (belchertown_is_element_near_viewport(element, isFinite(rootMarginPx) ? rootMarginPx : 0)) {
        complete();
        return {
            disconnect: function() {},
            triggerNow: complete,
        };
    }

    if ("IntersectionObserver" in window) {
        observer = new IntersectionObserver(function(entries) {
            for (var i = 0; i < entries.length; i++) {
                if (entries[i].isIntersecting || entries[i].intersectionRatio > 0) {
                    complete();
                    break;
                }
            }
        }, {
            root: null,
            rootMargin: rootMargin,
            threshold: threshold,
        });
        observer.observe(element);
    } else {
        // Safety fallback for older browsers without IntersectionObserver.
        fallbackTimer = setTimeout(function() {
            complete();
        }, Math.max(0, fallbackDelayMs));
    }

    if (config.alwaysFallback === true && !fallbackTimer) {
        fallbackTimer = setTimeout(function() {
            complete();
        }, Math.max(0, fallbackDelayMs));
    }

    return {
        disconnect: function() {
            if (observer && observer.disconnect) {
                observer.disconnect();
            }
            if (fallbackTimer) {
                clearTimeout(fallbackTimer);
            }
        },
        triggerNow: complete,
    };
}

function belchertown_progressive_queue(tasks, config = {}) {
    var queue = Array.isArray(tasks) ? tasks.slice() : [];
    var queueIndex = 0;
    var batchSize = parseInt(config.batchSize, 10);
    var delayMs = parseInt(config.delayMs, 10);
    var useIdleCallback = (typeof config.useIdleCallback === "boolean") ? config.useIdleCallback : true;

    if (!isFinite(batchSize) || batchSize < 1) {
        batchSize = 1;
    }
    if (!isFinite(delayMs) || delayMs < 0) {
        delayMs = 0;
    }

    var runBatch = function() {
        var count = 0;
        while (queueIndex < queue.length && count < batchSize) {
            var task = queue[queueIndex];
            queueIndex++;
            try {
                if (typeof task === "function") {
                    task();
                }
            } catch (err) {
                belchertown_debug("LazyLoad: progressive task failed: " + err.message);
            }
            count++;
        }

        if (queueIndex < queue.length) {
            scheduleNext();
        } else {
            queue = [];
            queueIndex = 0;
        }
    };

    var scheduleNext = function() {
        if (useIdleCallback && typeof window.requestIdleCallback === "function") {
            window.requestIdleCallback(function() {
                runBatch();
            }, {timeout: Math.max(1, delayMs || 1)});
        } else {
            setTimeout(runBatch, delayMs);
        }
    };

    scheduleNext();

    return {
        remaining: function() {
            return Math.max(queue.length - queueIndex, 0);
        },
        flush: function() {
            while (queueIndex < queue.length) {
                var task = queue[queueIndex];
                queueIndex++;
                if (typeof task === "function") {
                    task();
                }
            }
            queue = [];
            queueIndex = 0;
        },
    };
}

var belchertown_highcharts_module_promises = {};

function belchertown_load_script_once(moduleKey, moduleUrl) {
    if (belchertown_highcharts_module_promises[moduleKey]) {
        return belchertown_highcharts_module_promises[moduleKey];
    }

    belchertown_highcharts_module_promises[moduleKey] = new Promise(function(resolve, reject) {
        var existing = document.querySelector('script[data-belchertown-module="' + moduleKey + '"]');
        if (existing) {
            if (existing.getAttribute("data-loaded") === "1") {
                resolve();
                return;
            }
            existing.addEventListener("load", function() {
                existing.setAttribute("data-loaded", "1");
                resolve();
            }, {once: true});
            existing.addEventListener("error", function() {
                reject(new Error("Failed loading module " + moduleKey));
            }, {once: true});
            return;
        }

        var script = document.createElement("script");
        script.src = moduleUrl;
        script.async = false;
        script.setAttribute("data-belchertown-module", moduleKey);
        script.onload = function() {
            script.setAttribute("data-loaded", "1");
            resolve();
        };
        script.onerror = function() {
            reject(new Error("Failed loading module " + moduleKey));
        };
        document.head.appendChild(script);
    });

    return belchertown_highcharts_module_promises[moduleKey];
}

function belchertown_detect_highcharts_modules(chartData) {
    var modules = new Set();

    if (!chartData || typeof chartData !== "object") {
        return modules;
    }

    jQuery.each(chartData, function(plotname, plotData) {
        if (!plotData || typeof plotData !== "object" || !plotData.options) {
            return true;
        }

        if (plotData.options.type === "gauge") {
            modules.add("solid-gauge");
        }

        if (String(plotData.options.exporting).toLowerCase() === "true") {
            modules.add("exporting");
            modules.add("export-data");
            modules.add("accessibility");
        }

        if (plotData.series && typeof plotData.series === "object") {
            jQuery.each(plotData.series, function(seriesName, seriesData) {
                if (seriesData && seriesData.obsType === "windBarb") {
                    modules.add("windbarb");
                }
                return true;
            });
        }

        return true;
    });

    return modules;
}

function belchertown_ensure_highcharts_modules(moduleSet) {
    if (typeof Highcharts === "undefined") {
        return Promise.reject(new Error("Highcharts core is not available"));
    }

    var modules = Array.from(moduleSet || []);
    if (modules.length === 0) {
        return Promise.resolve();
    }

    var moduleBase = "//code.highcharts.com/12.6/modules/";
    var loaderPromises = modules.map(function(moduleKey) {
        return belchertown_load_script_once(moduleKey, moduleBase + moduleKey + ".js");
    });

    return Promise.all(loaderPromises);
}

function belchertown_has_own(obj, key) {
    return obj && Object.prototype.hasOwnProperty.call(obj, key);
}

function belchertown_is_finite_number(v) {
    return v !== null && typeof v !== "undefined" && v !== "" && isFinite(parseFloat(v));
}

function belchertown_axis_option_number(obj, key) {
    if (!belchertown_has_own(obj, key) || !belchertown_is_finite_number(obj[key])) {
        return null;
    }
    return parseFloat(obj[key]);
}

function belchertown_series_exists_in_data(series) {
    return series && Array.isArray(series.data) && series.data.length > 0;
}

function belchertown_series_data_points(series) {
    var obsType = (series && (series.obsType || series.observation_type)) || "";
    if (obsType === "windBarb" && series && Array.isArray(series.windspeedData) && series.windspeedData.length > 0) {
        return series.windspeedData;
    }
    return series && Array.isArray(series.data) ? series.data : [];
}

function belchertown_series_point_values(point, obsType) {
    if (point === null || typeof point === "undefined") {
        return [];
    }
    if (obsType === "weatherRange" || obsType === "haysChart") {
        if (Array.isArray(point)) {
            return [point[1], point[2], point[3]];
        }
        if (typeof point === "object") {
            return [point.low, point.high, point.average];
        }
        return [];
    }
    if (obsType === "windBarb") {
        if (Array.isArray(point)) {
            return [point[1]];
        }
        if (typeof point === "object") {
            return [point.value, point.y];
        }
        return [];
    }
    if (Array.isArray(point)) {
        return [point[1]];
    }
    if (typeof point === "object") {
        return [point.y, point.value];
    }
    return [point];
}

function belchertown_analyze_chart_series(seriesList) {
    var analysis = {
        axisExtents: {},
        missingSeries: [],
        usableSeriesIndexes: [],
        usableSeriesCount: 0
    };

    (Array.isArray(seriesList) ? seriesList : []).forEach(function(series, seriesIndex) {
        var obsType = (series && (series.obsType || series.observation_type)) || "";
        var axisIndex = parseInt(series && series.yAxis, 10);
        var seriesData = belchertown_series_data_points(series);
        var hasUsableData = obsType === "windRose" && belchertown_series_exists_in_data(series);

        if (!isFinite(axisIndex)) {
            axisIndex = 0;
        }
        if (!analysis.axisExtents[axisIndex]) {
            analysis.axisExtents[axisIndex] = {min: null, max: null};
        }

        if (obsType !== "windRose") {
            seriesData.forEach(function(point) {
                belchertown_series_point_values(point, obsType).forEach(function(rawValue) {
                    if (!belchertown_is_finite_number(rawValue)) {
                        return;
                    }
                    var value = parseFloat(rawValue);
                    hasUsableData = true;
                    if (analysis.axisExtents[axisIndex].min === null || value < analysis.axisExtents[axisIndex].min) {
                        analysis.axisExtents[axisIndex].min = value;
                    }
                    if (analysis.axisExtents[axisIndex].max === null || value > analysis.axisExtents[axisIndex].max) {
                        analysis.axisExtents[axisIndex].max = value;
                    }
                });
            });
        }

        if (hasUsableData) {
            analysis.usableSeriesCount++;
            analysis.usableSeriesIndexes.push(seriesIndex);
        } else {
            analysis.missingSeries.push(series || {});
        }
    });

    return analysis;
}

function belchertown_filter_unusable_chart_series(options, seriesAnalysis) {
    if (!options || !Array.isArray(options.series) || !seriesAnalysis || seriesAnalysis.missingSeries.length === 0) {
        return;
    }

    var usableByIndex = {};
    seriesAnalysis.usableSeriesIndexes.forEach(function(seriesIndex) {
        usableByIndex[seriesIndex] = true;
    });

    options.series = options.series.filter(function(series, seriesIndex) {
        return usableByIndex[seriesIndex] === true;
    });

    var axesWithSeries = {};
    options.series.forEach(function(series) {
        var axisIndex = parseInt(series && series.yAxis, 10);
        if (!isFinite(axisIndex)) {
            axisIndex = 0;
        }
        axesWithSeries[axisIndex] = true;
        if (Array.isArray(options.yAxis) && options.yAxis[axisIndex] && series.yAxis_label) {
            options.yAxis[axisIndex].title = options.yAxis[axisIndex].title || {};
            options.yAxis[axisIndex].title.text = series.yAxis_label;
        }
    });

    if (Array.isArray(options.yAxis)) {
        options.yAxis.forEach(function(axis, axisIndex) {
            if (!axis || axesWithSeries[axisIndex]) {
                return;
            }
            axis.visible = false;
            axis.showEmpty = false;
            axis.title = axis.title || {};
            axis.title.text = null;
        });
    }
}

function belchertown_apply_flat_axis_ranges(options, seriesAnalysis) {
    if (!options || !Array.isArray(options.yAxis) || !seriesAnalysis || !seriesAnalysis.axisExtents) {
        return;
    }

    Object.keys(seriesAnalysis.axisExtents).forEach(function(axisIndex) {
        var extent = seriesAnalysis.axisExtents[axisIndex];
        var axis = options.yAxis[axisIndex];
        if (!axis || extent.min === null || extent.max === null || extent.min !== extent.max) {
            return;
        }

        var flatValue = extent.min;
        var padding = Math.max(Math.abs(flatValue) * 0.05, 1);
        var configuredMin = belchertown_is_finite_number(axis.min);
        var configuredMax = belchertown_is_finite_number(axis.max);
        var currentMin = configuredMin ? parseFloat(axis.min) : null;
        var currentMax = configuredMax ? parseFloat(axis.max) : null;

        if (configuredMin && configuredMax && currentMin === currentMax) {
            axis.min = flatValue === 0 ? 0 : flatValue - padding;
            axis.max = flatValue + padding;
        } else if (flatValue === 0) {
            if (!configuredMin) {
                axis.min = 0;
            }
            if (!configuredMax || currentMax <= 0) {
                axis.max = 1;
            }
        } else {
            if (!configuredMin || currentMin >= flatValue) {
                axis.min = flatValue - padding;
            }
            if (!configuredMax || currentMax <= flatValue) {
                axis.max = flatValue + padding;
            }
        }
    });
}

function showChart(json_file, prepend_renderTo = false) {
    var highchartsCorePromise = belchertown_ensure_highcharts_core().then(function() {
        return null;
    }).catch(function(err) {
        return err;
    });

    // Relative URL by finding what page we're on currently.
    jQuery.ajax({
        url: get_relative_url() + '/json/' + json_file + '.json',
        dataType: 'json',
        headers: {'Cache-Control': 'no-cache'},
    }).done(function(data) {

        var renderCharts = function() {

        // Loop through each chart name (e.g. chart1, chart2, chart3)
        jQuery.each(data, function(plotname, obsname) {
            var observation_type = undefined;
            xAxis_categories = [];
            plot_tooltip_date_format = undefined;
            var zoom_enabled = false;
            var zoom_range = "";

            try {

            // Ignore the New Belchertown Version since this "plot" has no other options
            if (plotname == "belchertown_version") {
                return true;
            }

            // Ignore the generated timestamp since this "plot" has no other options
            if (plotname == "generated_timestamp") {
                return true;
            }

            // Ignore the chartgroup_title since this "plot" has no other options
            if (plotname == "chartgroup_title") {
                return true;
            }

            // Set the chart's tooltip date time format, then return since this "plot" has no other options
            if (plotname == "tooltip_date_format") {
                tooltip_date_format = obsname;
                return true;
            }

            // Set the chart colors, then return right away since this "plot" has no other options
            if (plotname == "colors") {
                colors = obsname.split(",");
                return true;
            }

            // Set the chart credits, then return right away since this "plot" has no other options
            if (plotname == "credits") {
                credits = obsname.split(",")[0];
                return true;
            }

            // Set the chart credits url, then return right away since this "plot" has no other options
            if (plotname == "credits_url") {
                credits_url = obsname.split(",")[0];
                return true;
            }

            // Set the chart credits position, then return right away since this "plot" has no other options
            if (plotname == "credits_position") {
                credits_position = obsname;
                return true;
            }

            // Loop through each chart options
            jQuery.each(data[plotname]["options"], function(optionName, optionVal) {
                switch (optionName) {
                    case "type":
                        type = optionVal;
                        break;
                    case "renderTo":
                        renderTo = optionVal;
                        break;
                    case "title":
                        title = optionVal;
                        break;
                    case "subtitle":
                        subtitle = optionVal;
                        break;
                    case "yAxis_label":
                        yAxis_label = optionVal;
                        break;
                    case "chart_group":
                        chart_group = optionVal;
                        break;
                    case "gapsize":
                        gapsize = optionVal;
                        break;
                    case "connectNulls":
                        connectNulls = optionVal;
                        break;
                    case "rounding":
                        rounding = optionVal;
                        break;
                    case "xAxis_categories":
                        xAxis_categories = optionVal;
                        break;
                    case "plot_tooltip_date_format":
                        plot_tooltip_date_format = optionVal;
                        break;
                    case "css_class":
                        css_class = optionVal;
                        break;
                    case "css_height":
                        css_height = optionVal;
                        break;
                    case "css_width":
                        css_width = optionVal;
                        break;
                    case "legend":
                        legend_enabled = optionVal;
                        break;
                    case "exporting":
                        exporting_enabled = optionVal;
                        break;
                    case "zoom":
                        zoom_enabled = optionVal;
                        break;
                    case "zoom_range":
                        zoom_range = optionVal;
                        break;
                }
            });

            // Handle any per-chart date time format override
            if (typeof plot_tooltip_date_format !== "undefined") {
                var tooltip_date_format = plot_tooltip_date_format;
            }

            var options = {
                chart: {
                    renderTo: '',
                    spacing: [5, 10, 10, 10],
                    type: '',
                    zooming: {
                        mouseWheel: {
                            enabled: false
                        }
                    }
                },

                exporting: {
                    chartOptions: {
                        chart: {
                            events: {
                                load: function() {
                                    this.title.update({style: {color: '#e5554e'}});

                                    if (sessionStorage.getItem('currentTheme') === 'dark') {
                                        var darktheme_textcolor = '#fff';
                                        for (var i = this.yAxis.length - 1; i >= 0; i--) {
                                            this.yAxis[i].update({
                                                title: {style: {color: darktheme_textcolor}},
                                                labels: {style: {color: darktheme_textcolor}},
                                                gridLineColor: '#707073',
                                                tickColor: '#707073'
                                            });
                                        }

                                        for (var i = this.xAxis.length - 1; i >= 0; i--) {
                                            this.xAxis[i].update({
                                                title: {style: {color: darktheme_textcolor}},
                                                labels: {style: {color: darktheme_textcolor}},
                                                gridLineColor: '#707073',
                                                tickColor: '#707073'
                                            });
                                        }

                                        this.legend.update({itemStyle: {color: darktheme_textcolor}});

                                        //this.credits.update({style:{color: darktheme_textcolor}});

                                        this.subtitle.update({style: {color: darktheme_textcolor}});

