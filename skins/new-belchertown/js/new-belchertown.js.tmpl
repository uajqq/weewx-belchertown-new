// Returns a color along a rainbow gradient from min (blue) to max (purple)
// Credit to excellent guide here: https://krazydad.com/tutorials/makecolors.php
// Setting red, blue, and green channels to oscillate as sine waves and
// then offsetting those waves by 120º (2π/3) gives us all colors of the rainbow

// Pre-parsed RGB tuples for the gradient stops (avoids repeated parseInt on every call)
const TEMP_GRADIENT_COLORS = [
    [0x8E, 0x62, 0xA8],
    [0x27, 0x7D, 0xA1],
    [0x27, 0x7D, 0xA1],
    [0x90, 0xBE, 0x6D],
    [0xF9, 0xC7, 0x4F],
    [0xF8, 0x96, 0x1E],
    [0xF3, 0x72, 0x2C],
    [0xF9, 0x41, 0x44],
    [0xE3, 0x3B, 0x76],
];

function new_gradient_temp(value, min, max) {
    if (value < min) { value = min; }
    if (value >= max) { value = max; }
    const position = (value - min) / (max - min) * 9; // position on 0–9 scale
    const low  = Math.min(Math.floor(position), 8);
    const high = Math.min(Math.ceil(position),  8);
    const [r_low,  g_low,  b_low]  = TEMP_GRADIENT_COLORS[low];
    const [r_high, g_high, b_high] = TEMP_GRADIENT_COLORS[high];
    const frac = position - low;
    const r = Math.round(r_low + (r_high - r_low) * frac);
    const g = Math.round(g_low + (g_high - g_low) * frac);
    const b = Math.round(b_low + (b_high - b_low) * frac);
    return "#" + r.toString(16).padStart(2, '0') + g.toString(16).padStart(2, '0') + b.toString(16).padStart(2, '0');
}

// Change the color of the AQI value
function get_aqi_color(aqi) {
    aqi = parseInt(aqi);
    if (isNaN(aqi)) return;
    var color;
    if (aqi <= 50) {
        color = "#71bc3c";
    } else if (aqi <= 100) {
        color = "rgba(255,174,0,0.9)";
    } else if (aqi <= 150) {
        color = "rgba(255,127,0,1)";
    } else if (aqi <= 200) {
        color = "rgba(255,69,69,1)";
    } else if (aqi <= 300) {
        color = "#b16286";
    } else {
        color = "#cc241d";
    }
    belchertown_apply_readable_color(".wx-aqi, .wx-aqi-category, .aqi_outer", color);
}

function get_outTemp_color(unit, outTemp, returnColor = false) {
    if (outTemp != null) {
        outTemp = parseFloat(outTemp).toFixed(0); // Convert back to decimal literal
    } else {
        return // No temperature value provided
    }

    if (unit == "degree_F") {
        var outTemp_color = new_gradient_temp(outTemp, 10, 120);
    } else if (unit == "degree_C") {
        var outTemp_color = new_gradient_temp(outTemp, -12, 49);
    } else {
        return // No unit provided
    }

    // Return the color value if requested, otherwise just set the div color
    if (returnColor) {
        return outTemp_color;
    } else {
        belchertown_apply_readable_color(".outtemp_outer", outTemp_color);
    }
}

function kts_to_beaufort(windspeed) {
    // Given windspeed in knots, converts to Beaufort scale
    var ws = parseFloat(windspeed);
    if (!isFinite(ws) || ws < 0) {
        return null;
    }

    if (ws <= 1) {
        return 0
    } else if (ws <= 3) {
        return 1
    } else if (ws <= 6) {
        return 2
    } else if (ws <= 10) {
        return 3
    } else if (ws <= 15) {
        return 4
    } else if (ws <= 21) {
        return 5
    } else if (ws <= 27) {
        return 6
    } else if (ws <= 33) {
        return 7
    } else if (ws <= 40) {
        return 8
    } else if (ws <= 47) {
        return 9
    } else if (ws <= 55) {
        return 10
    } else if (ws <= 63) {
        return 11
    } else {
        return 12
    }
}

function beaufort_cat(beaufort) {
    // Given Beaufort number, returns category description
    switch (beaufort) {
        case 0:
            return "$beaufort0"
        case 1:
            return "$beaufort1"
        case 2:
            return "$beaufort2"
        case 3:
            return "$beaufort3"
        case 4:
            return "$beaufort4"
        case 5:
            return "$beaufort5"
        case 6:
            return "$beaufort6"
        case 7:
            return "$beaufort7"
        case 8:
            return "$beaufort8"
        case 9:
            return "$beaufort9"
        case 10:
            return "$beaufort10"
        case 11:
            return "$beaufort11"
        case 12:
            return "$beaufort12"
        default:
            return "--"
    }
}

function beaufort_to_knots(beaufort) {
    var b = parseInt(beaufort, 10);
    if (!isFinite(b) || b < 0) {
        return null;
    }
    // Midpoint-style representative knot values by Beaufort number.
    var scale = [0, 2, 5, 8, 13, 19, 24, 30, 37, 44, 52, 60, 68];
    return scale[Math.min(b, 12)];
}

