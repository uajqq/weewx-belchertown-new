var wind_compass_calm_threshold_knots = 1;
var wind_compass_default_unit_label = "$unit.label.windSpeed";

function wind_compass_unit_label(obsName) {
    if (
        typeof unit_label_array === "object" &&
        unit_label_array !== null &&
        unit_label_array.hasOwnProperty(obsName)
    ) {
        return unit_label_array[obsName];
    }
    if (
        typeof unit_label_array === "object" &&
        unit_label_array !== null &&
        unit_label_array.hasOwnProperty("windSpeed")
    ) {
        return unit_label_array["windSpeed"];
    }
    if (typeof jQuery === "function") {
        var label = jQuery(".wind-table td.mph").first().text();
        if (label) {
            return label;
        }
    }
    return wind_compass_default_unit_label;
}

function wind_compass_value_to_knots(value, unitLabel) {
    var parsed = parse_wind_compass_knots(value);
    if (parsed === null) {
        return null;
    }

    var unit = String(unitLabel || "").replace(/&nbsp;/g, " ").trim().toLowerCase();
    if (unit === "mph" || unit.indexOf("mile") !== -1) {
        return parsed * 0.8689758;
    }
    if (unit === "km/h" || unit === "kph" || unit.indexOf("km") !== -1) {
        return parsed * 0.5399568;
    }
    if (unit === "m/s" || unit.indexOf("meter") !== -1 || unit.indexOf("metre") !== -1) {
        return parsed * 1.943844;
    }
    if (unit === "kt" || unit === "kts" || unit.indexOf("knot") !== -1) {
        return parsed;
    }
    if (unit === "bft" || unit.indexOf("beaufort") !== -1) {
        return beaufort_to_knots(parsed);
    }

    return null;
}

function displayed_wind_compass_knots(obsName) {
    if (typeof jQuery !== "function") {
        return null;
    }

    var selector = obsName == "windGust" ? ".curwindgust" : ".curwindspeed";
    var displayedValue = jQuery(selector).first().text();
    return wind_compass_value_to_knots(displayedValue, wind_compass_unit_label(obsName));
}

function knots_from_mqtt_payload(payload, obsName) {
    var windObs = obsName || "windSpeed";

    if (payload.hasOwnProperty(windObs + "_knot")) {
        return parseFloat(payload[windObs + "_knot"]);
    }
    if (payload.hasOwnProperty(windObs + "_mph")) {
        return parseFloat(payload[windObs + "_mph"]) * 0.8689758;
    }
    if (payload.hasOwnProperty(windObs + "_kph")) {
        return parseFloat(payload[windObs + "_kph"]) * 0.5399568;
    }
    if (payload.hasOwnProperty(windObs + "_mps")) {
        return parseFloat(payload[windObs + "_mps"]) * 1.943844;
    }
    if (payload.hasOwnProperty(windObs + "_beaufort")) {
        return beaufort_to_knots(payload[windObs + "_beaufort"]);
    }
    if (payload.hasOwnProperty(windObs)) {
        return wind_compass_value_to_knots(payload[windObs], wind_compass_unit_label(windObs));
    }

    var lowerWindObs = windObs.toLowerCase();
    if (payload.hasOwnProperty(lowerWindObs)) {
        return wind_compass_value_to_knots(payload[lowerWindObs], wind_compass_unit_label(windObs));
    }

    return null;
}

function build_windbarb_svg(knots) {
    var value = parseFloat(knots);
    if (!isFinite(value) || value < 0) {
        return "";
    }

    var rounded = Math.max(0, Math.round(value / 5) * 5);
    if (rounded === 0 && value >= wind_compass_calm_threshold_knots) {
        rounded = 5;
    }

    var color = "#c50a1d";
    var stroke = 5;
    var shaftX = 50;
    var shaftBottom = 88;
    // Keep the inner/center section invisible so the direction text remains clear.
    // Only render the outer/top part of the shaft.
    var shaftVisibleBottom = 44;
    var shaftTop = -12;
    var barbLen = 22;
    var barbStep = 8;
    var pennantLen = 34;
    var pennantHeight = 16;
    var pennantGap = 8;
    // Hard-coded visual slant tuned to match the pennant edge.
    var barbRise = 5.18;
    var barbY = shaftTop;
    var markerTop = shaftTop - pennantHeight;

    var parts = [];
    parts.push('<line x1="' + shaftX + '" y1="' + shaftVisibleBottom + '" x2="' + shaftX + '" y2="' + shaftTop + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="butt"/>');

    if (rounded >= 5) {
        while (rounded >= 50) {
            markerTop = Math.min(markerTop, barbY);
            parts.push('<polygon points="' + shaftX + ',' + barbY + ' ' + shaftX + ',' + (barbY + pennantHeight) + ' ' + (shaftX + pennantLen) + ',' + (barbY + (pennantHeight / 2)) + '" fill="' + color + '"/>');
            rounded -= 50;
            barbY += pennantHeight + pennantGap;
        }
        while (rounded >= 10) {
            var barbTipY = barbY - barbRise;
            markerTop = Math.min(markerTop, barbTipY - (stroke / 2));
            parts.push('<line x1="' + shaftX + '" y1="' + barbY + '" x2="' + (shaftX + barbLen) + '" y2="' + barbTipY + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="round"/>');
            rounded -= 10;
            barbY += barbStep;
        }
        if (rounded >= 5) {
            var halfBarbTipY = barbY - (barbRise * 0.55);
            markerTop = Math.min(markerTop, halfBarbTipY - (stroke / 2));
            parts.push('<line x1="' + shaftX + '" y1="' + barbY + '" x2="' + (shaftX + barbLen * 0.55) + '" y2="' + halfBarbTipY + '" stroke="' + color + '" stroke-width="' + stroke + '" stroke-linecap="round"/>');
        }
    }

    var viewBoxY = Math.floor(Math.min(0, markerTop - 4));
    var viewBoxHeight = 100 - viewBoxY;

    return '<svg class="windbarb-svg" viewBox="0 ' + viewBoxY + ' 100 ' + viewBoxHeight + '" aria-hidden="true" focusable="false">' + parts.join("") + '</svg>';
}

var live_wind_compass_state = {
    windSpeedKnots: null,
    windGustKnots: null,
    direction: null,
};

function parse_wind_compass_knots(knots) {
    var value = parseFloat(knots);

    return isFinite(value) ? value : null;
}

function wind_compass_is_calm(windSpeedKnots, windGustKnots) {
    var values = [
        parse_wind_compass_knots(windSpeedKnots),
        parse_wind_compass_knots(windGustKnots)
    ].filter(function(value) {
        return value !== null;
    });

    return values.length > 0 && values.every(function(value) {
        return value < wind_compass_calm_threshold_knots;
    });
}

function render_wind_compass_marker(direction, windSpeedKnots, windGustKnots) {
    var rotation = parseFloat(direction);
    var parsedWindSpeedKnots = parse_wind_compass_knots(windSpeedKnots);
    var parsedWindGustKnots = parse_wind_compass_knots(windGustKnots);
    var selectedKnots = wind_compass_source == "windGust" ? parsedWindGustKnots : parsedWindSpeedKnots;
    var arrow = jQuery(".arrow");

    if (arrow.length === 0) {
        return;
    }

    // Calm wind: hide both indicator styles (triangle and windbarb).
    if (wind_compass_is_calm(windSpeedKnots, windGustKnots)) {
        arrow.removeClass("windbarb-marker").addClass("wind-compass-marker--hidden").empty().css("visibility", "hidden");
        jQuery(".wind-arrow").addClass("wind-compass-marker--hidden").css("visibility", "hidden");
        return;
    }

    if (!isFinite(rotation)) {
        return;
    }

    // Wind is not calm: ensure indicators are visible.
    arrow.removeClass("wind-compass-marker--hidden").css("visibility", "visible");
    jQuery(".wind-arrow").removeClass("wind-compass-marker--hidden").css("visibility", "visible");

    if (wind_compass_marker == "windbarb") {
        arrow.addClass("windbarb-marker");
        if (selectedKnots === null) {
            selectedKnots = parsedWindSpeedKnots !== null ? parsedWindSpeedKnots : parsedWindGustKnots;
        }
        var svg = build_windbarb_svg(selectedKnots);
        if (svg) {
            arrow.html(svg);
        } else {
            arrow.removeClass("windbarb-marker").empty();
        }
    } else {
        arrow.removeClass("windbarb-marker").empty();
    }

    rotateThis(rotation);
}

function initialize_wind_compass_marker(direction, windSpeedKnots, windGustKnots) {
    var parsedDirection = parseFloat(direction);
    var parsedWindSpeedKnots = parseFloat(windSpeedKnots);
    var parsedWindGustKnots = parseFloat(windGustKnots);
    var displayedWindSpeedKnots = displayed_wind_compass_knots("windSpeed");
    var displayedWindGustKnots = displayed_wind_compass_knots("windGust");

    if (isFinite(parsedDirection)) {
        live_wind_compass_state.direction = parsedDirection;
    }
    if (
        displayedWindSpeedKnots !== null &&
        (!isFinite(parsedWindSpeedKnots) || (
            parsedWindSpeedKnots < wind_compass_calm_threshold_knots &&
            displayedWindSpeedKnots >= wind_compass_calm_threshold_knots
        ))
    ) {
        parsedWindSpeedKnots = displayedWindSpeedKnots;
    }
    if (
        displayedWindGustKnots !== null &&
        (!isFinite(parsedWindGustKnots) || (
            parsedWindGustKnots < wind_compass_calm_threshold_knots &&
            displayedWindGustKnots >= wind_compass_calm_threshold_knots
        ))
    ) {
        parsedWindGustKnots = displayedWindGustKnots;
    }
    if (isFinite(parsedWindSpeedKnots)) {
        live_wind_compass_state.windSpeedKnots = parsedWindSpeedKnots;
    }
    if (isFinite(parsedWindGustKnots)) {
        live_wind_compass_state.windGustKnots = parsedWindGustKnots;
    }

    render_wind_compass_marker(
        live_wind_compass_state.direction,
        live_wind_compass_state.windSpeedKnots,
        live_wind_compass_state.windGustKnots
    );
}

function update_wind_compass_marker(payload) {
    var direction = payload.hasOwnProperty("windDir") ? parseFloat(payload["windDir"]) : live_wind_compass_state.direction;
    var windSpeedKnots = knots_from_mqtt_payload(payload, "windSpeed");
    var windGustKnots = knots_from_mqtt_payload(payload, "windGust");

    if (windSpeedKnots === null || !isFinite(windSpeedKnots)) {
        windSpeedKnots = displayed_wind_compass_knots("windSpeed");
    }
    if (windSpeedKnots === null || !isFinite(windSpeedKnots)) {
        windSpeedKnots = live_wind_compass_state.windSpeedKnots;
    }
    if (windGustKnots === null || !isFinite(windGustKnots)) {
        windGustKnots = displayed_wind_compass_knots("windGust");
    }
    if (windGustKnots === null || !isFinite(windGustKnots)) {
        windGustKnots = live_wind_compass_state.windGustKnots;
    }

    if (!isFinite(direction)) {
        direction = live_wind_compass_state.direction;
    }

    if (isFinite(direction)) {
        live_wind_compass_state.direction = direction;
    }
    live_wind_compass_state.windSpeedKnots = windSpeedKnots;
    live_wind_compass_state.windGustKnots = windGustKnots;

    render_wind_compass_marker(direction, windSpeedKnots, windGustKnots);
}

function highcharts_tooltip_factory(obsvalue, point_obsType, highchartsReturn = false, rounding, mirrored = false, numberFormat) {
    // Mirrored values have the negative sign removed
    if (mirrored) {
        obsvalue = Math.abs(obsvalue);
    }

    if (point_obsType == "windDir") {
        // Map degrees to one of 16 compass sectors via arithmetic (replaces 17-branch if-else)
        const ordinal = ORDINATE_NAMES[Math.round(obsvalue / 22.5) % 16];

        // highchartsReturn returns the full wind direction string for highcharts tooltips. e.g "NNW (337)"
        if (highchartsReturn) {
            output = ordinal + " (" + Math.round(obsvalue) + "\xBA)";
        } else {
            output = ordinal;
        }
    } else {
        try {
            // Setup any charts.conf overrides on formatting
            var {decimals, decimalPoint, thousandsSep} = numberFormat;

            // Try to apply the highcharts numberFormat for locale awareness. Use rounding from weewx.conf StringFormats.
            // -1 is set from Python to notate no rounding data available and decimals from charts.conf is undefined.
            if (rounding == "-1" && typeof decimals === "undefined") {
                output = Highcharts.numberFormat(obsvalue);
            } else {
                // If the amount of decimal is defined, use that instead since rounding is provided to the function.
                if (typeof decimals !== "undefined") {
                    rounding = decimals;
                }
                // If decimalPoint is undefined, use the auto detect from the skin since this comes from the skin.
                if (typeof decimalPoint === "undefined") {
                    decimalPoint = "$highcharts_decimal";
                }
                // If thousandsSep is undefined, use the auto detect from the skin since this comes from the skin.
                if (typeof thousandsSep === "undefined") {
                    thousandsSep = "$highcharts_thousands";
                }

                output = Highcharts.numberFormat(obsvalue, rounding, decimalPoint, thousandsSep);
            }
        } catch (err) {
            // Fall back to just returning the highcharts point number value, which is a best guess.
            output = Highcharts.numberFormat(obsvalue);
        }
    }

    return output;
}

// Handle wind arrow rotation with the ability to "rollover" past 0 
// without spinning back around. e.g 350 to 3 would normally spin back around
// https://stackoverflow.com/a/19872672/1177153
function rotateThis(newRotation) {
    if (newRotation == "N/A") {return;}
    belchertown_debug("rotateThis: rotating to " + newRotation);
    var currentRotation;
    finalRotation = finalRotation || 0; // if finalRotation undefined or 0, make 0, else finalRotation
    currentRotation = finalRotation % 360;
    if (currentRotation < 0) {currentRotation += 360;}
    if (currentRotation < 180 && (newRotation > (currentRotation + 180))) {finalRotation -= 360;}
    if (currentRotation >= 180 && (newRotation <= (currentRotation - 180))) {finalRotation += 360;}
    finalRotation += (newRotation - currentRotation);
    jQuery(".wind-arrow").css("transform", "rotate(" + finalRotation + "deg)");
    jQuery(".arrow").css("transform", "rotate(" + finalRotation + "deg)");
}

function almanacTrackXBounds() {
    return {
        minX: 0,
        maxX: 1440
    };
}

function almanacWrapDiagramX(xValue, xOffset) {
    var x = parseFloat(xValue);
    var offset = parseFloat(xOffset);
    var bounds = almanacTrackXBounds();
    var span = bounds.maxX - bounds.minX;

    if (!isFinite(x)) {
        return null;
    }
    if (!isFinite(offset)) {
        offset = 0;
    }
    if (!isFinite(span) || span <= 0) {
        return x;
    }

    return ((x - bounds.minX + offset) % span + span) % span + bounds.minX;
}

function almanacDiagramCenteringMode() {
    var diagramEl = jQuery(".almanac-diagram").first();
    var mode = String(diagramEl.attr("data-centering-mode") || diagramEl.data("centeringMode") || "off").toLowerCase();
    if (mode === "now" || mode === "transit") {
        return mode;
    }
    return "off";
}

function almanacBodyXOffsetInfo(bodyKey) {
    var diagramEl = jQuery(".almanac-diagram").first();
    var mode = almanacDiagramCenteringMode();
    var attrName = bodyKey === "moon" ? "data-moon-x-offset" : "data-sun-x-offset";
    var dataKey = bodyKey === "moon" ? "moonXOffset" : "sunXOffset";
    var attrRaw;
    var dataRaw;
    var parsed;

    if (mode === "off") {
        return { value: 0, hasExplicit: false };
    }

    attrRaw = diagramEl.attr(attrName);
    parsed = parseFloat(attrRaw);
    if (attrRaw !== undefined && attrRaw !== null && String(attrRaw).trim() !== "" && isFinite(parsed)) {
        return { value: parsed, hasExplicit: true };
    }

    dataRaw = diagramEl.data(dataKey);
    parsed = parseFloat(dataRaw);
    if (dataRaw !== undefined && dataRaw !== null && String(dataRaw).trim() !== "" && isFinite(parsed)) {
        return { value: parsed, hasExplicit: true };
    }

    return { value: 0, hasExplicit: false };
}

function almanacCurrentTimeToDiagramX(currentTs, currentX, fallbackCurrentX) {
    var explicitX = parseFloat(currentX);
    var fallbackX = parseFloat(fallbackCurrentX);
    var ts = parseFloat(currentTs);
    var adjusted;
    var dayMinutes;

    if (isFinite(explicitX)) {
        return Math.max(0, Math.min(1440, explicitX));
    }

    if (isFinite(ts) && typeof tzAdjustedMoment === "function") {
        adjusted = tzAdjustedMoment(ts);
        if (adjusted && typeof adjusted.isValid === "function" && adjusted.isValid()) {
            dayMinutes = (
                (parseInt(adjusted.format("H"), 10) * 60)
                + parseInt(adjusted.format("m"), 10)
                + (parseInt(adjusted.format("s"), 10) / 60)
            );
            if (isFinite(dayMinutes)) {
                return Math.max(0, Math.min(1440, dayMinutes));
            }
        }
    }

    if (isFinite(fallbackX)) {
        return Math.max(0, Math.min(1440, fallbackX));
    }

    return null;
}

function readAlmanacDiagramNumber(diagram, attrName, dataKey) {
    var attrValue = parseFloat(diagram.attr(attrName));
    var dataValue;

    if (isFinite(attrValue)) {
        return attrValue;
    }

    dataValue = parseFloat(diagram.data(dataKey));
    return isFinite(dataValue) ? dataValue : null;
}

function almanacExistingMarkerX(marker) {
    var transformText = String(marker.attr("transform") || "");
    var match = transformText.match(/translate\(\s*([-+]?\d*\.?\d+(?:e[-+]?\d+)?)/i);
    var parsed = match ? parseFloat(match[1]) : NaN;

    return isFinite(parsed) ? parsed : null;
}

function almanacVerticalScale() {
    var diagramEl = jQuery(".almanac-diagram").first();
    var scale = parseFloat(diagramEl.attr("data-vertical-scale") || diagramEl.data("verticalScale"));

    if (!isFinite(scale)) {
        return 2.5;
    }

    return Math.max(0, scale);
}

function almanacAltitudeToDiagramY(altitude) {
    var alt = parseFloat(altitude);
    if (!isFinite(alt)) {
        return null;
    }

    return -(Math.max(-90, Math.min(90, alt)) * almanacVerticalScale());
}

function almanacDiagramViewBox() {
    var xPadding = 120;
    var yPadding = 20;
    var scaledHalfHeight = (90 * almanacVerticalScale()) + yPadding;

    return {
        x: -xPadding,
        y: -scaledHalfHeight,
        width: 1440 + (xPadding * 2),
        height: scaledHalfHeight * 2
    };
}

function setAlmanacDiagramTrackBelowHorizon(selector, altitude) {
    var track = jQuery(selector);
    var alt = parseFloat(altitude);

    if (!track.length) {
        return;
    }

    track.toggleClass("is-below-horizon", isFinite(alt) && alt < 0);
}

function setAlmanacDiagramHorizonBounds() {
    var horizon = jQuery(".almanac-diagram-horizon");
    var xBounds = almanacTrackXBounds();

    if (!horizon.length) {
        return;
    }

    horizon
        .attr("x1", xBounds.minX.toFixed(1))
        .attr("x2", xBounds.maxX.toFixed(1));
}

function setAlmanacDiagramObject(selector, pathSelector, label, azimuth, altitude, currentTs, currentX) {
    var point = null;
    var bodyKey = selector.indexOf("--moon") !== -1 ? "moon" : "sun";
    var displayLabel = belchertown_decode_html_entities(label);
    var alt = parseFloat(altitude);
    var marker = jQuery(selector);
    var projectedX;
    var projectedY;
    var bodyOffsetInfo = almanacBodyXOffsetInfo(bodyKey);
    var bodyOffset = bodyOffsetInfo.value;

    if (!marker.length) {
        return;
    }

    // Python is authoritative for curve geometry. Marker position should be a
    // direct projection of live altitude at current time using the same x-offset.
    if (isFinite(alt)) {
        projectedX = almanacWrapDiagramX(almanacCurrentTimeToDiagramX(currentTs, currentX), bodyOffset);
        if (projectedX === null) {
            projectedX = almanacExistingMarkerX(marker);
        }
        projectedY = almanacAltitudeToDiagramY(alt);
        if (projectedX !== null && projectedY !== null) {
            point = {
                x: projectedX,
                y: projectedY,
                belowHorizon: alt < 0
            };
        }
    }

    if (!point) {
        if (isFinite(alt)) {
            marker.show();
            marker.find("title").text(displayLabel);
            return;
        }
        marker.hide();
        return;
    }

    marker
        .show()
        .attr("transform", "translate(" + point.x.toFixed(1) + " " + point.y.toFixed(1) + ")")
        .toggleClass("is-below-horizon", point.belowHorizon || (isFinite(alt) && alt < 0));

    marker.find("title").text(displayLabel);
}

function fitAlmanacDiagramViewBox(diagramData) {
    var svg = jQuery(".almanac-diagram-svg");

    if (!svg.length || !diagramData) {
        return;
    }

    // Python is authoritative for content-fit SVG framing and viewport sizing.
    // Keep preserveAspectRatio aligned with server markup (no stretching).
    svg.attr("preserveAspectRatio", "xMidYMid meet");
}

jQuery(window).on("load orientationchange", function() {
    initializeAlmanacDiagramFromDOM();
});

function renderAlmanacDiagram(diagramData, preserveViewBox) {
    var diagram = jQuery(".almanac-diagram");

    setAlmanacDiagramHorizonBounds();

    if (!diagram.length) {
        return;
    }

    if (!diagramData) {
        // Keep any already-rendered DOM diagram visible. Fresh JSON can be
        // briefly unavailable/stale on first load, especially on desktop.
        return;
    }

    // Ensure server-generated path geometry is available during live MQTT updates.
    if (!diagramData["sun"]) {
        diagramData["sun"] = {};
    }
    if (!diagramData["moon"]) {
        diagramData["moon"] = {};
    }

    // Keep DOM data-* and jQuery data cache in sync with the freshest values
    // so MQTT incremental updates don't fall back to stale template-time values.
    var sunAz = parseFloat(diagramData["sun"]["azimuth"]);
    var sunAlt = parseFloat(diagramData["sun"]["altitude"]);
    var moonAz = parseFloat(diagramData["moon"]["azimuth"]);
    var moonAlt = parseFloat(diagramData["moon"]["altitude"]);
    var sunXOffset = parseFloat(diagramData["sun"]["x_offset"]);
    var moonXOffset = parseFloat(diagramData["moon"]["x_offset"]);
    var centeringMode = String(diagramData["centering_mode"] || "off").toLowerCase();
    var currentTs = parseFloat(diagramData["current_ts"]);
    var currentX = parseFloat(diagramData["current_x"]);
    var fallbackCurrentX = readAlmanacDiagramNumber(diagram, "data-current-x", "currentX");
    var resolvedCurrentX;

    if (!isFinite(currentTs)) {
        currentTs = readAlmanacDiagramNumber(diagram, "data-current-ts", "currentTs");
    }
    resolvedCurrentX = almanacCurrentTimeToDiagramX(currentTs, currentX, fallbackCurrentX);

    if (isFinite(sunAz)) {
        diagram.attr("data-sun-az", sunAz.toFixed(3));
        diagram.data("sunAz", sunAz);
    }
    if (isFinite(sunAlt)) {
        diagram.attr("data-sun-alt", sunAlt.toFixed(3));
        diagram.data("sunAlt", sunAlt);
    }
    if (isFinite(moonAz)) {
        diagram.attr("data-moon-az", moonAz.toFixed(3));
        diagram.data("moonAz", moonAz);
    }
    if (isFinite(moonAlt)) {
        diagram.attr("data-moon-alt", moonAlt.toFixed(3));
        diagram.data("moonAlt", moonAlt);
    }
    if (isFinite(sunXOffset)) {
        diagram.attr("data-sun-x-offset", sunXOffset.toFixed(3));
        diagram.data("sunXOffset", sunXOffset);
    }
    if (isFinite(moonXOffset)) {
        diagram.attr("data-moon-x-offset", moonXOffset.toFixed(3));
        diagram.data("moonXOffset", moonXOffset);
    }
    if (centeringMode === "now" || centeringMode === "transit") {
        diagram.attr("data-centering-mode", centeringMode);
        diagram.data("centeringMode", centeringMode);
    } else {
        diagram.attr("data-centering-mode", "off");
        diagram.data("centeringMode", "off");
    }
    if (isFinite(currentTs)) {
        diagram.attr("data-current-ts", currentTs.toFixed(3));
        diagram.data("currentTs", currentTs);
    }
    if (isFinite(resolvedCurrentX)) {
        diagram.attr("data-current-x", resolvedCurrentX.toFixed(3));
        diagram.data("currentX", resolvedCurrentX);
    }

    diagram.removeClass("almanac-diagram--inactive");

    // Python-authored SVG curves are authoritative. JS must never rewrite path d.
    // Keep only dynamic state classes in sync during live updates.
    setAlmanacDiagramTrackBelowHorizon(".almanac-diagram-track--sun", diagramData && diagramData["sun"] && diagramData["sun"]["altitude"]);
    setAlmanacDiagramTrackBelowHorizon(".almanac-diagram-track--moon", diagramData && diagramData["moon"] && diagramData["moon"]["altitude"]);

    if (!jQuery(".almanac-diagram-track--sun, .almanac-diagram-track--moon").length) {
        setAlmanacDiagramTrackBelowHorizon(".almanac-diagram-track", diagramData && diagramData["sun"] && diagramData["sun"]["altitude"]);
    }

    setAlmanacDiagramObject(
        ".almanac-diagram-object--sun",
        ".almanac-diagram-track--sun",
        "$obs.label.sun",
        diagramData["sun"]["azimuth"],
        diagramData["sun"]["altitude"],
        currentTs,
        resolvedCurrentX
    );
    setAlmanacDiagramObject(
        ".almanac-diagram-object--moon",
        ".almanac-diagram-track--moon",
        "$obs.label.moon",
        diagramData["moon"]["azimuth"],
        diagramData["moon"]["altitude"],
        currentTs,
        resolvedCurrentX
    );

    if (!preserveViewBox) {
        fitAlmanacDiagramViewBox(diagramData);
    }
}

function initializeAlmanacDiagramFromDOM() {
    var diagram = jQuery(".almanac-diagram");

    if (!diagram.length) {
        return;
    }

    var readNumericAttr = function(attrName, dataKey) {
        var attrRaw = diagram.attr(attrName);
        var attrParsed = parseFloat(attrRaw);
        if (isFinite(attrParsed)) {
            return attrParsed;
        }

        var dataParsed = parseFloat(diagram.data(dataKey));
        if (isFinite(dataParsed)) {
            return dataParsed;
        }

        return null;
    };

    renderAlmanacDiagram({
        hasExtras: true,
        sun: {
            azimuth: readNumericAttr("data-sun-az", "sunAz"),
            altitude: readNumericAttr("data-sun-alt", "sunAlt"),
            x_offset: readNumericAttr("data-sun-x-offset", "sunXOffset")
        },
        moon: {
            azimuth: readNumericAttr("data-moon-az", "moonAz"),
            altitude: readNumericAttr("data-moon-alt", "moonAlt"),
            x_offset: readNumericAttr("data-moon-x-offset", "moonXOffset")
        },
        centering_mode: String(diagram.attr("data-centering-mode") || diagram.data("centeringMode") || "off").toLowerCase(),
        current_ts: readNumericAttr("data-current-ts", "currentTs"),
        current_x: readNumericAttr("data-current-x", "currentX")
    });
}

function getPreferredColorSchemeTheme() {
    if (typeof window.matchMedia !== "function") {
        return null;
    }

    try {
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
        }
        if (window.matchMedia("(prefers-color-scheme: light)").matches) {
            return "light";
        }
    } catch (err) {
        belchertown_debug("Auto theme: prefers-color-scheme check failed: " + err);
    }

    return null;
}

function watchPreferredColorSchemeTheme() {
    if (belchertownAutoThemeMediaListenerAttached || typeof window.matchMedia !== "function") {
        return;
    }

    try {
        belchertownAutoThemeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        var themePreferenceChanged = function(event) {
            if (sessionStorage.getItem('theme') !== "auto") {
                belchertown_debug("Auto theme: system color-scheme changed, but auto theme is not active.");
                return;
            }

            var preferredTheme = event.matches ? "dark" : "light";
            belchertown_debug("Auto theme: system color-scheme changed to " + preferredTheme);
            changeTheme(preferredTheme);
        };

        if (typeof belchertownAutoThemeMediaQuery.addEventListener === "function") {
            belchertownAutoThemeMediaQuery.addEventListener("change", themePreferenceChanged);
            belchertownAutoThemeMediaListenerAttached = true;
        } else if (typeof belchertownAutoThemeMediaQuery.addListener === "function") {
            belchertownAutoThemeMediaQuery.addListener(themePreferenceChanged);
            belchertownAutoThemeMediaListenerAttached = true;
        }
    } catch (err) {
        belchertown_debug("Auto theme: unable to watch prefers-color-scheme changes: " + err);
    }
}

function getSunriseSunsetTheme(sunset_hour, sunset_min, sunrise_hour, sunrise_min) {
    var sunriseHour = parseInt(sunrise_hour, 10);
    var sunriseMinute = parseInt(sunrise_min, 10);
    var sunsetHour = parseInt(sunset_hour, 10);
    var sunsetMinute = parseInt(sunset_min, 10);

    if (!isFinite(sunriseHour) || !isFinite(sunsetHour)) {
        belchertown_debug("Auto theme: sunrise/sunset fallback is unavailable.");
        return null;
    }
    if (!isFinite(sunriseMinute)) {
        sunriseMinute = 0;
    }
    if (!isFinite(sunsetMinute)) {
        sunsetMinute = 0;
    }

    var d = new Date();
    var nowMinutes = (d.getHours() * 60) + d.getMinutes();
    var sunriseMinutes = (sunriseHour * 60) + sunriseMinute;
    var sunsetMinutes = (sunsetHour * 60) + sunsetMinute;
    var dayTime;

    if (sunriseMinutes === sunsetMinutes) {
        belchertown_debug("Auto theme: sunrise/sunset fallback has matching rise and set times.");
        return null;
    } else if (sunriseMinutes < sunsetMinutes) {
        dayTime = sunriseMinutes <= nowMinutes && nowMinutes < sunsetMinutes;
    } else {
        dayTime = nowMinutes >= sunriseMinutes || nowMinutes < sunsetMinutes;
    }

    belchertown_debug("Auto theme: sunrise: " + sunriseHour + ":" + sunriseMinute);
    belchertown_debug("Auto theme: now minutes: " + nowMinutes);
    belchertown_debug("Auto theme: sunset: " + sunsetHour + ":" + sunsetMinute);
    belchertown_debug("Auto theme: are we in daylight hours: " + dayTime);

    return dayTime ? "light" : "dark";
}

function applyAutoThemeChoice(themeName, reason) {
    belchertown_debug("Auto theme: sessionStorage.getItem('theme') = " + sessionStorage.getItem('theme'));

    if (sessionStorage.getItem('theme') == "auto") {
        belchertown_debug("Auto theme: setting " + themeName + " theme from " + reason);
        changeTheme(themeName);
        return true;
    }

    belchertown_debug("Auto theme: cannot set " + themeName + " theme since visitor used toggle to override theme. Refresh to reset the override.");
    return false;
}

function autoTheme(sunset_hour, sunset_min, sunrise_hour, sunrise_min) {
    // First check if ?theme= is in URL. If so, bail out and do not change anything.
    const themeParam = getURLvar("theme");
    if (themeParam && themeParam !== "auto") {
        belchertown_debug("Auto theme: theme override detected in URL. Skipping auto theme");
        return true;
    }
    belchertown_debug("Auto theme: checking to see if theme needs to be switched");

    var preferredTheme = getPreferredColorSchemeTheme();
    if (preferredTheme) {
        belchertown_debug("Auto theme: using prefers-color-scheme: " + preferredTheme);
        watchPreferredColorSchemeTheme();
        return applyAutoThemeChoice(preferredTheme, "browser color-scheme preference");
    }

    belchertown_debug("Auto theme: prefers-color-scheme unavailable. Falling back to sunrise/sunset.");
    var fallbackTheme = getSunriseSunsetTheme(sunset_hour, sunset_min, sunrise_hour, sunrise_min);
    if (!fallbackTheme) {
        return false;
    }

    return applyAutoThemeChoice(fallbackTheme, "sunrise/sunset fallback");
}

function ensureDarkThemeStylesheet() {
    if (document.getElementById("belchertownDarkStyle")) {
        return;
    }

    var darkStylesheet = document.createElement("link");
    darkStylesheet.id = "belchertownDarkStyle";
    darkStylesheet.rel = "stylesheet";
    darkStylesheet.type = "text/css";
    darkStylesheet.media = "all";
    darkStylesheet.href = get_relative_url() + "/new-belchertown-dark.min.css?ver=$belchertown_version";
    document.head.appendChild(darkStylesheet);
}

function changeTheme(themeName, toggleOverride = false) {
    belchertown_debug("Theme: Changing to " + themeName);
    // If the configured theme is auto, but the user toggles light/dark, remove the auto option.
    if (toggleOverride) {
        belchertown_debug("Theme: toggle override clicked.");
        belchertown_debug("Theme: sessionStorage.getItem('theme') was previously: " + sessionStorage.getItem('theme'));
        // This was applied only to auto theme config, but now it's applied to all themes so visitor has full control on light/dark mode
        //if ( sessionStorage.getItem('theme') == "auto" ) { }
        sessionStorage.setItem('theme', 'toggleOverride');
        belchertown_debug("Theme: sessionStorage.getItem('theme') is now: " + sessionStorage.getItem('theme'));
    }
    if (themeName == "dark") {
        ensureDarkThemeStylesheet();
        // Apply dark theme
        // #if $radar_html_dark != "None"
        jQuery('.radar_image').html('$radar_html_dark');
        belchertown_schedule_deferred_iframes(document.querySelector(".radar_image"), 100);
        // #end if
        jQuery('body').addClass("dark");
        jQuery('body').removeClass("light");
        // #if $Extras.has_key('theme_toggle_enabled') and $Extras.theme_toggle_enabled == '1'
        jQuery("#themeSwitch").prop("checked", true);
        // #end if
        // #if $Extras.has_key('logo_image_dark') and $Extras.logo_image_dark != ""
        belchertown_debug("Theme: logo_image_dark is defined.");
        jQuery("#logo_image").attr("src", "$Extras.logo_image_dark");
        // #end if
        sessionStorage.setItem('currentTheme', 'dark');
    } else if (themeName == "light") {
        // Apply light theme
        // #if $radar_html_dark != "None"
        jQuery('.radar_image').html('$radar_html');
        belchertown_schedule_deferred_iframes(document.querySelector(".radar_image"), 100);
        // #end if
        jQuery('body').addClass("light");
        jQuery('body').removeClass("dark");
        // #if $Extras.has_key('theme_toggle_enabled') and $Extras.theme_toggle_enabled == '1'
        jQuery("#themeSwitch").prop("checked", false);
        // #end if
        // #if $Extras.has_key('logo_image') and $Extras.logo_image != ""
        belchertown_debug("Theme: logo_image is defined.");
        jQuery("#logo_image").attr("src", "$Extras.logo_image");
        // #end if
        sessionStorage.setItem('currentTheme', 'light');
    }
}

async function ajaxweewx() {
    var url = get_relative_url() + "/json/weewx_data.json";
    var resp = await fetch(url, {cache: "no-cache"});
    if (!resp.ok) {
        throw new Error("HTTP error! Unable to load weewx_data.json");
    } else {
        return await resp.json();
    }
}

