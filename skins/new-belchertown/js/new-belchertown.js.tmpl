    jQuery(".dailystatswindavg").html(getNestedValue(d, ["wind", "average"]));
    jQuery(".dailystatswindmax").html(getNestedValue(d, ["wind", "max"]));
    jQuery(".dailystatsrain").html(getNestedValue(d, ["rain", "sum"]));
    jQuery(".dailystatsrainrate").html(getNestedValue(d, ["rain", "max"]));
    jQuery(".dailystatsuvavg").html(getNestedValue(d, ["uv", "average"]));
    jQuery(".dailystatsuvmax").html(getNestedValue(d, ["uv", "max"]));
    jQuery(".dailystatsradiationavg").html(getNestedValue(d, ["solar_radiation", "average"]));
    jQuery(".dailystatsradiationmax").html(getNestedValue(d, ["solar_radiation", "max"]));
    jQuery(".dailystatssunshineDur").html(getNestedValue(d, ["sunshineDur", "sum"]));
    if (d["wind"] && d["wind"]["windrun"]) {
        jQuery(".dailywindrun").html(d["wind"]["windrun"]);
