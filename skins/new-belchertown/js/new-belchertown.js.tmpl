    jQuery(".monthstatsuvavg").html(getNestedValue(d, ["uv", "average"]));
    jQuery(".monthstatsuvmax").html(getNestedValue(d, ["uv", "max"]));
    jQuery(".monthstatsradiationavg").html(getNestedValue(d, ["solar_radiation", "average"]));
    jQuery(".monthstatsradiationmax").html(getNestedValue(d, ["solar_radiation", "max"]));
}

