var weatherdirection = $charts_windDir_ordinals_label;

// Pre-built array of 16 compass ordinals for arithmetic wind-direction lookup
const ORDINATE_NAMES = [
    "$ordinate_names[0]",  // N
    "$ordinate_names[1]",  // NNE
    "$ordinate_names[2]",  // NE
    "$ordinate_names[3]",  // ENE
    "$ordinate_names[4]",  // E
