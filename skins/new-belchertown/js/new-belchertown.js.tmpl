/*
Cheetah template code starts with #. 
That code is commented out in this file so that code
editors can error check and format the JavaScript.
Code that starts with # is evaluated by the Cheetah
generator even if within a comment. 

#encoding "UTF-8"
#import datetime

#if "-" in str($station.stn_info.latitude_f)
#set global $hemisphere = "southern-hemisphere"
#else
#set global $hemisphere = "northern-hemisphere"
#end if

#set global $sunset_hour = "null"
#set global $sunset_minute = "null"
#set global $sunrise_hour = "null"
#set global $sunrise_minute = "null"
#if $almanac.sunrise.raw is not None and $almanac.sunset.raw is not None
#set global $sunset_hour = datetime.datetime.fromtimestamp($almanac.sunset.raw).strftime('%-H')
#set global $sunset_minute = datetime.datetime.fromtimestamp($almanac.sunset.raw).strftime('%-M')
#set global $sunrise_hour = datetime.datetime.fromtimestamp($almanac.sunrise.raw).strftime('%-H')
#set global $sunrise_minute = datetime.datetime.fromtimestamp($almanac.sunrise.raw).strftime('%-M')
#end if

#set global $moon_tilt_template_value = "null"
#try
#set $moon_tilt_template_value = "%.6f" % float($almanac.moon.moon_tilt.raw)
#except
#set $moon_tilt_template_value = "null"
#end try
*/

// Determine if debug is on via URL var or config setting
if (getURLvar("debug") && (getURLvar("debug") == "true" || getURLvar("debug") == "1")) {
    var belchertown_debug_config = true;
    belchertown_debug("Debug: URL debug variable enabled");
} else {
    var belchertown_debug_config = $belchertown_debug;
    belchertown_debug("Debug: skin.conf belchertown_debug enabled");
}

var moment_locale = "$moment_locale_js";
moment.locale(moment_locale);

var chartgroups_raw = $charts;
var chartgroups_titles = $chartpage_titles;
var chartpage_content = $chartpage_content;
var moon_tilt_template_value = $moon_tilt_template_value;
var belchertownAutoThemeMediaListenerAttached = false;
var belchertownAutoThemeMediaQuery = null;
var belchertownWindyRadarResizeTimer = null;
var belchertownWindyRadarViewportWidth = null;
var belchertownWebcamReloadTimers = [];

function belchertown_radar_tab_containers() {
    return jQuery(".belchertown-radar-tabs").add("#tabs-container").filter(function() {
        return jQuery(this).find(".tabs-menu a").length && jQuery(this).find(".belchertown-radar-tab-panel").length;
    });
}

function belchertown_activate_radar_tab(tabLink, animate) {
    var link = jQuery(tabLink);
    var container = link.closest(".belchertown-radar-tabs");
    var activeTab = link.attr("href");

    if (!container.length) {
        container = link.closest("#tabs-container");
    }
    if (!container.length || !activeTab || activeTab.charAt(0) !== "#") {
        return;
    }

    var activePanel = container.find(activeTab);
    if (!activePanel.length) {
        activePanel = jQuery(activeTab);
    }
    if (!activePanel.length) {
        return;
    }

    link.parent().addClass("active");
    link.parent().siblings().removeClass("active");
    container.find(".belchertown-radar-tab-panel").not(activePanel).removeClass("is-active").hide();
    activePanel.addClass("is-active");
    if (animate === false) {
        activePanel.show();
    } else {
        activePanel.fadeIn();
    }

    belchertown_schedule_windy_radar_scale(document, true);
}

function belchertown_initialize_radar_tabs() {
    belchertown_radar_tab_containers().each(function() {
        var container = jQuery(this);
        var activeLink = container.find(".tabs-menu li.active a").first();
        var activePanel = container.find(".belchertown-radar-tab-panel.is-active").first();

        if (!activeLink.length && activePanel.length && activePanel.attr("id")) {
            activeLink = container.find('.tabs-menu a[href="#' + activePanel.attr("id") + '"]').first();
        }
        if (!activeLink.length) {
            activeLink = container.find(".tabs-menu a").first();
        }
        if (activeLink.length) {
            belchertown_activate_radar_tab(activeLink, false);
        }
    });
}

function belchertown_webcam_reload_interval(container) {
    var interval = parseInt(jQuery(container).attr("data-webcam-reload-interval-ms"), 10);

    if (isNaN(interval)) {
        return 300000;
    }

    return interval;
}

function belchertown_reload_webcam_images(container) {
    var containers = container ? jQuery(container) : belchertown_radar_tab_containers();

    containers.find("#webcam img").each(function() {
        var image = jQuery(this);
        var imageUrl = image.attr("src");

        if (!imageUrl) {
            return;
        }

        image.attr("src", imageUrl.split("?")[0] + "?" + Math.floor(Math.random() * 999999999));
    });
}

// ---- Forecast icon helpers (Dark Sky-style icon names) ----
const DS_ICON_TO_W34 = {
    'clear-day': 'clear-day',
    'clear-night': 'clear-night',
    'mostly-clear-day': 'mostly-clear-day',
    'mostly-clear-night': 'mostly-clear-night',
    'partly-cloudy-day': 'partly-cloudy-day',
    'partly-cloudy-night': 'partly-cloudy-night',
    'mostly-cloudy-day': 'mostly-cloudy-day',
    'mostly-cloudy-night': 'mostly-cloudy-night',
    'cloudy': 'cloudy',
    'rain': 'rain',
    'sleet': 'sleet',
    'snow': 'snow',
    'wind': 'wind',
    'windy': 'windy',
    'fog': 'fog',
    'hail': 'sleet',
    'thunderstorm': 'thunderstorm',
    'tornado': 'wind'
};

/*
Resolve an icon name to the Weather34 icon base (without .png).
- Normalized forecast JSON uses Dark Sky-style names -> DS_ICON_TO_W34 map
 */

function resolveIconForProvider(iconRaw, provider) {
    const raw = String(iconRaw || '');
    const normalized = raw.trim();

    if (provider === 'pirateweather') {
        // Pirate Weather uses Dark Sky–style identifiers like "partly-cloudy-day"
        const key = normalized.toLowerCase(); // DS mapping is lowercase keys
        const mapped = DS_ICON_TO_W34[key];
        if (mapped) {
            return mapped;
        }
    } else {
        const key = normalized.toLowerCase();
        if (DS_ICON_TO_W34[key]) {
            return DS_ICON_TO_W34[key];
        }
    }

    let token = normalized
        .split('?')[0]
        .split('/')
        .pop()
        .split(',')[0]
        .trim()
        .toLowerCase()
        .replace(/-/g, '_')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');

    if (!token) {
        return 'unknown';
    }

    let isDaytime = !normalized.toLowerCase().includes('/night/');
    if (normalized.toLowerCase().includes('/day/')) {
        isDaytime = true;
    }
    if (token.charAt(0) === 'n' && token.length > 1) {
        isDaytime = false;
    } else if (token.charAt(0) === 'd' && token.length > 1) {
        isDaytime = true;
    }

    const dayNight = function(dayIcon, nightIcon) {
        return isDaytime ? dayIcon : nightIcon;
    };

    const nwsIconMap = {
        'skc': dayNight('clear-day', 'clear-night'),
        'clear': dayNight('clear-day', 'clear-night'),
        'mostly_clear': dayNight('mostly-clear-day', 'mostly-clear-night'),
        'sunny': 'clear-day',
        'mostly_sunny': 'mostly-clear-day',
        'fair': dayNight('mostly-clear-day', 'mostly-clear-night'),
        'few': dayNight('mostly-clear-day', 'mostly-clear-night'),
        'few_clouds': dayNight('mostly-clear-day', 'mostly-clear-night'),
        'a_few_clouds': dayNight('mostly-clear-day', 'mostly-clear-night'),
        'sct': dayNight('partly-cloudy-day', 'partly-cloudy-night'),
        'scattered_clouds': dayNight('partly-cloudy-day', 'partly-cloudy-night'),
        'partly_cloudy': dayNight('partly-cloudy-day', 'partly-cloudy-night'),
        'partly_sunny': 'partly-cloudy-day',
        'bkn': dayNight('mostly-cloudy-day', 'mostly-cloudy-night'),
        'mostly_cloudy': dayNight('mostly-cloudy-day', 'mostly-cloudy-night'),
        'ovc': 'cloudy',
        'overcast': 'cloudy',
        'cloudy': 'cloudy',
        'wind_skc': 'wind',
        'wind_few': 'wind',
        'wind_sct': 'wind',
        'wind_bkn': 'wind',
        'wind_ovc': 'wind',
        'rain': 'rain',
        'ra': 'rain',
        'light_rain': 'rain',
        'heavy_rain': 'rain',
        'rain_fog_mist': 'rain',
        'drizzle': 'rain',
        'light_drizzle': 'rain',
        'shra': 'rain',
        'shwrs': 'rain',
        'hi_shwrs': 'rain',
        'rain_showers': 'rain',
        'rain_showers_hi': 'rain',
        'rain_showers_sct': 'rain',
        'rain_snow': 'sleet',
        'rain_sleet': 'sleet',
        'rain_fzra': 'sleet',
        'tsra': 'thunderstorm',
        'thunderstorm': 'thunderstorm',
        'thunderstorms': 'thunderstorm',
        'tsra_sct': 'thunderstorm',
        'tsra_hi': 'thunderstorm',
        'hi_tsra': 'thunderstorm',
        'snow': 'snow',
        'sn': 'snow',
        'light_snow': 'snow',
        'heavy_snow': 'snow',
        'blizzard': 'snow',
        'snow_sleet': 'sleet',
        'snow_fzra': 'sleet',
        'sleet': 'sleet',
        'fzra': 'sleet',
        'freezing_rain': 'sleet',
        'ip': 'sleet',
        'ice_pellets': 'sleet',
        'mix': 'sleet',
        'hail': 'sleet',
        'fg': 'fog',
        'fog': 'fog',
        'fog_mist': 'fog',
        'mist': 'fog',
        'smoke': 'fog',
        'haze': 'fog',
        'dust': 'fog',
        'tornado': 'wind',
        'hurricane': 'wind',
        'tropical_storm': 'wind',
        'breezy': 'wind',
        'windy': 'wind',
        'hot': 'clear-day',
        'cold': dayNight('clear-day', 'clear-night')
    };

    if (nwsIconMap[token]) {
        return nwsIconMap[token];
    }

    if (token.length > 1 && (token.charAt(0) === 'd' || token.charAt(0) === 'n')) {
        const unprefixed = token.substring(1);
        if (nwsIconMap[unprefixed]) {
            return nwsIconMap[unprefixed];
        }
    }

    if (token.includes('tsra') || token.includes('thunder')) {
        return 'thunderstorm';
    }
    if (token.includes('sleet') || token.includes('fzra') || token.includes('ice')) {
        return 'sleet';
    }
    if (token.includes('snow') || token.includes('blizzard')) {
        return 'snow';
    }
    if (token.includes('rain') || token === 'ra' || token === 'shra' || token.includes('shwrs') || token.includes('drizzle')) {
        return 'rain';
    }
    if (token.includes('fog') || token.includes('fg') || token.includes('smoke') || token.includes('haze') || token.includes('dust')) {
        return 'fog';
    }
    if (token.includes('wind') || token.includes('hurricane') || token.includes('tropical') || token.includes('tornado')) {
        return 'wind';
    }
    if (token.includes('partly')) {
        return dayNight('partly-cloudy-day', 'partly-cloudy-night');
    }
    if (token.includes('mostly_cloudy')) {
        return dayNight('mostly-cloudy-day', 'mostly-cloudy-night');
    }
    if (token.includes('ovc') || token.includes('cloudy')) {
        return 'cloudy';
    }
    if (token.includes('bkn')) {
        return dayNight('mostly-cloudy-day', 'mostly-cloudy-night');
    }
    if (token.includes('sct')) {
        return dayNight('partly-cloudy-day', 'partly-cloudy-night');
    }
    if (token.includes('few')) {
        return dayNight('mostly-clear-day', 'mostly-clear-night');
    }
    if (token.includes('mostly_clear') || token.includes('mostly_sunny')) {
        return dayNight('mostly-clear-day', 'mostly-clear-night');
    }
    if (token.includes('skc') || token.includes('clear') || token.includes('sunny') || token.includes('fair')) {
        return dayNight('clear-day', 'clear-night');
    }

    return 'unknown';
}

function belchertown_debug(message) {
    if (belchertown_debug_config > 0) {
        console.log(message);
    }
}

function belchertown_load_deferred_iframes(root) {
    var scope = (root && root.querySelectorAll) ? root : document;
    var frames = scope.querySelectorAll("iframe[data-src]");

    frames.forEach(function(frame) {
        var src = frame.getAttribute("data-src");
        if (!src) {
            return;
        }

        frame.setAttribute("src", src);
        frame.removeAttribute("data-src");
    });

    belchertown_scale_windy_radar_iframes(scope);
}

function belchertown_parse_radar_dimension(value) {
    var parsed = parseFloat(String(value || "").replace("px", ""));
    return isFinite(parsed) && parsed > 0 ? parsed : null;
}

function belchertown_windy_radar_src(frame) {
    return frame.getAttribute("src") || frame.getAttribute("data-src") || "";
}

function belchertown_windy_radar_container(frame) {
    if (frame.closest) {
        return frame.closest(".radar_image") || frame.parentElement;
    }

    var node = frame.parentElement;
    while (node) {
        if (node.className && String(node.className).indexOf("radar_image") !== -1) {
            return node;
        }
        node = node.parentElement;
    }

    return frame.parentElement;
}

function belchertown_clear_windy_radar_scale(frame, container) {
    if (container) {
        if (container.classList) {
            container.classList.remove("radar_image--scaled-frame");
        }
        container.style.removeProperty("--radar-frame-display-height");
    }

    frame.style.removeProperty("width");
    frame.style.removeProperty("height");
    frame.style.removeProperty("max-width");
    frame.style.removeProperty("min-height");
    frame.style.removeProperty("transform");
    frame.style.removeProperty("transform-origin");
}

function belchertown_windy_radar_original_src(frame) {
    var originalSrc = frame.getAttribute("data-radar-original-src");
    var currentSrc = belchertown_windy_radar_src(frame);

    if (!originalSrc && currentSrc) {
        originalSrc = currentSrc;
        frame.setAttribute("data-radar-original-src", originalSrc);
    }

    return originalSrc || currentSrc;
}

function belchertown_windy_radar_zoomed_src(src, zoomOffset) {
    try {
        var url = new URL(src, window.location.href);
        var zoom = parseFloat(url.searchParams.get("zoom"));
        if (!isFinite(zoom)) {
            return src;
        }

        url.searchParams.set("zoom", String(Math.max(0, zoom + zoomOffset)));
        return url.toString();
    } catch (e) {
        return src;
    }
}

function belchertown_set_windy_radar_mobile_zoom(frame, enabled) {
    var originalSrc = belchertown_windy_radar_original_src(frame);
    if (!originalSrc) {
        return;
    }

    var targetSrc = enabled
        ? belchertown_windy_radar_zoomed_src(originalSrc, 1)
        : originalSrc;
    var srcAttribute = frame.getAttribute("data-src") ? "data-src" : "src";

    if (frame.getAttribute(srcAttribute) !== targetSrc) {
        frame.setAttribute(srcAttribute, targetSrc);
    }
}

function belchertown_scale_windy_radar_iframes(root) {
    var scope = (root && root.querySelectorAll) ? root : document;
    var frames = scope.querySelectorAll(".radar_image iframe");

    frames.forEach(function(frame) {
        var src = belchertown_windy_radar_src(frame);
        if (src.indexOf("embed.windy.com") === -1) {
            return;
        }

        var container = belchertown_windy_radar_container(frame);
        if (!container) {
            return;
        }

        var shouldScaleForMobile = window.matchMedia
            ? window.matchMedia("(max-width: 800px)").matches
            : window.innerWidth <= 800;
        if (!shouldScaleForMobile) {
            belchertown_set_windy_radar_mobile_zoom(frame, false);
            belchertown_clear_windy_radar_scale(frame, container);
            return;
        }
        belchertown_set_windy_radar_mobile_zoom(frame, true);

        var containerRect = container.getBoundingClientRect();
        var containerWidth = containerRect.width;
        if (!containerWidth) {
            return;
        }
        var targetHeight = containerRect.height;
        var frameArea = container.parentElement;
        if (frameArea) {
            var frameAreaHeight = frameArea.getBoundingClientRect().height;
            if (frameAreaHeight) {
                targetHeight = frameAreaHeight;
            }
        }

        var baseWidth = belchertown_parse_radar_dimension(frame.getAttribute("data-radar-base-width"));
        var baseHeight = belchertown_parse_radar_dimension(frame.getAttribute("data-radar-base-height"));

        if (!baseWidth) {
            baseWidth = belchertown_parse_radar_dimension(frame.getAttribute("width"));
        }
        if (!baseHeight) {
            baseHeight = belchertown_parse_radar_dimension(frame.getAttribute("height"));
        }

        if (!baseWidth || baseWidth < 480) {
            baseWidth = 650;
        }
        if (!baseHeight || baseHeight < 260) {
            baseHeight = Math.round(baseWidth * 360 / 650);
        }

        frame.setAttribute("data-radar-base-width", baseWidth);
        frame.setAttribute("data-radar-base-height", baseHeight);

        if (containerWidth >= baseWidth) {
            belchertown_clear_windy_radar_scale(frame, container);
            return;
        }

        var scale = containerWidth / baseWidth;
        var frameHeight = baseHeight;
        if (targetHeight) {
            frameHeight = Math.max(baseHeight, Math.ceil(targetHeight / scale));
        }
        var displayHeight = Math.ceil(frameHeight * scale);

        if (container.classList) {
            container.classList.add("radar_image--scaled-frame");
        }
        var displayHeightValue = displayHeight + "px";
        if (container.style.getPropertyValue("--radar-frame-display-height") !== displayHeightValue) {
            container.style.setProperty("--radar-frame-display-height", displayHeightValue);
        }

        var frameWidthValue = baseWidth + "px";
        var frameHeightValue = frameHeight + "px";
        var frameTransformValue = "scale(" + scale + ")";
        if (frame.style.width !== frameWidthValue) {
            frame.style.width = frameWidthValue;
        }
        if (frame.style.height !== frameHeightValue) {
            frame.style.height = frameHeightValue;
        }
        if (frame.style.maxWidth !== "none") {
            frame.style.maxWidth = "none";
        }
        if (frame.style.minHeight !== "0px" && frame.style.minHeight !== "0") {
            frame.style.minHeight = "0";
        }
        if (frame.style.transform !== frameTransformValue) {
            frame.style.transform = frameTransformValue;
        }
        if (frame.style.transformOrigin !== "left top" && frame.style.transformOrigin !== "top left") {
            frame.style.transformOrigin = "top left";
        }
    });
}

function belchertown_schedule_windy_radar_scale(root, force) {
    var viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
    if (!force && belchertownWindyRadarViewportWidth === viewportWidth) {
        return;
    }
    belchertownWindyRadarViewportWidth = viewportWidth;

    window.clearTimeout(belchertownWindyRadarResizeTimer);
    belchertownWindyRadarResizeTimer = window.setTimeout(function() {
        belchertown_scale_windy_radar_iframes(root || document);
    }, 100);
}

function belchertown_schedule_deferred_iframes(root, delayMs, options) {
    options = options || {};
    var loadFrames = function() {
        belchertown_load_deferred_iframes(root);
    };
    var delay = parseInt(delayMs, 10);
    var rootElement = (root && root.nodeType === 1) ? root : null;
    var scheduled = false;

    if (!isFinite(delay) || delay < 0) {
        delay = 0;
    }

    var scheduleLoad = function() {
        if (scheduled) {
            return;
        }
        scheduled = true;

        window.setTimeout(function() {
            if ("requestIdleCallback" in window) {
                window.requestIdleCallback(loadFrames, {timeout: 2500});
            } else {
                loadFrames();
            }
        }, delay);
    };

    if (options.waitUntilVisible === true && rootElement && "IntersectionObserver" in window) {
        var observer = new IntersectionObserver(function(entries) {
            for (var i = 0; i < entries.length; i++) {
                if (entries[i].isIntersecting || entries[i].intersectionRatio > 0) {
                    observer.disconnect();
                    scheduleLoad();
                    break;
                }
            }
        }, {
            root: null,
            rootMargin: options.rootMargin || "200px 0px",
            threshold: typeof options.threshold === "number" ? options.threshold : 0.01,
        });
        observer.observe(rootElement);

        if (typeof options.fallbackDelayMs === "number" && options.fallbackDelayMs >= 0) {
            window.setTimeout(function() {
                observer.disconnect();
                scheduleLoad();
            }, options.fallbackDelayMs);
        }
        return;
    }

    scheduleLoad();
}

function belchertown_parse_rgb_color(color) {
    var value = String(color || "").trim();
    var match;

    if (value.charAt(0) === "#") {
        value = value.slice(1);
        if (value.length === 3) {
            value = value.replace(/(.)/g, "$1$1");
        }
        if (value.length === 6 && /^[0-9a-fA-F]+$/.test(value)) {
            return [
                parseInt(value.slice(0, 2), 16),
                parseInt(value.slice(2, 4), 16),
                parseInt(value.slice(4, 6), 16),
            ];
        }
    }

    match = value.match(/^rgba?\(([^)]+)\)$/i);
    if (match) {
        return match[1].split(",").slice(0, 3).map(function(part) {
            return Math.max(0, Math.min(255, parseFloat(part)));
        });
    }

    return null;
}

function belchertown_rgb_to_hex(rgb) {
    return "#" + rgb.map(function(channel) {
        return Math.round(channel).toString(16).padStart(2, "0");
    }).join("");
}

function belchertown_relative_luminance(rgb) {
    var channels = rgb.map(function(channel) {
        var value = channel / 255;
        return value <= 0.03928 ? value / 12.92 : Math.pow((value + 0.055) / 1.055, 2.4);
    });

    return (0.2126 * channels[0]) + (0.7152 * channels[1]) + (0.0722 * channels[2]);
}

function belchertown_contrast_ratio(foreground, background) {
    var foregroundLum = belchertown_relative_luminance(foreground);
    var backgroundLum = belchertown_relative_luminance(background);
    var lighter = Math.max(foregroundLum, backgroundLum);
    var darker = Math.min(foregroundLum, backgroundLum);

    return (lighter + 0.05) / (darker + 0.05);
}

function belchertown_effective_background_color(element) {
    var current = element;

    while (current && current !== document.documentElement) {
        var color = window.getComputedStyle(current).backgroundColor;
        var parsed = belchertown_parse_rgb_color(color);
        if (parsed && !/rgba\([^,]+,[^,]+,[^,]+,\s*0\s*\)/i.test(color)) {
            return parsed;
        }
        current = current.parentElement;
    }

    return belchertown_parse_rgb_color(window.getComputedStyle(document.body).backgroundColor) || [255, 255, 255];
}

function belchertown_readable_color(color, background, minimumRatio) {
    var rgb = belchertown_parse_rgb_color(color);
    var bg = Array.isArray(background) ? background : belchertown_parse_rgb_color(background);
    var ratio = parseFloat(minimumRatio);

    if (!rgb || !bg) {
        return color;
    }
    if (!isFinite(ratio) || ratio <= 0) {
        ratio = 4.5;
    }
    if (belchertown_contrast_ratio(rgb, bg) >= ratio) {
        return color;
    }

    var target = belchertown_relative_luminance(bg) > 0.45 ? [0, 0, 0] : [255, 255, 255];
    for (var step = 1; step <= 24; step++) {
        var mix = step / 24;
        var candidate = rgb.map(function(channel, index) {
            return (channel * (1 - mix)) + (target[index] * mix);
        });
        if (belchertown_contrast_ratio(candidate, bg) >= ratio) {
            return belchertown_rgb_to_hex(candidate);
        }
    }

    return belchertown_rgb_to_hex(target);
}

function belchertown_apply_readable_color(selector, color, minimumRatio) {
    jQuery(selector).each(function() {
        var background = belchertown_effective_background_color(this);
