                        ),
                        makeRecord(
                            "$obs.label.records_consec_days_with_rain",
                            null,
                            { value: "$year_days_with_rain[0] $obs.label.records_days_text", dateText: "$year_days_with_rain[1]", dateRaw: null },
                            { value: "$at_days_with_rain[0] $obs.label.records_days_text", dateText: "$at_days_with_rain[1]", dateRaw: null },
                            {
                                omitTime: true,
                                datePrefix: "$obs.label.records_ending ",
                                blankPeriods: ["day", "yesterday"],
                                periodValues: {
                                    week: { value: "$week_days_with_rain[0] $obs.label.records_days_text", dateText: "$week_days_with_rain[1]", dateRaw: "$week_days_with_rain[1]" },
                                    month: { value: "$month_days_with_rain[0] $obs.label.records_days_text", dateText: "$month_days_with_rain[1]", dateRaw: "$month_days_with_rain[1]" }
                                }
                            }
                        ),
                        makeRecord(
                            "$obs.label.records_consec_days_without_rain",
                            null,
                            { value: "$year_days_without_rain[0] $obs.label.records_days_text", dateText: "$year_days_without_rain[1]", dateRaw: null },
                            { value: "$at_days_without_rain[0] $obs.label.records_days_text", dateText: "$at_days_without_rain[1]", dateRaw: null },
                            {
                                omitTime: true,
                                datePrefix: "$obs.label.records_ending ",
                                blankPeriods: ["day", "yesterday"],
                                periodValues: {
                                    week: { value: "$week_days_without_rain[0] $obs.label.records_days_text", dateText: "$week_days_without_rain[1]", dateRaw: "$week_days_without_rain[1]" },
                                    month: { value: "$month_days_without_rain[0] $obs.label.records_days_text", dateText: "$month_days_without_rain[1]", dateRaw: "$month_days_without_rain[1]" }
                                }
                            }
                        )
                    ]
                },
                {
                    title: "$obs.label.records_humidity_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: [
                        makeRecord(
                            "$obs.label.records_high_humidity",
                            metric("humidity", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.outHumidity.max", dateText: "$year.outHumidity.maxtime", dateRaw: "$year.outHumidity.maxtime.raw" },
                            { value: "$alltime.outHumidity.max", dateText: "$alltime.outHumidity.maxtime", dateRaw: "$alltime.outHumidity.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_lowest_humidity",
                            metric("humidity", "min", "mintime", "mintime_raw"),
                            { value: "$year.outHumidity.min", dateText: "$year.outHumidity.mintime", dateRaw: "$year.outHumidity.mintime.raw" },
                            { value: "$alltime.outHumidity.min", dateText: "$alltime.outHumidity.mintime", dateRaw: "$alltime.outHumidity.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_highest_dewpoint",
                            metric("dewpoint", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.dewpoint.max", dateText: "$year.dewpoint.maxtime", dateRaw: "$year.dewpoint.maxtime.raw" },
                            { value: "$alltime.dewpoint.max", dateText: "$alltime.dewpoint.maxtime", dateRaw: "$alltime.dewpoint.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_lowest_dewpoint",
                            metric("dewpoint", "min", "mintime", "mintime_raw"),
                            { value: "$year.dewpoint.min", dateText: "$year.dewpoint.mintime", dateRaw: "$year.dewpoint.mintime.raw" },
                            { value: "$alltime.dewpoint.min", dateText: "$alltime.dewpoint.mintime", dateRaw: "$alltime.dewpoint.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    ]
                },
                {
                    title: "$obs.label.records_barometer_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: [
                        makeRecord(
                            "$obs.label.records_high_barometer",
                            metric("barometer", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.barometer.max", dateText: "$year.barometer.maxtime", dateRaw: "$year.barometer.maxtime.raw" },
                            { value: "$alltime.barometer.max", dateText: "$alltime.barometer.maxtime", dateRaw: "$alltime.barometer.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_low_barometer",
                            metric("barometer", "min", "mintime", "mintime_raw"),
                            { value: "$year.barometer.min", dateText: "$year.barometer.mintime", dateRaw: "$year.barometer.mintime.raw" },
                            { value: "$alltime.barometer.min", dateText: "$alltime.barometer.mintime", dateRaw: "$alltime.barometer.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    ]
                }
            ];

            if (hasRadiation || hasUv) {
                var sunRows = [];

                if (hasUv) {
                    sunRows.push(
                        makeRecord(
                            "$obs.label.records_high_uv",
                            metric("uv", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.UV.max", dateText: "$year.UV.maxtime", dateRaw: "$year.UV.maxtime.raw" },
                            { value: "$alltime.UV.max", dateText: "$alltime.UV.maxtime", dateRaw: "$alltime.UV.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    );
                }

                if (hasRadiation) {
                    sunRows.push(
                        makeRecord(
                            "$obs.label.records_high_solar_rad",
                            metric("solar_radiation", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.radiation.max", dateText: "$year.radiation.maxtime", dateRaw: "$year.radiation.maxtime.raw" },
                            { value: "$alltime.radiation.max", dateText: "$alltime.radiation.maxtime", dateRaw: "$alltime.radiation.maxtime.raw" },
