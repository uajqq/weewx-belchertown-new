                                { omitTime: true, hideDatePeriods: ["day", "yesterday", "week", "month", "year", "alltime"] }
                            ),
                            ##makeRecord(
                            ##   "$obs.label.records_month_high_sunshine",
                            ##    null,
                            ##    { value: "$year_suniest_month[1] $unit.label.sunshineDur", dateText: "$year_suniest_month[0]", dateRaw: null },
                            ##    { value: "$at_suniest_month[1] $unit.label.sunshineDur", dateText:"$at_suniest_month[0]", dateRaw: null },
                            ##    { dashPeriods: ["day", "yesterday", "week", "month"] }
                            ##),
                            ##makeRecord(
                            ##    "$obs.label.records_year_hight_sunshine",
                            ##    null,
                            ##    { value: "$year.sunshineDur.sum" , dateText: "$current.dateTime.format('%Y')", dateRaw: null  },
                            ##    { value: "$at_sunshineDur_highest_year[1] $unit.label.sunshineDur", dateText: "$at_sunshineDur_highest_year[0]", dateRaw: null },
                            ##    { 
                            ##      dashPeriods: ["day", "yesterday", "week", "month"],
                            ##    }
                            ##),

                        );
