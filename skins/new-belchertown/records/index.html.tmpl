                            { value: "$at_rainiest_month[1] $unit.label.rain", dateText: "$at_rainiest_month[0]", dateRaw: null },
                            { 
                              dashPeriods: ["day", "yesterday", "week", "month"],
                            }
                        ),
                        makeRecord(
                            "$obs.label.records_total_rainfall",
                            metric("rain", "sum", null, null),
