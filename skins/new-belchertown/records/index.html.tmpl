                            yesterday: { value: "$yesterday_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($yesterday_outTemp_range_min[2] - $yesterday_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$yesterday_outTemp_range_min[0]", dateRaw: "$yesterday_outTemp_range_min[0]" },
