            return sections;
        }

        function updateSectionPeriodHeader(section, labels) {
            if (!section || !section.length) {
                return;
            }

            section.find(".records-section-card__period-header-cell--day").text(displayText("$obs.label.snapshot_period_day"));
            section.find(".records-section-card__period-header-cell--yesterday").text(displayText("$obs.label.snapshot_period_yesterday"));
            section.find(".records-section-card__period-header-cell--week").text(displayText("$obs.label.snapshot_period_7days"));
            section.find(".records-section-card__period-header-cell--month").text(displayText("$obs.label.snapshot_period_month"));
            section.find(".records-section-card__period-header-cell--year").text(displayText(labels.year || ""));
            section.find(".records-section-card__period-header-cell--alltime").text(displayText(labels.alltime || "$obs.label.records_all_time"));
        }

        function snapshotMetric(periodData, metricDef) {
            if (!periodData || !metricDef) {
                return null;
            }

            var groupData = periodData[metricDef.group];
            if (!groupData) {
                return null;
            }

            var value = groupData[metricDef.valueKey];
            if (typeof value === "undefined" || value === null || value === "") {
                return null;
            }

            return {
                value: jQuery.trim(displayText(value)),
                dateText: jQuery.trim(displayText(groupData[metricDef.timeKey] || "--")) || "--",
                dateRaw: metricDef.rawKey ? groupData[metricDef.rawKey] : null,
                valueDetail: null
            };
        }

        function formatValueHtml(valueText, valueDetailText) {
            var mainValue = jQuery.trim(String(valueText || "--")) || "--";
            var detailValue = jQuery.trim(String(valueDetailText || ""));
            var html = '<span class="records-record-period__value-main">' + escapeHtml(mainValue) + '</span>';

            if (detailValue) {
                html += '<span class="records-record-period__value-detail">' + escapeHtml(detailValue) + '</span>';
            }

            return html;
        }

        function parseSnapshotMoment(dateRaw, dateText) {
            var rawText = jQuery.trim(String(dateRaw || ""));
            if (rawText && /^\d+(\.\d+)?$/.test(rawText)) {
                var raw = parseFloat(rawText);
                if (isFinite(raw) && raw > 0) {
                    return tzAdjustedMoment(raw);
                }
            }

            var text = jQuery.trim(displayText(dateText || ""));
            if (!text || text === "--") {
                return null;
            }

            if (/^\d+(\.\d+)?$/.test(text)) {
                var textEpoch = parseFloat(text);
                if (isFinite(textEpoch) && textEpoch > 0) {
                    return tzAdjustedMoment(textEpoch);
                }
            }

            var m = moment(text, belchertown_date_time_parse_formats(), true);

            if (!m.isValid()) {
                m = moment(text);
            }

            if (m.isValid()) {
                return tzAdjustedMoment(m.unix());
            }

            return null;
        }

        function splitDateNote(text) {
            var rawText = jQuery.trim(displayText(text || ""));
            if (!rawText) {
                return { primary: "", secondary: "" };
            }

            var noteStart = rawText.indexOf("(");
            if (noteStart > 0) {
                return {
                    primary: jQuery.trim(rawText.substring(0, noteStart)),
                    secondary: jQuery.trim(rawText.substring(noteStart).replace(/^\(|\)$/g, ""))
                };
            }

            return { primary: rawText, secondary: "" };
        }

        function formatSnapshotDateHtml(dateRaw, dateText, periodKey, options) {
            var rowOptions = options || {};
            var hideDatePeriods = rowOptions.hideDatePeriods || [];
            if (hideDatePeriods.indexOf(periodKey) !== -1) {
                return "";
            }

            var parsed = parseSnapshotMoment(dateRaw, dateText);

            if (rowOptions.omitTime) {
                var sourceText = jQuery.trim(displayText(dateText || ""));
                var dateLine = "";

                if (/^\d{4}$/.test(sourceText)) {
                    dateLine = sourceText;
                } else if (parsed && parsed.isValid()) {
                    dateLine = parsed.format(belchertown_moment_compact_date_format(periodKey === "alltime"));
                } else {
                    dateLine = sourceText;
                }

                if (!dateLine || dateLine === "--") {
                    return '<span class="records-record-period__date-line">--</span>';
                }

                if (rowOptions.datePrefix) {
                    dateLine = displayText(rowOptions.datePrefix) + dateLine;
                }

                if (rowOptions.datePrefix) {
                    return '<span class="records-record-period__date-line records-record-period__date-line--prefixed">' + escapeHtml(dateLine) + '</span>';
                }

                return '<span class="records-record-period__date-line">' + escapeHtml(dateLine) + '</span>';
            }

            if (periodKey === "yesterday") {
                if (parsed && parsed.isValid()) {
                    return '<span class="records-record-period__time-line">' + escapeHtml(parsed.format("LT")) + '</span>';
                }

                return '<span class="records-record-period__time-line">--</span>';
            }

            if (periodKey === "day") {
                if (parsed && parsed.isValid()) {
                    return '<span class="records-record-period__time-line">' + escapeHtml(parsed.format("LT")) + '</span>';
                }

                return '<span class="records-record-period__time-line">--</span>';
            }

            if (parsed && parsed.isValid()) {
                var dateLine = parsed.format(belchertown_moment_compact_date_format(periodKey === "alltime"));
                var timeLine = parsed.format("LT");
                return '<span class="records-record-period__date-line">' + escapeHtml(dateLine) + '</span>' +
                       '<span class="records-record-period__time-line">' + escapeHtml(timeLine) + '</span>';
            }

            var text = jQuery.trim(displayText(dateText || ""));
            if (!text || text === "--") {
                return '<span class="records-record-period__date-line">--</span>';
            }

            var split = splitDateNote(text);
            if (split.secondary) {
                return '<span class="records-record-period__date-line">' + escapeHtml(split.primary) + '</span>' +
                       '<span class="records-record-period__time-line">' + escapeHtml(split.secondary) + '</span>';
            }

            return '<span class="records-record-period__date-line">' + escapeHtml(text) + '</span>';
        }

        function periodDisplay(periodData, metricDef, fallback, options) {
            var metricValue = snapshotMetric(periodData, metricDef);
            if (metricValue) {
                return metricValue;
            }

            if (options && options.noMetricFallback) {
                return {
                    value: "--",
                    dateText: "--",
                    dateRaw: null,
                    valueDetail: null
                };
            }

            return {
                value: fallback.value,
                dateText: fallback.dateText,
                dateRaw: fallback.dateRaw,
                valueDetail: fallback.valueDetail || null
            };
        }

        function applyPeriod(recordCard, periodClass, labelText, periodKey, periodData, metricDef, fallback, rowOptions) {
            var options = rowOptions || {};
            var blankPeriods = options.blankPeriods || [];
            if (blankPeriods.indexOf(periodKey) !== -1) {
                recordCard.find(periodClass + " .records-record-period__label").text(displayText(labelText));
                recordCard.find(periodClass + " .records-record-period__value").html(formatValueHtml("--", ""));
                recordCard.find(periodClass + " .records-record-period__date").removeClass("records-record-period__date--prefixed").html('<span class="records-record-period__date-line">--</span>');
                return;
            }

            var dashPeriods = options.dashPeriods || [];
            if (dashPeriods.indexOf(periodKey) !== -1) {
                recordCard.find(periodClass + " .records-record-period__label").text(displayText(labelText));
                recordCard.find(periodClass + " .records-record-period__value").html(formatValueHtml("--", ""));
                recordCard.find(periodClass + " .records-record-period__date").removeClass("records-record-period__date--prefixed").html('<span class="records-record-period__date-line">--</span>');
                return;
            }

            var periodValues = (rowOptions && rowOptions.periodValues) || null;
            var periodFallback = fallback;
            if (periodValues && periodValues[periodKey]) {
                periodFallback = periodValues[periodKey];
            }

            var resolved = periodDisplay(periodData, metricDef, periodFallback, rowOptions);
            var valueText = resolved.value;
            var valueDetailText = resolved.valueDetail;
            var dateText = resolved.dateText;
            var dateRaw = resolved.dateRaw;
            var formattedDateHtml = formatSnapshotDateHtml(dateRaw, dateText, periodKey, rowOptions);
            var formattedValueHtml = formatValueHtml(valueText, valueDetailText);
            var dateElement = recordCard.find(periodClass + " .records-record-period__date");

            recordCard.find(periodClass + " .records-record-period__label").text(displayText(labelText));
            recordCard.find(periodClass + " .records-record-period__value").html(formattedValueHtml);
            if (rowOptions && rowOptions.datePrefix) {
                dateElement.addClass("records-record-period__date--prefixed");
            } else {
                dateElement.removeClass("records-record-period__date--prefixed");
            }
            dateElement.html(formattedDateHtml);
        }

        var sectionsContainer = jQuery("#records-sections");
        if (!sectionsContainer.length) {
            return;
        }

        sectionsContainer.empty();

        var sections = getRecordsSectionsConfig();

        sections.forEach(function(sectionConfig) {
            var section = jQuery(
                    '<section class="records-section-card">' +
                        '<div class="records-section-card__header">' +
                            '<h2 class="records-section-card__title"></h2>' +
                        '</div>' +
                        '<div class="records-section-card__table">' +
                            '<div class="records-section-card__period-header">' +
                                '<div class="records-section-card__period-header-spacer" aria-hidden="true"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--day"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--yesterday"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--week"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--month"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--year"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--alltime"></div>' +
                            '</div>' +
                            '<div class="records-section-card__body"></div>' +
                        '</div>' +
                    '</section>'
                );
            section.find(".records-section-card__title").text(displayText(sectionConfig.title));
            updateSectionPeriodHeader(section, {
                year: sectionConfig.yearLabel,
                alltime: sectionConfig.alltimeLabel
            });

            var sectionBody = section.find(".records-section-card__body");

            sectionConfig.rows.forEach(function(rowConfig) {
                var recordTitle = displayText(rowConfig.label);

                var recordCard = jQuery(
                '<article class="records-record-card">' +
                    '<h3 class="records-record-card__title"></h3>' +
                    '<section class="records-record-period records-record-period--day">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--yesterday">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--week">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--month">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--year">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--alltime">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                '</article>'
            );

                recordCard.find(".records-record-card__title").text(recordTitle);

                var yearValueText = jQuery.trim(displayText(rowConfig.year.value || "--")) || "--";
                var yearValueDetailText = jQuery.trim(displayText(rowConfig.year.valueDetail || ""));
                var yearDateText = jQuery.trim(displayText(rowConfig.year.dateText || "--")) || "--";
                var yearDateRaw = rowConfig.year.dateRaw;
                var rowOptions = rowConfig.options || {};
                var yearDateHtml = formatSnapshotDateHtml(yearDateRaw, yearDateText, "year", rowOptions);
                var yearValueHtml = formatValueHtml(yearValueText, yearValueDetailText);

                recordCard.find(".records-record-period--year .records-record-period__label").text(displayText(sectionConfig.yearLabel));
                recordCard.find(".records-record-period--year .records-record-period__value").html(yearValueHtml);
                recordCard.find(".records-record-period--year .records-record-period__date").html(yearDateHtml);

                var fallback = {
                    value: yearValueText,
                    valueDetail: yearValueDetailText,
                    dateText: yearDateText,
                    dateRaw: yearDateRaw
                };

                applyPeriod(
                    recordCard,
                    ".records-record-period--day",
                    "$obs.label.snapshot_period_day",
                    "day",
                    snapshotData ? snapshotData["day"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--yesterday",
                    "$obs.label.snapshot_period_yesterday",
                    "yesterday",
                    snapshotData ? snapshotData["yesterday"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--week",
                    "$obs.label.snapshot_period_7days",
                    "week",
                    snapshotData ? snapshotData["week"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--month",
                    "$obs.label.snapshot_period_month",
                    "month",
                    snapshotData ? snapshotData["month"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );

                var alltimeValueText = jQuery.trim(displayText(rowConfig.alltime.value || "--")) || "--";
                var alltimeValueDetailText = jQuery.trim(displayText(rowConfig.alltime.valueDetail || ""));
                var alltimeDateText = jQuery.trim(displayText(rowConfig.alltime.dateText || "--")) || "--";
                var alltimeDateRaw = rowConfig.alltime.dateRaw;
                var alltimeDateHtml = formatSnapshotDateHtml(alltimeDateRaw, alltimeDateText, "alltime", rowOptions);
                var alltimeValueHtml = formatValueHtml(alltimeValueText, alltimeValueDetailText);
                var alltimeLabelText = rowOptions.hideAlltimeLabel ? "" : sectionConfig.alltimeLabel;
                recordCard.find(".records-record-period--alltime .records-record-period__label").text(displayText(alltimeLabelText));
                recordCard.find(".records-record-period--alltime .records-record-period__value").html(alltimeValueHtml);
                recordCard.find(".records-record-period--alltime .records-record-period__date").html(alltimeDateHtml);

                sectionBody.append(recordCard);
            });

            sectionsContainer.append(section);
        });
    }

    jQuery(document).ready(function() {
        if (typeof ajaxweewx === "function") {
            ajaxweewx().then(function(weewxData) {
                enhanceRecordsPage(weewxData);
            }).catch(function() {
                enhanceRecordsPage(null);
            });
        } else {
            enhanceRecordsPage(null);
        }

        // #if $year.sunshineDur.has_data
        jQuery("#year-suniest-day-ts").text( tzAdjustedMoment($suniest_day[0]).format( "$obs.label.time_records_page_month_day_year" ) );
        jQuery("#at-suniest-day-ts").text( tzAdjustedMoment($at_suniest_day[0] - 0).format( "$obs.label.time_records_page_month_day_year" ) );
        // #end if

    });

    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initRecordsPage);
    } else {
        initRecordsPage();
    }
    })();
</script>

