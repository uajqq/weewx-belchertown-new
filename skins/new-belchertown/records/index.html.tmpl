                    { value: "$year_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($year_outTemp_range_min[2] - $year_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$year_outTemp_range_min[0]", dateRaw: "$year_outTemp_range_min[0]" },
                    { value: "$at_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($at_outTemp_range_min[2] - $at_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$at_outTemp_range_min[0]", dateRaw: "$at_outTemp_range_min[0]" },
                    {
