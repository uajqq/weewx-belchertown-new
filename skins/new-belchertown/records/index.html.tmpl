#errorCatcher Echo
#encoding UTF-8
#set global $page = "records"

#import datetime
#from datetime import timedelta

#include "header.html.tmpl"

<script type="text/javascript">
    (function() {
    function initRecordsPage() {
    var moment_locale = "$moment_locale_js";
    moment.locale(moment_locale);

    function enhanceRecordsPage(snapshotData) {
        function decodeHtmlEntities(value) {
            var text = String(value || "");
            if (typeof belchertown_decode_html_entities === "function") {
                return belchertown_decode_html_entities(text);
            }

            var textarea = document.createElement("textarea");
            var decoded = text;
            var previous;
            var i;

            for (i = 0; i < 3 && decoded.indexOf("&") !== -1; i++) {
                previous = decoded;
                textarea.innerHTML = previous;
                decoded = textarea.value;
                if (decoded === previous) {
                    break;
                }
            }

            return decoded;
        }

        function displayText(value) {
            return decodeHtmlEntities(String(value || ""));
        }

        function belchertown_trim(value) {
            return value == null ? "" : String(value).trim();
        }

        function buildElementFromHtml(html) {
            var wrapper = document.createElement("div");
            wrapper.innerHTML = html;
            return wrapper.firstElementChild;
        }

        function setElementText(root, selector, text) {
            var el = root.querySelector(selector);
            if (el) {
                el.textContent = text;
            }
        }

        function setElementHtml(root, selector, html) {
            var el = root.querySelector(selector);
            if (el) {
                el.innerHTML = html;
            }
        }

        function escapeHtml(value) {
            return displayText(value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#39;");
        }

        function makeRecord(label, metric, year, alltime, options) {
            return {
                label: label,
                metric: metric,
                year: year,
                alltime: alltime,
                options: options || {}
            };
        }

        function metric(group, valueKey, timeKey, rawKey) {
            return {
                group: group,
                valueKey: valueKey,
                timeKey: timeKey,
                rawKey: rawKey
            };
        }

        function getRecordsSectionsConfig() {
            var hasAppTemp = "$year.appTemp.has_data" === "True" && "$alltime.appTemp.has_data" === "True";
            var hasWindRun = "$year.windrun.has_data" === "True" && "$alltime.windrun.has_data" === "True";
            var hasRadiation = "$year.radiation.has_data" === "True";
            var hasUv = "$year.UV.has_data" === "True";
            var hasSunshineDur = "$year.sunshineDur.has_data" === "True";

            var temperatureRows = [
                makeRecord(
                    "$obs.label.records_high_temp",
                    metric("outTemp", "max", "maxtime", "maxtime_raw"),
                    { value: "$year.outTemp.max", dateText: "$year.outTemp.maxtime", dateRaw: "$year.outTemp.maxtime.raw" },
                    { value: "$alltime.outTemp.max", dateText: "$alltime.outTemp.maxtime", dateRaw: "$alltime.outTemp.maxtime.raw" },
                    { hideDatePeriods: ["day"] }
                ),
                makeRecord(
                    "$obs.label.records_avg_temp",
                    metric("outTemp", "average"),
                    { value: "$year.outTemp.avg" },
                    { value: "$alltime.outTemp.avg" },
                    { hideDatePeriods: ["day", "yesterday", "week", "month", "year", "alltime"] }
                ),
                makeRecord(
                    "$obs.label.records_low_temp",
                    metric("outTemp", "min", "mintime", "mintime_raw"),
                    { value: "$year.outTemp.min", dateText: "$year.outTemp.mintime", dateRaw: "$year.outTemp.mintime.raw" },
                    { value: "$alltime.outTemp.min", dateText: "$alltime.outTemp.mintime", dateRaw: "$alltime.outTemp.mintime.raw" },
                    { hideDatePeriods: ["day"] }
                )
            ];

            if (hasAppTemp) {
                temperatureRows.push(
                    makeRecord(
                        "$obs.label.records_high_apptemp",
                        metric("appTemp", "max", "maxtime", "maxtime_raw"),
                        { value: "$year.appTemp.max", dateText: "$year.appTemp.maxtime", dateRaw: "$year.appTemp.maxtime.raw" },
                        { value: "$alltime.appTemp.max", dateText: "$alltime.appTemp.maxtime", dateRaw: "$alltime.appTemp.maxtime.raw" },
                        { hideDatePeriods: ["day"] }
                    ),
                    makeRecord(
                        "$obs.label.records_low_apptemp",
                        metric("appTemp", "min", "mintime", "mintime_raw"),
                        { value: "$year.appTemp.min", dateText: "$year.appTemp.mintime", dateRaw: "$year.appTemp.mintime.raw" },
                        { value: "$alltime.appTemp.min", dateText: "$alltime.appTemp.mintime", dateRaw: "$alltime.appTemp.mintime.raw" },
                        { hideDatePeriods: ["day"] }
                    )
                );
            }

            temperatureRows.push(
                makeRecord(
                    "$obs.label.records_high_heatindex",
                    metric("heatindex", "max", "maxtime", "maxtime_raw"),
                    { value: "$year.heatindex.max", dateText: "$year.heatindex.maxtime", dateRaw: "$year.heatindex.maxtime.raw" },
                    { value: "$alltime.heatindex.max", dateText: "$alltime.heatindex.maxtime", dateRaw: "$alltime.heatindex.maxtime.raw" },
                    { hideDatePeriods: ["day"] }
                ),
                makeRecord(
                    "$obs.label.records_low_windchill",
                    metric("windchill", "max", "maxtime", "maxtime_raw"),
                    { value: "$year.windchill.min", dateText: "$year.windchill.mintime", dateRaw: "$year.windchill.mintime.raw" },
                    { value: "$alltime.windchill.min", dateText: "$alltime.windchill.mintime", dateRaw: "$alltime.windchill.mintime.raw" },
                    { hideDatePeriods: ["day"] }
                ),
                makeRecord(
                    "$obs.label.records_largest_temp_range",
                    null,
                    { value: "$year_outTemp_range_max[1] $unit.label.outTemp", valueDetail: "($year_outTemp_range_max[2] - $year_outTemp_range_max[3] $unit.label.outTemp)", dateText: "$year_outTemp_range_max[0]", dateRaw: "$year_outTemp_range_max[0]" },
                    { value: "$at_outTemp_range_max[1] $unit.label.outTemp", valueDetail: "($at_outTemp_range_max[2] - $at_outTemp_range_max[3] $unit.label.outTemp)", dateText: "$at_outTemp_range_max[0]", dateRaw: "$at_outTemp_range_max[0]" },
                    {
                        omitTime: true,
                        hideDatePeriods: ["day"],
                        blankPeriods: ["day"],
                        periodValues: {
                            yesterday: { value: "$yesterday_outTemp_range_max[1] $unit.label.outTemp", valueDetail: "($yesterday_outTemp_range_max[2] - $yesterday_outTemp_range_max[3] $unit.label.outTemp)", dateText: "$yesterday_outTemp_range_max[0]", dateRaw: "$yesterday_outTemp_range_max[0]" },
                            week: { value: "$week_outTemp_range_max[1] $unit.label.outTemp", valueDetail: "($week_outTemp_range_max[2] - $week_outTemp_range_max[3] $unit.label.outTemp)", dateText: "$week_outTemp_range_max[0]", dateRaw: "$week_outTemp_range_max[0]" },
                            month: { value: "$month_outTemp_range_max[1] $unit.label.outTemp", valueDetail: "($month_outTemp_range_max[2] - $month_outTemp_range_max[3] $unit.label.outTemp)", dateText: "$month_outTemp_range_max[0]", dateRaw: "$month_outTemp_range_max[0]" }
                        }
                    }
                ),
                makeRecord(
                    "$obs.label.records_smallest_temp_range",
                    null,
                    { value: "$year_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($year_outTemp_range_min[2] - $year_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$year_outTemp_range_min[0]", dateRaw: "$year_outTemp_range_min[0]" },
                    { value: "$at_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($at_outTemp_range_min[2] - $at_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$at_outTemp_range_min[0]", dateRaw: "$at_outTemp_range_min[0]" },
                    {
                        omitTime: true,
                        ##hideDatePeriods: ["day"],
                        blankPeriods: ["day", "yesterday"],
                        periodValues: {
                            yesterday: { value: "$yesterday_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($yesterday_outTemp_range_min[2] - $yesterday_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$yesterday_outTemp_range_min[0]", dateRaw: "$yesterday_outTemp_range_min[0]" },
                            week: { value: "$week_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($week_outTemp_range_min[2] - $week_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$week_outTemp_range_min[0]", dateRaw: "$week_outTemp_range_min[0]" },
                            month: { value: "$month_outTemp_range_min[1] $unit.label.outTemp", valueDetail: "($month_outTemp_range_min[2] - $month_outTemp_range_min[3] $unit.label.outTemp)", dateText: "$month_outTemp_range_min[0]", dateRaw: "$month_outTemp_range_min[0]" }
                        }
                    }
                )
            );

            var windRows = [
                makeRecord(
                    "$obs.label.records_strongest_wind",
                    metric("windGust", "max", "maxtime", "maxtime_raw"),
                    { value: "$year.windGust.max", dateText: "$year.windGust.maxtime", dateRaw: "$year.windGust.maxtime.raw" },
                    { value: "$alltime.windGust.max", dateText: "$alltime.windGust.maxtime", dateRaw: "$alltime.windGust.maxtime.raw" },
                    { hideDatePeriods: ["day"] }
                )
            ];

            if (hasWindRun) {
                windRows.push(
                    makeRecord(
                        "$obs.label.records_daily_windrun",
                        metric("wind", "windrun_maxsum", "windrun_maxsumtime", "windrun_maxsumtime_raw"),
                        { value: "$year.windrun.maxsum", dateText: "$year.windrun.maxsumtime", dateRaw: "$year.windrun.maxsumtime.raw" },
                        { value: "$alltime.windrun.maxsum", dateText: "$alltime.windrun.maxsumtime", dateRaw: "$alltime.windrun.maxsumtime.raw" },
                        { omitTime: true, hideDatePeriods: ["day", "yesterday"] }
                    )
                );
            }

            var sections = [
                {
                    title: "$obs.label.records_temperature_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: temperatureRows
                },
                {
                    title: "$obs.label.records_wind_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: windRows
                },
                {
                    title: "$obs.label.records_rain_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: [
                        makeRecord(
                            "$obs.label.records_highest_daily_rainfall",
                            metric("rain", "maxsum", "maxsumtime", "maxsumtime_raw"),
                            { value: "$rainiest_day[1] $unit.label.rain", dateText: "$rainiest_day[0]", dateRaw: "$rainiest_day[0]" },
                            { value: "$at_rainiest_day[1] $unit.label.rain", dateText: "$at_rainiest_day[0]", dateRaw: "$at_rainiest_day[0]" },
                            { omitTime: true, hideDatePeriods: ["day", "yesterday"] }
                        ),
                        makeRecord(
                            "$obs.label.records_highest_daily_rainrate",
                            metric("rain", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.rainRate.max", dateText: "$year.rainRate.maxtime", dateRaw: "$year.rainRate.maxtime.raw" },
                            { value: "$alltime.rainRate.max", dateText: "$alltime.rainRate.maxtime", dateRaw: "$alltime.rainRate.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_month_high_rainfall",
                            null,
                            { value: "$year_rainiest_month[1] $unit.label.rain", dateText: "$year_rainiest_month[0]", dateRaw: null },
                            { value: "$at_rainiest_month[1] $unit.label.rain", dateText: "$at_rainiest_month[0]", dateRaw: null },
                            {
                                dashPeriods: ["day", "yesterday", "week", "month"]
                            }
                        ),
                        makeRecord(
                            "$obs.label.records_total_rainfall",
                            metric("rain", "sum", null, null),
                            { value: "$year.rain.sum", dateText: "$current.dateTime.format('%Y')", dateRaw: null },
                            { value: "$at_rain_highest_year[1] $unit.label.rain", dateText: "$at_rain_highest_year[0]", dateRaw: null },
                            { omitTime: true, hideDatePeriods: ["day", "yesterday"], hideAlltimeLabel: true }
                        ),
                        makeRecord(
                            "$obs.label.records_consec_days_with_rain",
                            null,
                            { value: "$year_days_with_rain[0] $obs.label.records_days_text", dateText: "$year_days_with_rain[1]", dateRaw: null },
                            { value: "$at_days_with_rain[0] $obs.label.records_days_text", dateText: "$at_days_with_rain[1]", dateRaw: null },
                            {
                                omitTime: true,
                                datePrefix: "$obs.label.records_ending ",
                                blankPeriods: ["day", "yesterday"],
                                periodValues: {
                                    week: { value: "$week_days_with_rain[0] $obs.label.records_days_text", dateText: "$week_days_with_rain[1]", dateRaw: "$week_days_with_rain[1]" },
                                    month: { value: "$month_days_with_rain[0] $obs.label.records_days_text", dateText: "$month_days_with_rain[1]", dateRaw: "$month_days_with_rain[1]" }
                                }
                            }
                        ),
                        makeRecord(
                            "$obs.label.records_consec_days_without_rain",
                            null,
                            { value: "$year_days_without_rain[0] $obs.label.records_days_text", dateText: "$year_days_without_rain[1]", dateRaw: null },
                            { value: "$at_days_without_rain[0] $obs.label.records_days_text", dateText: "$at_days_without_rain[1]", dateRaw: null },
                            {
                                omitTime: true,
                                datePrefix: "$obs.label.records_ending ",
                                blankPeriods: ["day", "yesterday"],
                                periodValues: {
                                    week: { value: "$week_days_without_rain[0] $obs.label.records_days_text", dateText: "$week_days_without_rain[1]", dateRaw: "$week_days_without_rain[1]" },
                                    month: { value: "$month_days_without_rain[0] $obs.label.records_days_text", dateText: "$month_days_without_rain[1]", dateRaw: "$month_days_without_rain[1]" }
                                }
                            }
                        )
                    ]
                },
                {
                    title: "$obs.label.records_humidity_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: [
                        makeRecord(
                            "$obs.label.records_high_humidity",
                            metric("humidity", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.outHumidity.max", dateText: "$year.outHumidity.maxtime", dateRaw: "$year.outHumidity.maxtime.raw" },
                            { value: "$alltime.outHumidity.max", dateText: "$alltime.outHumidity.maxtime", dateRaw: "$alltime.outHumidity.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_lowest_humidity",
                            metric("humidity", "min", "mintime", "mintime_raw"),
                            { value: "$year.outHumidity.min", dateText: "$year.outHumidity.mintime", dateRaw: "$year.outHumidity.mintime.raw" },
                            { value: "$alltime.outHumidity.min", dateText: "$alltime.outHumidity.mintime", dateRaw: "$alltime.outHumidity.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_highest_dewpoint",
                            metric("dewpoint", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.dewpoint.max", dateText: "$year.dewpoint.maxtime", dateRaw: "$year.dewpoint.maxtime.raw" },
                            { value: "$alltime.dewpoint.max", dateText: "$alltime.dewpoint.maxtime", dateRaw: "$alltime.dewpoint.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_lowest_dewpoint",
                            metric("dewpoint", "min", "mintime", "mintime_raw"),
                            { value: "$year.dewpoint.min", dateText: "$year.dewpoint.mintime", dateRaw: "$year.dewpoint.mintime.raw" },
                            { value: "$alltime.dewpoint.min", dateText: "$alltime.dewpoint.mintime", dateRaw: "$alltime.dewpoint.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    ]
                },
                {
                    title: "$obs.label.records_barometer_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: [
                        makeRecord(
                            "$obs.label.records_high_barometer",
                            metric("barometer", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.barometer.max", dateText: "$year.barometer.maxtime", dateRaw: "$year.barometer.maxtime.raw" },
                            { value: "$alltime.barometer.max", dateText: "$alltime.barometer.maxtime", dateRaw: "$alltime.barometer.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        ),
                        makeRecord(
                            "$obs.label.records_low_barometer",
                            metric("barometer", "min", "mintime", "mintime_raw"),
                            { value: "$year.barometer.min", dateText: "$year.barometer.mintime", dateRaw: "$year.barometer.mintime.raw" },
                            { value: "$alltime.barometer.min", dateText: "$alltime.barometer.mintime", dateRaw: "$alltime.barometer.mintime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    ]
                }
            ];

            if (hasRadiation || hasUv || hasSunshineDur) {
                var sunRows = [];

                if (hasUv) {
                    sunRows.push(
                        makeRecord(
                            "$obs.label.records_high_uv",
                            metric("uv", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.UV.max", dateText: "$year.UV.maxtime", dateRaw: "$year.UV.maxtime.raw" },
                            { value: "$alltime.UV.max", dateText: "$alltime.UV.maxtime", dateRaw: "$alltime.UV.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    );
                }

                if (hasRadiation) {
                    sunRows.push(
                        makeRecord(
                            "$obs.label.records_high_solar_rad",
                            metric("solar_radiation", "max", "maxtime", "maxtime_raw"),
                            { value: "$year.radiation.max", dateText: "$year.radiation.maxtime", dateRaw: "$year.radiation.maxtime.raw" },
                            { value: "$alltime.radiation.max", dateText: "$alltime.radiation.maxtime", dateRaw: "$alltime.radiation.maxtime.raw" },
                            { hideDatePeriods: ["day"] }
                        )
                    );
                }

                if (hasSunshineDur) {
                    sunRows.push(
                        makeRecord(
                            "$obs.label.records_total_sunshine",
                            metric("sunshineDur", "sum"),
                            { value: "$year.sunshineDur.sum", dateText: null },
                            { value: "$alltime.sunshineDur.sum", dateText: null },
                            { omitTime: true, hideDatePeriods: ["day", "yesterday", "week", "month", "year", "alltime"] }
                        )
                    );
                }

                sections.push({
                    title: "$obs.label.records_sun_records",
                    yearLabel: "$current.dateTime.format('%Y')",
                    alltimeLabel: "$obs.label.records_all_time",
                    rows: sunRows
                });
            }

            return sections;
        }

        function updateSectionPeriodHeader(section, labels) {
            if (!section) {
                return;
            }

            setElementText(section, ".records-section-card__period-header-cell--day", displayText("$obs.label.snapshot_period_day"));
            setElementText(section, ".records-section-card__period-header-cell--yesterday", displayText("$obs.label.snapshot_period_yesterday"));
            setElementText(section, ".records-section-card__period-header-cell--week", displayText("$obs.label.snapshot_period_7days"));
            setElementText(section, ".records-section-card__period-header-cell--month", displayText("$obs.label.snapshot_period_month"));
            setElementText(section, ".records-section-card__period-header-cell--year", displayText(labels.year || ""));
            setElementText(section, ".records-section-card__period-header-cell--alltime", displayText(labels.alltime || "$obs.label.records_all_time"));
        }

        function snapshotMetric(periodData, metricDef) {
            if (!periodData || !metricDef) {
                return null;
            }

            var groupData = periodData[metricDef.group];
            if (!groupData) {
                return null;
            }

            var value = groupData[metricDef.valueKey];
            if (typeof value === "undefined" || value === null || value === "") {
                return null;
            }

            return {
                value: belchertown_trim(displayText(value)),
                dateText: belchertown_trim(displayText(groupData[metricDef.timeKey] || "--")) || "--",
                dateRaw: metricDef.rawKey ? groupData[metricDef.rawKey] : null,
                valueDetail: null
            };
        }

        function formatValueHtml(valueText, valueDetailText) {
            var mainValue = belchertown_trim(String(valueText || "--")) || "--";
            var detailValue = belchertown_trim(String(valueDetailText || ""));
            var html = '<span class="records-record-period__value-main">' + escapeHtml(mainValue) + '</span>';

            if (detailValue) {
                html += '<span class="records-record-period__value-detail">' + escapeHtml(detailValue) + '</span>';
            }

            return html;
        }

        function parseSnapshotMoment(dateRaw, dateText) {
            var rawText = belchertown_trim(String(dateRaw || ""));
            if (rawText && /^\d+(\.\d+)?$/.test(rawText)) {
                var raw = parseFloat(rawText);
                if (isFinite(raw) && raw > 0) {
                    return tzAdjustedMoment(raw);
                }
            }

            var text = belchertown_trim(displayText(dateText || ""));
            if (!text || text === "--") {
                return null;
            }

            if (/^\d+(\.\d+)?$/.test(text)) {
                var textEpoch = parseFloat(text);
                if (isFinite(textEpoch) && textEpoch > 0) {
                    return tzAdjustedMoment(textEpoch);
                }
            }

            var m = moment(text, belchertown_date_time_parse_formats(), true);

            if (!m.isValid()) {
                m = moment(text);
            }

            if (m.isValid()) {
                return tzAdjustedMoment(m.unix());
            }

            return null;
        }

        function splitDateNote(text) {
            var rawText = belchertown_trim(displayText(text || ""));
            if (!rawText) {
                return { primary: "", secondary: "" };
            }

            var noteStart = rawText.indexOf("(");
            if (noteStart > 0) {
                return {
                    primary: belchertown_trim(rawText.substring(0, noteStart)),
                    secondary: belchertown_trim(rawText.substring(noteStart).replace(/^\(|\)$/g, ""))
                };
            }

            return { primary: rawText, secondary: "" };
        }

        function formatSnapshotDateHtml(dateRaw, dateText, periodKey, options) {
            var rowOptions = options || {};
            var hideDatePeriods = rowOptions.hideDatePeriods || [];
            if (hideDatePeriods.indexOf(periodKey) !== -1) {
                return "";
            }

            var parsed = parseSnapshotMoment(dateRaw, dateText);

            if (rowOptions.omitTime) {
                var sourceText = belchertown_trim(displayText(dateText || ""));
                var dateLine = "";

                if (/^\d{4}$/.test(sourceText)) {
                    dateLine = sourceText;
                } else if (parsed && parsed.isValid()) {
                    dateLine = parsed.format(belchertown_moment_compact_date_format(periodKey === "alltime"));
                } else {
                    dateLine = sourceText;
                }

                if (!dateLine || dateLine === "--") {
                    return '<span class="records-record-period__date-line">--</span>';
                }

                if (rowOptions.datePrefix) {
                    dateLine = displayText(rowOptions.datePrefix) + dateLine;
                }

                if (rowOptions.datePrefix) {
                    return '<span class="records-record-period__date-line records-record-period__date-line--prefixed">' + escapeHtml(dateLine) + '</span>';
                }

                return '<span class="records-record-period__date-line">' + escapeHtml(dateLine) + '</span>';
            }

            if (periodKey === "yesterday") {
                if (parsed && parsed.isValid()) {
                    return '<span class="records-record-period__time-line">' + escapeHtml(parsed.format("LT")) + '</span>';
                }

                return '<span class="records-record-period__time-line">--</span>';
            }

            if (periodKey === "day") {
                if (parsed && parsed.isValid()) {
                    return '<span class="records-record-period__time-line">' + escapeHtml(parsed.format("LT")) + '</span>';
                }

                return '<span class="records-record-period__time-line">--</span>';
            }

            if (parsed && parsed.isValid()) {
                var dateLine = parsed.format(belchertown_moment_compact_date_format(periodKey === "alltime"));
                var timeLine = parsed.format("LT");
                return '<span class="records-record-period__date-line">' + escapeHtml(dateLine) + '</span>' +
                       '<span class="records-record-period__time-line">' + escapeHtml(timeLine) + '</span>';
            }

            var text = belchertown_trim(displayText(dateText || ""));
            if (!text || text === "--") {
                return '<span class="records-record-period__date-line">--</span>';
            }

            var split = splitDateNote(text);
            if (split.secondary) {
                return '<span class="records-record-period__date-line">' + escapeHtml(split.primary) + '</span>' +
                       '<span class="records-record-period__time-line">' + escapeHtml(split.secondary) + '</span>';
            }

            return '<span class="records-record-period__date-line">' + escapeHtml(text) + '</span>';
        }

        function periodDisplay(periodData, metricDef, fallback, options) {
            var metricValue = snapshotMetric(periodData, metricDef);
            if (metricValue) {
                return metricValue;
            }

            if (metricDef || (options && options.noMetricFallback)) {
                return {
                    value: "--",
                    dateText: "--",
                    dateRaw: null,
                    valueDetail: null
                };
            }

            return {
                value: fallback.value,
                dateText: fallback.dateText,
                dateRaw: fallback.dateRaw,
                valueDetail: fallback.valueDetail || null
            };
        }

        function applyPeriod(recordCard, periodClass, labelText, periodKey, periodData, metricDef, fallback, rowOptions) {
            var options = rowOptions || {};
            var blankPeriods = options.blankPeriods || [];
            var dashPeriods = options.dashPeriods || [];
            if (blankPeriods.indexOf(periodKey) !== -1 || dashPeriods.indexOf(periodKey) !== -1) {
                setElementText(recordCard, periodClass + " .records-record-period__label", displayText(labelText));
                setElementHtml(recordCard, periodClass + " .records-record-period__value", formatValueHtml("--", ""));
                var blankDateElement = recordCard.querySelector(periodClass + " .records-record-period__date");
                if (blankDateElement) {
                    blankDateElement.classList.remove("records-record-period__date--prefixed");
                    blankDateElement.innerHTML = '<span class="records-record-period__date-line">--</span>';
                }
                return;
            }

            var periodValues = (rowOptions && rowOptions.periodValues) || null;
            var periodFallback = fallback;
            if (periodValues && periodValues[periodKey]) {
                periodFallback = periodValues[periodKey];
            }

            var resolved = periodDisplay(periodData, metricDef, periodFallback, rowOptions);
            var valueText = resolved.value;
            var valueDetailText = resolved.valueDetail;
            var dateText = resolved.dateText;
            var dateRaw = resolved.dateRaw;
            var formattedDateHtml = formatSnapshotDateHtml(dateRaw, dateText, periodKey, rowOptions);
            var formattedValueHtml = formatValueHtml(valueText, valueDetailText);
            var dateElement = recordCard.querySelector(periodClass + " .records-record-period__date");

            setElementText(recordCard, periodClass + " .records-record-period__label", displayText(labelText));
            setElementHtml(recordCard, periodClass + " .records-record-period__value", formattedValueHtml);
            if (dateElement) {
                dateElement.classList.toggle("records-record-period__date--prefixed", !!(rowOptions && rowOptions.datePrefix));
                dateElement.innerHTML = formattedDateHtml;
            }
        }

        var sectionsContainer = document.getElementById("records-sections");
        if (!sectionsContainer) {
            return;
        }

        sectionsContainer.innerHTML = "";

        var sections = getRecordsSectionsConfig();

        sections.forEach(function(sectionConfig) {
            var section = buildElementFromHtml(
                    '<section class="records-section-card">' +
                        '<div class="records-section-card__header">' +
                            '<h2 class="records-section-card__title"></h2>' +
                        '</div>' +
                        '<div class="records-section-card__table">' +
                            '<div class="records-section-card__period-header">' +
                                '<div class="records-section-card__period-header-spacer" aria-hidden="true"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--day"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--yesterday"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--week"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--month"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--year"></div>' +
                                '<div class="records-section-card__period-header-cell records-section-card__period-header-cell--alltime"></div>' +
                            '</div>' +
                            '<div class="records-section-card__body"></div>' +
                        '</div>' +
                    '</section>'
                );
            setElementText(section, ".records-section-card__title", displayText(sectionConfig.title));
            updateSectionPeriodHeader(section, {
                year: sectionConfig.yearLabel,
                alltime: sectionConfig.alltimeLabel
            });

            var sectionBody = section.querySelector(".records-section-card__body");

            sectionConfig.rows.forEach(function(rowConfig) {
                var recordTitle = displayText(rowConfig.label);

                var recordCard = buildElementFromHtml(
                '<article class="records-record-card">' +
                    '<h3 class="records-record-card__title"></h3>' +
                    '<section class="records-record-period records-record-period--day">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--yesterday">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--week">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--month">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--year">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                    '<section class="records-record-period records-record-period--alltime">' +
                        '<div class="records-record-period__label"></div>' +
                        '<div class="records-record-period__value"></div>' +
                        '<div class="records-record-period__date"></div>' +
                    '</section>' +
                '</article>'
            );

                setElementText(recordCard, ".records-record-card__title", recordTitle);

                var yearValueText = belchertown_trim(displayText(rowConfig.year.value || "--")) || "--";
                var yearValueDetailText = belchertown_trim(displayText(rowConfig.year.valueDetail || ""));
                var yearDateText = belchertown_trim(displayText(rowConfig.year.dateText || "--")) || "--";
                var yearDateRaw = rowConfig.year.dateRaw;
                var rowOptions = rowConfig.options || {};
                var yearDateHtml = formatSnapshotDateHtml(yearDateRaw, yearDateText, "year", rowOptions);
                var yearValueHtml = formatValueHtml(yearValueText, yearValueDetailText);

                setElementText(recordCard, ".records-record-period--year .records-record-period__label", displayText(sectionConfig.yearLabel));
                setElementHtml(recordCard, ".records-record-period--year .records-record-period__value", yearValueHtml);
                setElementHtml(recordCard, ".records-record-period--year .records-record-period__date", yearDateHtml);

                var fallback = {
                    value: yearValueText,
                    valueDetail: yearValueDetailText,
                    dateText: yearDateText,
                    dateRaw: yearDateRaw
                };

                applyPeriod(
                    recordCard,
                    ".records-record-period--day",
                    "$obs.label.snapshot_period_day",
                    "day",
                    snapshotData ? snapshotData["day"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--yesterday",
                    "$obs.label.snapshot_period_yesterday",
                    "yesterday",
                    snapshotData ? snapshotData["yesterday"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--week",
                    "$obs.label.snapshot_period_7days",
                    "week",
                    snapshotData ? snapshotData["week"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );
                applyPeriod(
                    recordCard,
                    ".records-record-period--month",
                    "$obs.label.snapshot_period_month",
                    "month",
                    snapshotData ? snapshotData["month"] : null,
                    rowConfig.metric,
                    fallback,
                    rowOptions
                );

                var alltimeValueText = belchertown_trim(displayText(rowConfig.alltime.value || "--")) || "--";
                var alltimeValueDetailText = belchertown_trim(displayText(rowConfig.alltime.valueDetail || ""));
                var alltimeDateText = belchertown_trim(displayText(rowConfig.alltime.dateText || "--")) || "--";
                var alltimeDateRaw = rowConfig.alltime.dateRaw;
                var alltimeDateHtml = formatSnapshotDateHtml(alltimeDateRaw, alltimeDateText, "alltime", rowOptions);
                var alltimeValueHtml = formatValueHtml(alltimeValueText, alltimeValueDetailText);
                var alltimeLabelText = rowOptions.hideAlltimeLabel ? "" : sectionConfig.alltimeLabel;
                setElementText(recordCard, ".records-record-period--alltime .records-record-period__label", displayText(alltimeLabelText));
                setElementHtml(recordCard, ".records-record-period--alltime .records-record-period__value", alltimeValueHtml);
                setElementHtml(recordCard, ".records-record-period--alltime .records-record-period__date", alltimeDateHtml);

                if (sectionBody) {
                    sectionBody.appendChild(recordCard);
                }
            });

            sectionsContainer.appendChild(section);
        });
    }

    if (typeof ajaxweewx === "function") {
        ajaxweewx().then(function(weewxData) {
            enhanceRecordsPage(weewxData);
        }).catch(function() {
            enhanceRecordsPage(null);
        });
    } else {
        enhanceRecordsPage(null);
    }

    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initRecordsPage);
    } else {
        initRecordsPage();
    }
    })();
</script>

<div class="site-inner">
    <main class="content">
        <article class="weewx records" itemscope itemtype="https://schema.org/CreativeWork">

            #include "page-header.inc"

            #if os.path.exists("records.inc")
            <div class="wx-records-description">
                #include "records.inc"
            </div>
            #end if

            <div id="records-sections" class="records-sections"></div>

            #if os.path.exists("records-table.inc")
            <div class="records-sections records-custom-sections">
                #include "records-table.inc"
            </div>
            #end if

        </article>
</div>
</div>


#include "footer.html.tmpl"
