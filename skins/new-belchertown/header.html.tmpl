        #if not $load_core_js
        <script>
            (function() {
                function setSimpleTheme(themeName, toggleOverride) {
                    if (toggleOverride) {
                        sessionStorage.setItem("theme", "toggleOverride");
                    }

                    if (themeName === "dark") {
                        document.documentElement.setAttribute("data-bs-theme", "dark");
                        document.body.classList.add("dark");
                        document.body.classList.remove("light");
                        sessionStorage.setItem("currentTheme", "dark");
                        #if $Extras.has_key('logo_image_dark') and $Extras.logo_image_dark != ""
                        var darkLogo = document.getElementById("logo_image");
                        if (darkLogo) {
                            darkLogo.setAttribute("src", "$Extras.logo_image_dark");
                        }
                        #end if
                    } else if (themeName === "light") {
                        document.documentElement.setAttribute("data-bs-theme", "light");
                        document.body.classList.add("light");
                        document.body.classList.remove("dark");
                        sessionStorage.setItem("currentTheme", "light");
                        #if $Extras.has_key('logo_image') and $Extras.logo_image != ""
                        var lightLogo = document.getElementById("logo_image");
                        if (lightLogo) {
                            lightLogo.setAttribute("src", "$Extras.logo_image");
                        }
                        #end if
                    }

                    document.querySelectorAll(".themeSwitchInput").forEach(function(el) {
                        el.checked = themeName === "dark";
                    });
                }

                function getSimplePreferredColorSchemeTheme() {
                    if (typeof window.matchMedia !== "function") {
                        return null;
                    }

                    try {
                        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                            return "dark";
                        }
                        if (window.matchMedia("(prefers-color-scheme: light)").matches) {
                            return "light";
                        }
                    } catch (err) {
                        return null;
                    }

                    return null;
                }

                function getSimpleAutoTheme() {
                    var fallbackTheme = "$bodyTheme";
                    var preferredTheme = getSimplePreferredColorSchemeTheme();

                    if (preferredTheme === "dark" || preferredTheme === "light") {
                        return preferredTheme;
                    }

                    if (fallbackTheme !== "dark" && fallbackTheme !== "light") {
                        fallbackTheme = "light";
                    }

                    return fallbackTheme;
                }

                function watchSimpleAutoTheme() {
                    if (typeof window.matchMedia !== "function" || watchSimpleAutoTheme.isAttached) {
                        return;
                    }

                    try {
                        var colorSchemeQuery = window.matchMedia("(prefers-color-scheme: dark)");
                        var colorSchemeChanged = function(event) {
                            if (sessionStorage.getItem("theme") === "auto") {
                                setSimpleTheme(event.matches ? "dark" : "light", false);
                            }
                        };

                        if (typeof colorSchemeQuery.addEventListener === "function") {
                            colorSchemeQuery.addEventListener("change", colorSchemeChanged);
                            watchSimpleAutoTheme.isAttached = true;
                        } else if (typeof colorSchemeQuery.addListener === "function") {
                            colorSchemeQuery.addListener(colorSchemeChanged);
                            watchSimpleAutoTheme.isAttached = true;
                        }
                    } catch (err) {
                        return;
                    }
                }

                function applySimpleAutoTheme() {
                    setSimpleTheme(getSimpleAutoTheme(), false);
                    watchSimpleAutoTheme();
                }

                function initSimpleTheme() {
                    var requestedTheme = "";
                    try {
                        requestedTheme = new URLSearchParams(window.location.search).get("theme") || "";
                    } catch (err) {
                        requestedTheme = "";
                    }

                    if (requestedTheme === "dark" || requestedTheme === "light") {
                        setSimpleTheme(requestedTheme, true);
                    } else if (requestedTheme === "auto") {
                        sessionStorage.setItem("theme", "auto");
                        applySimpleAutoTheme();
                    } else if (sessionStorage.getItem("theme") === "toggleOverride") {
                        setSimpleTheme(sessionStorage.getItem("currentTheme") || "$bodyTheme", false);
                    } else if (sessionStorage.getItem("theme") === "auto") {
                        applySimpleAutoTheme();
                    }

                    document.querySelectorAll(".themeSwitchInput").forEach(function(el) {
                        el.addEventListener("change", function(event) {
                            setSimpleTheme(event.target.checked ? "dark" : "light", true);
                        });
                    });
                }

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", initSimpleTheme);
                } else {
                    initSimpleTheme();
                }
            })();
        </script>
