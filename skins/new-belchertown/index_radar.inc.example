<!-- Rename this file to index_radar.inc.
See other example at https://github.com/poblabs/weewx-belchertown/issues/703 -->
#if $page == "kiosk"
#set $default_radar_html = $radar_html_kiosk
#else
#set $default_radar_html = $radar_html
#end if
## Webcam image cache-busting interval in milliseconds. Set to 0 to disable.
#set $webcam_reload_interval_ms = 300000
<div id="tabs-container" class="belchertown-radar-tabs" data-webcam-reload-interval-ms="$webcam_reload_interval_ms">
    <!-- Nav tabs -->
    <ul class="nav nav-tabs tabs-menu" role="tablist">
        <li role="presentation" class="active"><a href="#radar" aria-controls="radar" role="tab">Radar</a></li>
        <li role="presentation"><a href="#webcam" aria-controls="webcam" role="tab">Station Camera</a></li>
    </ul>
    <!-- Tabs contents -->
    <div class="belchertown-radar-tab-panels">
        <div id="radar" class="belchertown-radar-tab-panel is-active">
            <div class="radar_image">$default_radar_html</div>
        </div>
        <div id="webcam" class="belchertown-radar-tab-panel">
            <a name="webcam" href="https://your_domain/your_photo.jpg" target="_blank"><img src="https://your_domain/your_photo.jpg"></a>
        </div>
    </div>
</div>

<style>
.dark .tabs-menu > li > a {
    padding: 0px 5px;
}

.dark .nav-tabs>li.active>a, .dark .nav-tabs>li.active>a:focus, .dark .nav-tabs>li.active>a:hover {
    color: #e5554e;
}

.active a {
    /* color:red; */
}

.belchertown-radar-tabs {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    min-height: 0;
}

.belchertown-radar-tabs .tabs-menu {
    flex: 0 0 auto;
}

.belchertown-radar-tab-panels {
    flex: 1 1 auto;
    width: 100%;
    min-height: 0;
}

.belchertown-radar-tab-panel {
    display: none;
    width: 100%;
    height: 100%;
    min-height: 0;
}

.belchertown-radar-tab-panel.is-active {
    display: block;
}

.belchertown-radar-tab-panel .radar_image,
.belchertown-radar-tab-panel iframe,
.belchertown-radar-tab-panel a,
.belchertown-radar-tab-panel img {
    width: 100%;
    height: 100%;
    min-height: 0;
}

.belchertown-radar-tab-panel a,
.belchertown-radar-tab-panel img {
    display: block;
}

.tabs-menu > li > a {
    padding: 0px 5px;
}
</style>
